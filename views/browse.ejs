<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Browse Games — <%= settings.title %></title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="facebook-domain-verification" content="noj6ccmsehjq0v2oeq2e716fgyaqq0" />
</head>
<body>

<%- include('partials/announcement') %>
<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse" class="active">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
  </div>
</nav>

<div class="browse-header">
  <h1>Browse Games</h1>
  <form class="filters" method="GET" action="/browse">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
      </svg>
      <input type="text" id="liveSearch" name="search" placeholder="Search games..." value="<%= search %>" autocomplete="off"
        oninput="liveFilterGames(this.value)"
        onkeydown="if(event.key==='Enter'){event.preventDefault();liveFilterGames(this.value);}">
    </div>
    <select class="filter-select" name="platform" onchange="this.form.submit()">
      <option value="">All Platforms</option>
      <option value="PS5" <%= platform === 'PS5' ? 'selected' : '' %>>PS5</option>
      <option value="PS4" <%= platform === 'PS4' ? 'selected' : '' %>>PS4</option>
      <option value="PS4/PS5" <%= platform === 'PS4/PS5' ? 'selected' : '' %>>PS4/PS5</option>
    </select>
    <select class="filter-select" name="genre" onchange="this.form.submit()">
      <option value="">All Genres</option>
      <% genres.forEach(g => { %>
        <option value="<%= g %>" <%= genre === g ? 'selected' : '' %>><%= g %></option>
      <% }) %>
    </select>
    <button type="submit" class="filter-btn">Search</button>
    <% if (search || platform || genre) { %>
      <a href="/browse" class="btn-outline btn" style="padding:0.65rem 1rem;font-size:0.875rem;">Clear</a>
    <% } %>
  </form>
  <div class="results-count" id="resultsCount"><%= games.length %> game<%= games.length !== 1 ? 's' : '' %> found</div>
</div>

<!-- UPCOMING GAMES — hidden when searching/filtering -->
<% if (!search && !platform && !genre) { %>
<%- include('partials/upcoming-section', { upcoming, noBorderTop: true }) %>
<% } %>

<!-- AVAILABLE GAMES grouped by price category -->
<div id="section-rentals" style="<%= upcoming.length > 0 ? 'border-top:1px solid #1a1a1a;' : '' %>">
  <% if (games.length === 0) { %>
    <div id="no-rentals-msg" style="text-align:center;padding:4rem;color:var(--text-secondary);">
      <div style="font-size:3rem;margin-bottom:1rem;">🎮</div>
      <p>No games found. Try a different search.</p>
    </div>
  <% } else { %>
    <%
      // Group games by price category
      const catMap = {};
      const uncategorized = [];
      games.forEach(g => {
        if (g.price_category_id) {
          const cat = priceCategories.find(c => c.id === g.price_category_id);
          if (cat) {
            if (!catMap[cat.id]) catMap[cat.id] = { cat, games: [] };
            catMap[cat.id].games.push(g);
          } else {
            uncategorized.push(g);
          }
        } else {
          uncategorized.push(g);
        }
      });
      // Order categories as defined in admin
      const orderedCats = priceCategories.filter(c => catMap[c.id]);
    %>
    <% orderedCats.forEach((cat, ci) => { %>
    <div class="section cat-section" id="cat-section-<%= cat.id %>" style="<%= ci > 0 || upcoming.length > 0 ? 'border-top:1px solid #1a1a1a;padding-top:3rem;' : 'padding-top:2rem;' %>">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
        <h2 class="section-title" style="margin:0;"><%= cat.name %></h2>
        <span style="font-size:0.78rem;color:var(--text-secondary);background:#111;border:1px solid #222;border-radius:20px;padding:0.2rem 0.65rem;"><%= catMap[cat.id].games.length %> game<%= catMap[cat.id].games.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="games-grid rentals-grid">
        <% catMap[cat.id].games.forEach(game => { %><%- include('partials/game-card', { game }) %><% }) %>
      </div>
    </div>
    <% }) %>
    <% if (uncategorized.length > 0) { %>
    <div class="section cat-section" id="cat-section-uncategorized" style="border-top:1px solid #1a1a1a;padding-top:3rem;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;">
        <h2 class="section-title" style="margin:0;">Other Games</h2>
        <span style="font-size:0.78rem;color:var(--text-secondary);background:#111;border:1px solid #222;border-radius:20px;padding:0.2rem 0.65rem;"><%= uncategorized.length %> game<%= uncategorized.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="games-grid rentals-grid">
        <% uncategorized.forEach(game => { %><%- include('partials/game-card', { game }) %><% }) %>
      </div>
    </div>
    <% } %>
  <% } %>
</div>

<!-- PS PLUS MONTHLY GAMES -->
<% if (psplus.length > 0) { %>
<div class="section" id="section-psplus" style="border-top:1px solid #1a1a1a;padding-top:3rem;">
  <h2 class="section-title" style="display:flex;align-items:center;gap:0.6rem;">
    <span style="background:linear-gradient(135deg,#FFD700,#ffa500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">★</span>
    PS Plus Deluxe — Monthly Games
    <a href="/ps-plus" style="font-size:0.8rem;font-weight:500;color:var(--ps-blue);text-decoration:none;margin-left:0.5rem;">View Full Page →</a>
  </h2>
  <p style="color:var(--text-secondary);font-size:0.85rem;margin:-0.5rem 0 1.5rem;">Access these games anytime through a PS Plus Deluxe account rental.</p>
  <div id="psplus-entries">
  <% psplus.forEach(entry => { %>
    <%
      const monthNames = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
      const mName = monthNames[entry.month] || '';
      const gamesList = (entry.games_list || '').split('\n').map(g => g.trim()).filter(Boolean);
    %>
    <div class="psplus-browse-entry" data-games="<%= gamesList.join('|').toLowerCase() %>" data-month="<%= mName.toLowerCase() %> <%= entry.year %>">
      <div class="psplus-browse-header">
        <% if (entry.cover_image) { %>
          <img src="<%= entry.cover_image %>" alt="<%= mName %> <%= entry.year %>" class="psplus-browse-cover">
        <% } else { %>
          <div class="psplus-browse-cover psplus-browse-cover-placeholder">
            <span style="font-size:1.5rem;">★</span>
          </div>
        <% } %>
        <div>
          <div style="font-weight:700;font-size:1rem;color:#FFD700;"><%= mName %> <span style="color:#888;"><%= entry.year %></span></div>
          <div style="font-size:0.75rem;color:#555;margin-top:0.2rem;"><%= gamesList.length %> game<%= gamesList.length !== 1 ? 's' : '' %></div>
          <% if (entry.notes) { %><div style="font-size:0.75rem;color:#666;margin-top:0.15rem;"><%= entry.notes %></div><% } %>
        </div>
        <a href="/ps-plus" class="btn btn-outline" style="margin-left:auto;padding:0.3rem 0.85rem;font-size:0.78rem;white-space:nowrap;">Rent Access →</a>
      </div>
      <div class="psplus-browse-games">
        <% gamesList.forEach(g => { %>
          <span class="psplus-browse-game-tag"><%= g %></span>
        <% }) %>
      </div>
    </div>
  <% }) %>
  </div>
  <div id="no-psplus-msg" style="display:none;text-align:center;padding:2rem;color:var(--text-secondary);">No PS Plus monthly games match your search.</div>
</div>
<% } %>

<!-- RESERVE MODAL -->
<div class="modal-overlay" id="reserveModal">
  <div class="modal">
    <div style="font-size:1.5rem;margin-bottom:0.5rem;">🔔</div>
    <h2>Reserve a Slot</h2>
    <div id="reserveGameTitle" style="font-weight:700;font-size:1rem;color:#a855f7;margin:0.5rem 0 1rem;"></div>
    <div style="background:#111;border:1px solid #222;border-radius:10px;padding:1rem;margin-bottom:1.25rem;text-align:left;">
      <div style="font-size:0.82rem;color:#bbb;line-height:1.7;margin-bottom:0.75rem;">
        This game is not yet available but you can <strong style="color:#fff;">reserve your slot now</strong>. Message us on Facebook to lock in your reservation!
      </div>
      <div style="font-size:0.78rem;color:var(--ps-blue);font-weight:700;margin-bottom:0.25rem;">📘 Message us on Facebook:</div>
      <div style="font-size:0.8rem;color:#888;">Include the game name and your preferred rental duration.</div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeReserveModal()" style="flex:1;">Cancel</button>
      <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
        class="btn" style="flex:1;text-align:center;background:linear-gradient(135deg,#4a0080,#7b2ff7);color:#fff;font-weight:700;border-radius:50px;padding:0.75rem 1.75rem;text-decoration:none;"
        onclick="closeReserveModal()">📘 Message Us</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/rent-modal') %>

<script>
function liveFilterGames(query) {
  const q = query.trim().toLowerCase();
  // If the page was server-filtered and user clears box, reload to show all
  const wasServerFiltered = '<%= search ? "1" : "" %>' === '1';
  if (wasServerFiltered && !q) {
    const url = new URL(window.location.href);
    url.searchParams.delete('search');
    window.location.href = url.toString();
    return;
  }

  // ── Rental games (grouped by category) ──
  let rentalVisible = 0;
  document.querySelectorAll('.cat-section').forEach(section => {
    let sectionVisible = 0;
    section.querySelectorAll('.game-card').forEach(card => {
      const title = (card.querySelector('.game-title') || {}).textContent || '';
      const platform = (card.querySelector('.game-platform') || {}).textContent || '';
      const desc = (card.querySelector('.game-desc-inline') || {}).textContent || '';
      const match = !q || title.toLowerCase().includes(q) || platform.toLowerCase().includes(q) || desc.toLowerCase().includes(q);
      card.style.display = match ? '' : 'none';
      if (match) { sectionVisible++; rentalVisible++; }
    });
    section.style.display = (q && sectionVisible === 0) ? 'none' : '';
  });
  const rentalSection = document.getElementById('section-rentals');
  if (rentalSection) rentalSection.style.display = (q && rentalVisible === 0) ? 'none' : '';

  // ── Upcoming / Coming Soon ──
  let upcomingVisible = 0;
  document.querySelectorAll('.section[data-upcoming] .game-card').forEach(card => {
    const title = card.dataset.title || '';
    const genre = card.dataset.genre || '';
    const nameEl = card.querySelector('.game-title');
    const nameText = nameEl ? nameEl.textContent.toLowerCase() : '';
    const match = !q || title.includes(q) || genre.includes(q) || nameText.includes(q);
    card.style.display = match ? '' : 'none';
    if (match) upcomingVisible++;
  });
  const upcomingSection = document.querySelector('.section[data-upcoming]');
  if (upcomingSection) upcomingSection.style.display = (q && upcomingVisible === 0) ? 'none' : '';

  // ── PS Plus monthly ──
  let psplusVisible = 0;
  document.querySelectorAll('.psplus-browse-entry').forEach(entry => {
    const games = entry.dataset.games || '';
    const month = entry.dataset.month || '';
    const match = !q || games.includes(q) || month.includes(q);
    entry.style.display = match ? '' : 'none';
    if (match) psplusVisible++;
  });
  const psplusSection = document.getElementById('section-psplus');
  if (psplusSection) psplusSection.style.display = (q && psplusVisible === 0) ? 'none' : '';
  const noPsplus = document.getElementById('no-psplus-msg');
  if (noPsplus) noPsplus.style.display = (q && psplusVisible === 0) ? '' : 'none';

  const counter = document.getElementById('resultsCount');
  if (counter) {
    const total = rentalVisible + upcomingVisible + psplusVisible;
    counter.textContent = q
      ? total + ' result' + (total !== 1 ? 's' : '') + ' found'
      : '<%= games.length %> game' + (<%= games.length %> !== 1 ? 's' : '') + ' found';
  }
}

// Run on page load in case the field has a pre-filled value
(function(){ const s = document.getElementById('liveSearch'); if (s && s.value) liveFilterGames(s.value); })();

function openReserveModal(title) {
  document.getElementById('reserveGameTitle').textContent = title;
  document.getElementById('reserveModal').classList.add('active');
}
function closeReserveModal() { document.getElementById('reserveModal').classList.remove('active'); }
document.getElementById('reserveModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeReserveModal(); });

function openRentModal(title, nt10, nt15, nt30, tr10, tr15, tr30, hasTrophy, hasNt) {
  document.getElementById('modalGameTitle').textContent = title;
  document.getElementById('modalNtP10').textContent = '₱' + nt10;
  document.getElementById('modalNtP15').textContent = '₱' + nt15;
  document.getElementById('modalNtP30').textContent = '₱' + nt30;
  document.getElementById('modalTrP10').textContent = '₱' + tr10;
  document.getElementById('modalTrP15').textContent = '₱' + tr15;
  document.getElementById('modalTrP30').textContent = '₱' + tr30;
  document.getElementById('modalNtSection').style.display = hasNt ? 'block' : 'none';
  document.getElementById('modalTrophySection').style.display = hasTrophy ? 'block' : 'none';
  document.getElementById('rentModal').classList.add('active');
}
function closeRentModal() { document.getElementById('rentModal').classList.remove('active'); }
document.getElementById('rentModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeRentModal(); });
</script>
</body>
</html>




