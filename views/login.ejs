<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — <%= settings.title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; background:#0a0a0a; }
    .login-box {
      background:#141414;
      border:1px solid #222;
      border-radius:20px;
      padding:2.5rem 2rem;
      width:100%;
      max-width:380px;
      text-align:center;
    }
    .login-box img { height:48px; width:auto; margin-bottom:1.5rem; }
    .login-box h1 { font-size:1.25rem; font-weight:800; margin-bottom:0.4rem; }
    .login-box p { color:var(--text-secondary); font-size:0.875rem; margin-bottom:1.75rem; }
    .login-input {
      width:100%;
      background:#1a1a1a;
      border:1px solid #2a2a2a;
      border-radius:10px;
      padding:0.8rem 1rem;
      color:#fff;
      font-size:1rem;
      margin-bottom:1rem;
      box-sizing:border-box;
      transition:border-color 0.2s;
    }
    .login-input:focus { outline:none; border-color:var(--ps-blue); }
    .login-btn {
      width:100%;
      background:var(--ps-blue);
      color:#000;
      font-weight:800;
      font-size:1rem;
      padding:0.85rem;
      border:none;
      border-radius:10px;
      cursor:pointer;
      transition:opacity 0.2s;
    }
    .login-btn:hover { opacity:0.88; }
    .login-error {
      background:rgba(220,50,50,0.12);
      border:1px solid rgba(220,50,50,0.3);
      color:#ff6b6b;
      border-radius:10px;
      padding:0.7rem 1rem;
      font-size:0.875rem;
      margin-bottom:1rem;
    }
    .back-link { display:block; margin-top:1.25rem; color:#444; font-size:0.8rem; text-decoration:none; }
    .back-link:hover { color:#666; }
  </style>
</head>
<body>
  <div class="login-box">
    <a href="/"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>"></a>
    <h1>Admin Panel</h1>
    <p>Enter your password to continue</p>

    <% if (error) { %>
      <div class="login-error">⚠️ <%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <input type="password" name="password" class="login-input" placeholder="Password" autofocus required>
      <button type="submit" class="login-btn">🔐 Login</button>
    </form>

    <a href="/" class="back-link">← Back to website</a>
  </div>
</body>
</html>
