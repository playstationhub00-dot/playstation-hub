<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= game.title %> — Playstation Hub</title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="facebook-domain-verification" content="noj6ccmsehjq0v2oeq2e716fgyaqq0" />
</head>
<body>
<%- include('partials/announcement') %>
<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
  </div>
</nav>

<%
  const promo = settings.promo || { enabled: true, discount_pct: 10, apply_on_days: 30, deposit: 100 };
  const ntSlots  = game.non_trophy_slots || 0;
  const trSlots  = game.trophy_slots || 0;
  const ps4Slots = game.ps4_primary_slots || 0;
  const showPs4  = game.platform === 'PS4' || game.platform === 'PS4/PS5';
  const hasTrophy = !!(game.trophy_account || trSlots > 0);
  const trAvail = trSlots > 0;
  const ntAvail = ntSlots > 0;
  const allUnavail = ntSlots <= 0 && trSlots <= 0 && (!showPs4 || ps4Slots <= 0);
%>

<div class="gd-page">
  <div class="gd-back"><a href="/browse">← Back to Catalog</a></div>

  <div class="gd-layout">

    <!-- LEFT: Cover -->
    <div class="gd-cover-col">
      <% if (game.cover_image) { %>
        <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="gd-cover">
      <% } else { %>
        <div class="gd-cover gd-cover-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;opacity:0.3;">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
      <% } %>
      <!-- Platform badge -->
      <div class="gd-platform-badge"><%= game.platform %></div>
    </div>

    <!-- RIGHT: Detail + Rental Form -->
    <div class="gd-detail-col">

      <!-- Genre + Title -->
      <% if (game.genre) { %>
      <div class="gd-genres">
        <% game.genre.split('/').forEach(g => { %><span class="gd-genre-tag"><%= g.trim().toUpperCase() %></span><% }) %>
      </div>
      <% } %>
      <h1 class="gd-title"><%= game.title %></h1>
      <% if (game.description) { %><p class="gd-desc"><%= game.description %></p><% } %>

      <% if (allUnavail) { %>

      <!-- NO SLOT — Reservation options -->
      <div class="gd-noslot-banner">
        <span class="gd-noslot-icon">⏳</span>
        <div>
          <div class="gd-noslot-title">No Slots Available Right Now</div>
          <div class="gd-noslot-sub">All slots for this game are currently rented. Pick your preferred type and duration, then choose how you'd like to get in line.</div>
        </div>
      </div>

      <!-- SELECT RENTAL TYPE -->
      <div class="gd-section-label" style="margin-top:1.25rem;">SELECT RENTAL TYPE</div>
      <div class="gd-type-options" id="typeOptions">

        <% if (hasTrophy) { %>
        <label class="gd-type-card" id="label-tr">
          <input type="radio" name="rentalType" value="tr" onchange="onTypeChange(this)">
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🏆</span>
              <span class="gd-type-name">Trophy<% if(showPs4){ %> / PS4 Primary<% } %></span>
              <span class="gd-type-status gd-status-rented">Reserved</span>
            </div>
            <div class="gd-type-desc">Perfect for trophy hunters. Play through games at your own pace and earn trophies on your own main account.</div>
          </div>
        </label>
        <% } %>

        <label class="gd-type-card" id="label-nt">
          <input type="radio" name="rentalType" value="nt" onchange="onTypeChange(this)">
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🎮</span>
              <span class="gd-type-name">Non-Trophy</span>
              <span class="gd-type-status gd-status-rented">Reserved</span>
            </div>
            <div class="gd-type-desc">Ideal for casual players focused on the story and experience, without the need for account-linked achievements.</div>
          </div>
        </label>

      </div>

      <!-- SELECT DURATION -->
      <div class="gd-section-label" style="margin-top:1.5rem;">SELECT DURATION</div>
      <div class="gd-duration-grid" id="durationGrid">
        <button class="gd-dur-btn" data-days="10" onclick="onDurChange(this)">
          <span class="gd-dur-days">10</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-10">—</span>
        </button>
        <button class="gd-dur-btn" data-days="15" onclick="onDurChange(this)">
          <span class="gd-dur-days">15</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-15">—</span>
        </button>
        <button class="gd-dur-btn" data-days="30" onclick="onDurChange(this)">
          <span class="gd-dur-days">30</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-30">—</span>
          <% if (promo.enabled) { %><span class="gd-dur-promo"><%= promo.discount_pct %>% OFF</span><% } %>
        </button>
      </div>

      <!-- TOTAL BREAKDOWN -->
      <div class="gd-total-box" id="totalBox" style="display:none;">
        <div class="gd-total-label">ORDER SUMMARY</div>
        <div class="gd-total-rows" id="totalRows"></div>
        <div class="gd-total-final">
          <span>Total</span>
          <span id="totalFinal" style="color:var(--ps-blue);font-size:1.2rem;font-weight:900;"></span>
        </div>
      </div>

      <!-- CHOOSE OPTION -->
      <div class="gd-section-label" style="margin-top:1.5rem;">CHOOSE YOUR OPTION</div>

      <div class="gd-reserve-options">

        <!-- Priority Reservation -->
        <a id="reserveLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="gd-reserve-card gd-reserve-priority">
          <div class="gd-reserve-badge">PRIORITY</div>
          <div class="gd-reserve-icon">⭐</div>
          <div class="gd-reserve-name">Reservation</div>
          <div class="gd-reserve-fee">₱100 fee</div>
          <div class="gd-reserve-note">Fee is deducted from your total rent when a slot opens.</div>
          <div class="gd-reserve-cta">📘 Reserve Now →</div>
        </a>

        <!-- Fall in Line -->
        <a id="queueLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="gd-reserve-card gd-reserve-queue">
          <div class="gd-reserve-icon">🎮</div>
          <div class="gd-reserve-name">Fall in Line</div>
          <div class="gd-reserve-fee">FREE</div>
          <div class="gd-reserve-note">Join the waitlist at no cost. You'll be notified when a slot is available.</div>
          <div class="gd-reserve-cta">📘 Join Waitlist →</div>
        </a>

      </div>

      <% } else { %>

      <!-- SELECT RENTAL TYPE -->
      <div class="gd-section-label">SELECT RENTAL TYPE</div>
      <div class="gd-type-options" id="typeOptions">

        <% if (hasTrophy) { %>
        <label class="gd-type-card" id="label-tr">
          <input type="radio" name="rentalType" value="tr" onchange="onTypeChange(this)">
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🏆</span>
              <span class="gd-type-name">Trophy<% if(showPs4){ %> / PS4 Primary<% } %></span>
              <span class="gd-type-status <%= trAvail ? 'gd-status-avail' : 'gd-status-rented' %>"><%= trAvail ? 'Available' : 'Reserved' %></span>
            </div>
            <div class="gd-type-desc">Perfect for trophy hunters. Play through games at your own pace and earn trophies on your own main account.</div>
          </div>
        </label>
        <% } %>

        <label class="gd-type-card" id="label-nt">
          <input type="radio" name="rentalType" value="nt" onchange="onTypeChange(this)">
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🎮</span>
              <span class="gd-type-name">Non-Trophy</span>
              <span class="gd-type-status <%= ntAvail ? 'gd-status-avail' : 'gd-status-rented' %>"><%= ntAvail ? 'Available' : 'Reserved' %></span>
            </div>
            <div class="gd-type-desc">Ideal for casual players focused on the story and experience, without the need for account-linked achievements.</div>
          </div>
        </label>

      </div>

      <!-- SELECT DURATION -->
      <div class="gd-section-label" style="margin-top:1.5rem;">SELECT DURATION</div>
      <div class="gd-duration-grid" id="durationGrid">
        <button class="gd-dur-btn" data-days="10" onclick="onDurChange(this)">
          <span class="gd-dur-days">10</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-10">—</span>
        </button>
        <button class="gd-dur-btn" data-days="15" onclick="onDurChange(this)">
          <span class="gd-dur-days">15</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-15">—</span>
        </button>
        <button class="gd-dur-btn" data-days="30" onclick="onDurChange(this)">
          <span class="gd-dur-days">30</span>
          <span class="gd-dur-label">DAYS</span>
          <span class="gd-dur-price" id="price-30">—</span>
          <% if (promo.enabled) { %><span class="gd-dur-promo"><%= promo.discount_pct %>% OFF</span><% } %>
        </button>
      </div>

      <!-- TOTAL BREAKDOWN -->
      <div class="gd-total-box" id="totalBox" style="display:none;">
        <div class="gd-total-label">ORDER SUMMARY</div>
        <div class="gd-total-rows" id="totalRows"></div>
        <div class="gd-total-final">
          <span>Total</span>
          <span id="totalFinal" style="color:var(--ps-blue);font-size:1.2rem;font-weight:900;"></span>
        </div>
      </div>

      <!-- CTA: Message Us (shown when selected type has a slot) -->
      <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="gd-cta-btn" id="ctaBtn" style="display:none;">
        📘 Message Us on Facebook
      </a>
      <div class="gd-cta-hint" id="ctaHint" style="display:none;">Send us: <strong>Game name · Days · Trophy or Non-Trophy</strong></div>

      <!-- CTA: Reserve options (shown when selected type has no slot) -->
      <div id="reserveSection" style="display:none;">
        <div class="gd-noslot-banner" style="margin-top:0.5rem;">
          <span class="gd-noslot-icon">⏳</span>
          <div>
            <div class="gd-noslot-title">This type has no slot right now</div>
            <div class="gd-noslot-sub">Choose how you'd like to get in line for this account type.</div>
          </div>
        </div>
        <div class="gd-section-label" style="margin-top:1rem;">CHOOSE YOUR OPTION</div>
        <div class="gd-reserve-options">
          <a id="reserveLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="gd-reserve-card gd-reserve-priority">
            <div class="gd-reserve-badge">PRIORITY</div>
            <div class="gd-reserve-icon">⭐</div>
            <div class="gd-reserve-name">Reservation</div>
            <div class="gd-reserve-fee">₱100 fee</div>
            <div class="gd-reserve-note">Fee is deducted from your total rent when a slot opens.</div>
            <div class="gd-reserve-cta">📘 Reserve Now →</div>
          </a>
          <a id="queueLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="gd-reserve-card gd-reserve-queue">
            <div class="gd-reserve-icon">🎮</div>
            <div class="gd-reserve-name">Fall in Line</div>
            <div class="gd-reserve-fee">FREE</div>
            <div class="gd-reserve-note">Join the waitlist at no cost. You'll be notified when a slot is available.</div>
            <div class="gd-reserve-cta">📘 Join Waitlist →</div>
          </a>
        </div>
      </div>

      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
const PRICES = {
  nt: { 10: <%= game.nt_price_10d %>, 15: <%= game.nt_price_15d %>, 30: <%= game.nt_price_30d %> },
  tr: { 10: <%= game.tr_price_10d || game.nt_price_10d %>, 15: <%= game.tr_price_15d || game.nt_price_15d %>, 30: <%= game.tr_price_30d || game.nt_price_30d %> }
};
const PROMO = {
  enabled: <%= promo.enabled ? 'true' : 'false' %>,
  discount_pct: <%= promo.discount_pct %>,
  apply_on_days: <%= promo.apply_on_days %>,
  deposit: <%= promo.deposit %>
};
const AVAIL = { nt: <%= ntAvail ? 'true' : 'false' %>, tr: <%= trAvail ? 'true' : 'false' %> };

let selectedType = null;
let selectedDays = null;

function onTypeChange(radio) {
  selectedType = radio.value;
  document.querySelectorAll('.gd-type-card').forEach(c => c.classList.remove('gd-type-selected'));
  document.getElementById('label-' + selectedType)?.classList.add('gd-type-selected');
  updatePrices();
  updateTotal();
  updateReserveLinks();
  // Swap CTA based on whether selected type has a slot
  const hasSlot = AVAIL[selectedType] !== false;
  const ctaBtn = document.getElementById('ctaBtn');
  const ctaHint = document.getElementById('ctaHint');
  const reserveSection = document.getElementById('reserveSection');
  if (ctaBtn) ctaBtn.style.display = hasSlot ? '' : 'none';
  if (ctaHint) ctaHint.style.display = hasSlot ? '' : 'none';
  if (reserveSection) reserveSection.style.display = hasSlot ? 'none' : '';
}

function onDurChange(btn) {
  selectedDays = parseInt(btn.dataset.days);
  document.querySelectorAll('.gd-dur-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  updateTotal();
  updateReserveLinks();
}

function updatePrices() {
  if (!selectedType) return;
  [10, 15, 30].forEach(d => {
    const el = document.getElementById('price-' + d);
    if (el) el.textContent = '₱' + PRICES[selectedType][d];
  });
}

function updateTotal() {
  const box = document.getElementById('totalBox');
  if (!selectedType || !selectedDays) { box.style.display = 'none'; return; }

  const base = PRICES[selectedType][selectedDays];
  const isPromoDay = PROMO.enabled && selectedDays === PROMO.apply_on_days;
  const discount = isPromoDay ? Math.round(base * PROMO.discount_pct / 100) : 0;
  const deposit  = selectedType === 'tr' ? PROMO.deposit : 0;
  const total    = base - discount + deposit;

  let rows = '';
  rows += `<div class="gd-total-row"><span>Base (${selectedDays} days)</span><span>₱${base}</span></div>`;
  if (discount > 0) rows += `<div class="gd-total-row gd-total-disc"><span>🎉 ${PROMO.discount_pct}% OFF (${selectedDays}-day promo)</span><span>-₱${discount}</span></div>`;
  if (deposit > 0)  rows += `<div class="gd-total-row gd-total-dep"><span>🔒 Security Deposit (refundable)</span><span>+₱${deposit}</span></div>`;

  document.getElementById('totalRows').innerHTML = rows;
  document.getElementById('totalFinal').textContent = '₱' + total;
  box.style.display = 'block';
}

function updateReserveLinks() {
  const gameTitle = '<%= game.title.replace(/'/g, "\\'") %>';
  const typeLabel = selectedType === 'tr' ? 'Trophy Account' : selectedType === 'nt' ? 'Non-Trophy Account' : '';
  const daysLabel = selectedDays ? selectedDays + ' Days' : '';

  // Compute total for the message
  let totalLine = '';
  if (selectedType && selectedDays) {
    const base = PRICES[selectedType][selectedDays];
    const isPromoDay = PROMO.enabled && selectedDays === PROMO.apply_on_days;
    const discount = isPromoDay ? Math.round(base * PROMO.discount_pct / 100) : 0;
    const deposit  = selectedType === 'tr' ? PROMO.deposit : 0;
    const total    = base - discount + deposit;
    totalLine = 'Total: ₱' + total;
    if (discount > 0) totalLine += ' (incl. ' + PROMO.discount_pct + '% promo discount)';
    if (deposit  > 0) totalLine += ' + ₱' + deposit + ' refundable deposit';
  }

  // Message Us button (available slot)
  const ctaBtn = document.getElementById('ctaBtn');
  if (ctaBtn) {
    const rentMsg = [
      'Hi! I want to RENT a game 🎮',
      'Game: ' + gameTitle,
      typeLabel ? 'Account Type: ' + typeLabel : '',
      daysLabel ? 'Duration: ' + daysLabel : '',
      totalLine
    ].filter(Boolean).join('\n');
    ctaBtn.href = 'http://m.me/PlaystationHub00?text=' + encodeURIComponent(rentMsg);
  }

  // Priority Reservation button
  const rLink = document.getElementById('reserveLink');
  if (rLink) {
    const reserveMsg = [
      'Hi! I want to PRIORITY RESERVE a slot ⭐',
      'Game: ' + gameTitle,
      typeLabel ? 'Account Type: ' + typeLabel : '',
      daysLabel ? 'Duration: ' + daysLabel : '',
      totalLine,
      'Note: I am paying the ₱100 priority reservation fee.'
    ].filter(Boolean).join('\n');
    rLink.href = 'http://m.me/PlaystationHub00?text=' + encodeURIComponent(reserveMsg);
  }

  // Fall in Line button
  const qLink = document.getElementById('queueLink');
  if (qLink) {
    const queueMsg = [
      'Hi! I want to JOIN THE WAITLIST (Fall in Line) 🎮',
      'Game: ' + gameTitle,
      typeLabel ? 'Account Type: ' + typeLabel : '',
      daysLabel ? 'Duration: ' + daysLabel : '',
      'Please notify me when a slot becomes available.'
    ].filter(Boolean).join('\n');
    qLink.href = 'http://m.me/PlaystationHub00?text=' + encodeURIComponent(queueMsg);
  }
}

// Auto-select first available type (prefer available slot, fallback to first)
window.addEventListener('DOMContentLoaded', () => {
  const available = document.querySelector('input[name="rentalType"][value="tr"]') && AVAIL.tr
    ? document.querySelector('input[name="rentalType"][value="tr"]')
    : AVAIL.nt ? document.querySelector('input[name="rentalType"][value="nt"]')
    : document.querySelector('input[name="rentalType"]');
  if (available) { available.checked = true; onTypeChange(available); }
  updateReserveLinks();
});
</script>
</body>
</html>
