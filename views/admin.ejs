      <% } %>
    </div>

  </div><!-- /tab-psplus -->

  <!-- ═══════════════ CUSTOMERS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-customers">

    <%
      const activeCustomers = customers.filter(c => c.status === 'renting');
      const boughtCustomers = customers.filter(c => c.status === 'bought');
      const doneCustomers = customers.filter(c => c.status === 'done');
      const reservationCustomers = customers.filter(c => c.status === 'reservation');

      // Sales calculations
      const totalRevenue = customers.reduce((s, c) => s + (c.price || 0), 0);
      const rentRevenue  = customers.filter(c => c.status !== 'bought').reduce((s, c) => s + (c.price || 0), 0);
      const buyRevenue   = boughtCustomers.reduce((s, c) => s + (c.price || 0), 0);
      const totalGameCosts = games.reduce((s, g) => s + (g.cost || 0), 0);
      const netProfit = totalRevenue - totalGameCosts;

      // This month — based on start_date (when they actually started renting/buying)
      const now = new Date();
      const thisMonth = now.getMonth(), thisYear = now.getFullYear();
      const monthCustomers = customers.filter(c => {
        const dateStr = c.start_date || c.created_at;
        if (!dateStr) return false;
        const d = new Date(c.start_date ? c.start_date + 'T00:00:00' : c.created_at);
        return d.getMonth() === thisMonth && d.getFullYear() === thisYear;
      });
      const monthRevenue = monthCustomers.reduce((s, c) => s + (c.price || 0), 0);

      // Overdue
      const today0 = new Date(); today0.setHours(0,0,0,0);
      const overdueCustomers = activeCustomers.filter(c => {
        if (!c.end_date) return false;
        return new Date(c.end_date + 'T00:00:00') < today0;
      });

      // Top games by rental count
      const gameCount = {};
      customers.forEach(c => { gameCount[c.game_title] = (gameCount[c.game_title] || 0) + 1; });
      const topGames = Object.entries(gameCount).sort((a,b) => b[1]-a[1]).slice(0, 5);

      // Monthly revenue for last 6 months
      const monthLabels = [], monthRevs = [];
      for (let i = 5; i >= 0; i--) {
        const d = new Date(thisYear, thisMonth - i, 1);
        const lbl = d.toLocaleDateString('en-US', {month:'short', year:'2-digit'});
        monthLabels.push(lbl);
        const rev = customers.filter(c => {
          const dateStr = c.start_date || c.created_at;
          if (!dateStr) return false;
          const cd = new Date(c.start_date ? c.start_date + 'T00:00:00' : c.created_at);
          return cd.getMonth() === d.getMonth() && cd.getFullYear() === d.getFullYear();
        }).reduce((s, c) => s + (c.price || 0), 0);
        monthRevs.push(rev);
      }
      const maxMonthRev = Math.max(...monthRevs, 1);
    %>

    <!-- ── DASHBOARD ── -->
    <div style="margin-bottom:2rem;">
      <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1rem;">
        <span style="font-size:1.1rem;font-weight:800;color:#fff;">📊 Business Dashboard</span>
        <span style="font-size:0.72rem;color:#444;margin-left:auto;">as of <%= now.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></span>
      </div>

      <!-- KPI row -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:0.75rem;">
        <div style="background:linear-gradient(135deg,#0a1a0a,#061006);border:1px solid #1a3a1a;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Total Earned</div>
          <div style="font-size:1.6rem;font-weight:900;color:#22c55e;">₱<%= totalRevenue.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;"><%= customers.length %> transactions</div>
        </div>
        <div style="background:linear-gradient(135deg,#1a0800,#100500);border:1px solid #3a1a00;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Total Game Costs</div>
          <div style="font-size:1.6rem;font-weight:900;color:#f59e0b;">₱<%= totalGameCosts.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;"><%= games.length %> game<%= games.length !== 1 ? 's' : '' %> in library</div>
        </div>
        <div style="background:linear-gradient(135deg,<%= netProfit >= 0 ? '#060a18,#03060f' : '#1a0606,#0f0303' %>);border:1px solid <%= netProfit >= 0 ? '#1a2a4a' : '#3a1a1a' %>;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Net Profit</div>
          <div style="font-size:1.6rem;font-weight:900;color:<%= netProfit >= 0 ? 'var(--ps-blue)' : '#ef4444' %>;">₱<%= netProfit.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;">Earned − Game Costs</div>
        </div>
      </div>
      <!-- KPI row 2 -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:0.75rem;">
        <div style="background:linear-gradient(135deg,#100a00,#0a0800);border:1px solid #3a2a00;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">This Month</div>
          <div style="font-size:1.6rem;font-weight:900;color:#fbbf24;">₱<%= monthRevenue.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;"><%= monthCustomers.length %> customer<%= monthCustomers.length !== 1 ? 's' : '' %></div>
        </div>
        <div style="background:linear-gradient(135deg,#0a0f1a,#060a10);border:1px solid #1a2a3a;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Rental Sales</div>
          <div style="font-size:1.6rem;font-weight:900;color:#a78bfa;">₱<%= rentRevenue.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;"><%= customers.length - boughtCustomers.length %> rentals</div>
        </div>
        <div style="background:linear-gradient(135deg,#0f0a1a,#080610);border:1px solid #2a1a3a;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Game Sales</div>
          <div style="font-size:1.6rem;font-weight:900;color:#60a5fa;">₱<%= buyRevenue.toLocaleString() %></div>
          <div style="font-size:0.7rem;color:#444;margin-top:0.2rem;"><%= boughtCustomers.length %> game<%= boughtCustomers.length !== 1 ? 's' : '' %> sold</div>
        </div>
      </div>

      <!-- Status + overdue row -->
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:0.75rem;margin-bottom:0.75rem;">
        <div style="background:#0a1a0a;border:1px solid #1a3a1a;border-radius:10px;padding:0.85rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">🟢</div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#22c55e;line-height:1;"><%= activeCustomers.length %></div><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;">Currently Renting</div></div>
        </div>
        <div style="background:#0f0a1a;border:1px solid #2a1a3a;border-radius:10px;padding:0.85rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">🔖</div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#c084fc;line-height:1;"><%= reservationCustomers.length %></div><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;">Reservations</div></div>
        </div>
        <div style="background:#0a0f1a;border:1px solid #1a2a3a;border-radius:10px;padding:0.85rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">🛒</div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#60a5fa;line-height:1;"><%= boughtCustomers.length %></div><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;">Bought Games</div></div>
        </div>
        <div style="background:#0a0a1a;border:1px solid #1a1a3a;border-radius:10px;padding:0.85rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">✅</div>
          <div><div style="font-size:1.4rem;font-weight:900;color:#aaa;line-height:1;"><%= doneCustomers.length %></div><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;">Completed</div></div>
        </div>
        <div style="background:<%= overdueCustomers.length > 0 ? '#1a0a0a' : '#0d0d0d' %>;border:1px solid <%= overdueCustomers.length > 0 ? '#3a1a1a' : '#1a1a1a' %>;border-radius:10px;padding:0.85rem;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">⚠️</div>
          <div><div style="font-size:1.4rem;font-weight:900;color:<%= overdueCustomers.length > 0 ? '#ef4444' : '#555' %>;line-height:1;"><%= overdueCustomers.length %></div><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;">Overdue</div></div>
        </div>
      </div>

      <!-- Charts row: monthly bar + top games -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">

        <!-- Monthly Revenue Bar Chart -->
        <div style="background:#0d0d0d;border:1px solid #1a1a1a;border-radius:12px;padding:1rem;">
          <div style="font-size:0.75rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.85rem;">Monthly Revenue (Last 6 Months)</div>
          <div style="display:flex;align-items:flex-end;gap:0.4rem;height:90px;">
            <% monthLabels.forEach((lbl, i) => {
              const pct = Math.round((monthRevs[i] / maxMonthRev) * 100);
              const isLast = i === monthLabels.length - 1;
            %>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.25rem;height:100%;">
              <div style="flex:1;display:flex;align-items:flex-end;width:100%;">
                <div style="width:100%;height:<%= Math.max(pct,3) %>%;background:<%= isLast ? 'var(--ps-blue)' : '#2a2a2a' %>;border-radius:4px 4px 0 0;min-height:3px;transition:height 0.3s;"
                  title="₱<%= monthRevs[i].toLocaleString() %>"></div>
              </div>
              <div style="font-size:0.6rem;color:#444;white-space:nowrap;"><%= lbl %></div>
              <% if (monthRevs[i] > 0) { %>
              <div style="font-size:0.6rem;color:<%= isLast ? 'var(--ps-blue)' : '#555' %>;font-weight:700;">₱<%= monthRevs[i] >= 1000 ? (monthRevs[i]/1000).toFixed(1)+'k' : monthRevs[i] %></div>
              <% } %>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Top Games -->
        <div style="background:#0d0d0d;border:1px solid #1a1a1a;border-radius:12px;padding:1rem;">
          <div style="font-size:0.75rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.85rem;">Most Rented / Sold Games</div>
          <% if (topGames.length === 0) { %>
            <div style="color:#333;font-size:0.8rem;text-align:center;padding:1.5rem 0;">No data yet</div>
          <% } else { %>
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <% const maxCount = topGames[0][1]; %>
            <% topGames.forEach(([title, count], i) => { %>
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.2rem;">
                <div style="font-size:0.75rem;color:#ccc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:70%;"><%= i+1 %>. <%= title %></div>
                <div style="font-size:0.72rem;font-weight:700;color:var(--ps-blue);"><%= count %>x</div>
              </div>
              <div style="background:#1a1a1a;border-radius:3px;height:5px;">
                <div style="width:<%= Math.round((count/maxCount)*100) %>%;height:100%;background:var(--ps-blue);border-radius:3px;"></div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>

      </div>
    </div>

    <!-- Import Customers from Excel -->
    <div class="form-card" style="border-color:rgba(99,102,241,0.35);background:linear-gradient(135deg,#0d0d1f,#0a0a0a);">
      <h2 style="display:flex;align-items:center;gap:0.6rem;">📥 Import Customers from Excel</h2>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin:0 0 1rem;">
        Upload an Excel file (.xlsx) to bulk-import customer records. Existing customers are kept — only new rows are added.
      </p>
      <% if (locals.msg) { %>
        <% if (String(msg).startsWith('imported_')) { %>
          <%
            const parts = String(msg).split('_');
            const importedN = parts[1] || '?';
            const skippedN = parts[3] || '0';
          %>
          <div style="background:rgba(34,197,94,0.12);border:1px solid #22c55e;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;color:#22c55e;font-weight:600;">
            ✅ Successfully imported <%= importedN %> customer(s)<% if (parseInt(skippedN) > 0) { %>, <%= skippedN %> row(s) skipped (blank name)<% } %>.
          </div>
        <% } else if (String(msg).includes('import_error') || String(msg) === 'error') { %>
          <div style="background:rgba(239,68,68,0.12);border:1px solid #ef4444;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;color:#ef4444;font-weight:600;">
            ❌ Import failed. Make sure the file is a valid .xlsx using the sample format.
          </div>
        <% } %>
      <% } %>
      <form method="POST" action="/admin/customers/import" enctype="multipart/form-data">
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
          <label style="flex:1;min-width:240px;">
            <span style="color:var(--text-secondary);font-size:0.8rem;display:block;margin-bottom:0.35rem;">Select Excel File (.xlsx)</span>
            <input type="file" name="import_file" accept=".xlsx,.xls" required
              style="width:100%;padding:0.5rem 0.75rem;background:#111;border:1px solid #333;border-radius:8px;color:#eee;font-size:0.85rem;cursor:pointer;">
          </label>
          <div style="display:flex;flex-direction:column;gap:0.5rem;padding-top:0.4rem;">
            <button type="submit" class="btn btn-primary" style="background:#4f46e5;min-width:130px;">📤 Import</button>
            <a href="/admin/customers/sample" class="btn btn-outline" style="text-align:center;font-size:0.8rem;min-width:130px;">⬇️ Sample File</a>
          </div>
        </div>
      </form>
      <div style="margin-top:1rem;padding:0.85rem 1rem;background:#0d0d0d;border-radius:8px;border:1px solid #222;">
        <p style="font-size:0.78rem;color:var(--text-secondary);margin:0 0 0.4rem;font-weight:700;">Required columns in your Excel file:</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
          <% ['customer_name','game_title','days','account_type','start_date','end_date','price','status','notes'].forEach(col => { %>
            <code style="background:#1a1a1a;border:1px solid #333;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.75rem;color:#a78bfa;"><%= col %></code>
          <% }) %>
        </div>
        <p style="font-size:0.75rem;color:#666;margin:0.5rem 0 0;">account_type: <b style="color:#ccc">nt</b> / <b style="color:#ffc400">tr</b> / <b style="color:#60a5fa">ps4</b> &nbsp;|&nbsp; status: <b style="color:#ccc">renting</b> / <b style="color:#ccc">done</b> / <b style="color:#ccc">bought</b> / <b style="color:#ccc">reservation</b> &nbsp;|&nbsp; dates: YYYY-MM-DD</p>
      </div>
    </div>

    <!-- Add Customer Form -->
    <div class="form-card" style="border-color:rgba(34,197,94,0.3);background:linear-gradient(135deg,#001a06,#0a0a0a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">👤 Add New Customer</h2>
      <form method="POST" action="/admin/customers/add">
        <div class="form-grid">

          <div class="form-group full">
            <label>Customer Name *</label>
            <input type="text" name="customer_name" placeholder="e.g. Juan dela Cruz" required>
          </div>

          <div class="form-group full">
            <label id="cust_game_label">Game Rented *</label>
            <select name="game_id" id="cust_game" onchange="updateCustPrice()" required>
              <option value="">— Select a game —</option>
              <!-- Regular games (shown for renting/done/bought) -->
              <optgroup label="Available Games" id="cust_optgroup_regular">
                <% games.forEach(g => { %>
                <option value="<%= g.id %>" data-type="regular"
                  data-nt10="<%= g.nt_price_10d %>" data-nt15="<%= g.nt_price_15d %>" data-nt30="<%= g.nt_price_30d %>"
                  data-tr10="<%= g.tr_price_10d %>" data-tr15="<%= g.tr_price_15d %>" data-tr30="<%= g.tr_price_30d %>"
                  data-slots="<%= g.available_slots %>">
                  <%= g.title %> (<%= g.platform %>)<%= g.available_slots > 0 ? ' — '+g.available_slots+' slot(s)' : ' — FULL' %>
                </option>
                <% }) %>
              </optgroup>
              <!-- Upcoming games (shown for reservation) -->
              <optgroup label="Upcoming Games" id="cust_optgroup_upcoming" style="display:none;">
                <% upcoming.forEach(g => { %>
                <option value="upcoming_<%= g.id %>" data-type="upcoming" data-title="<%= g.title %>">
                  <%= g.title %> (<%= g.platform %>) — <%= g.release_date === 'TBA' ? 'TBA' : g.release_date %>
                </option>
                <% }) %>
              </optgroup>
            </select>
          </div>

          <div class="form-group" id="cust_days_group">
            <label>Rental Duration</label>
            <select name="days" id="cust_days" onchange="toggleCustCustomDays(this.value);updateCustPrice()">
              <option value="10">10 Days</option>
              <option value="15">15 Days</option>
              <option value="30">30 Days</option>
              <option value="custom">✏️ Custom...</option>
            </select>
            <input type="number" id="cust_custom_days" name="custom_days" min="1" max="365" placeholder="Enter number of days"
              hidden oninput="updateCustEndDate()">
          </div>

          <div class="form-group">
            <label>Account Type</label>
            <select name="account_type" id="cust_type" onchange="updateCustPrice()">
              <option value="nt">🎮 Non-Trophy</option>
              <option value="tr">🏆 Trophy Account</option>
              <option value="ps4">🕹️ PS4 Primary</option>
            </select>
          </div>

          <div class="form-group">
            <label>Start Date</label>
            <input type="date" name="start_date" id="cust_start" onchange="updateCustEndDate()">
          </div>

          <div class="form-group">
            <label>End Date <span style="color:#555;font-size:0.72rem;">(auto-calculated)</span></label>
            <input type="date" name="end_date" id="cust_end">
          </div>

          <div class="form-group">
            <label>Price (₱) <span style="color:#555;font-size:0.72rem;">(auto-filled)</span></label>
            <input type="number" name="price" id="cust_price" min="0" placeholder="0">
          </div>

          <div class="form-group">
            <label>Status</label>
            <select name="status" id="cust_status" onchange="toggleCustStatus(this.value)">
              <option value="renting">🟢 Currently Renting</option>
              <option value="reservation">🔖 Reservation</option>
              <option value="done">✅ Done</option>
              <option value="bought">🛒 Bought</option>
            </select>
          </div>

          <div class="form-group full">
            <label>Notes <span style="color:#555;font-size:0.72rem;">(optional)</span></label>
            <input type="text" name="notes" placeholder="e.g. Paid via GCash, needs follow-up...">
          </div>

        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" style="background:#166534;">Add Customer</button>
          <button type="reset" class="btn btn-outline">Clear</button>
        </div>
      </form>
      <script>
      function getCustDays() {
        const sel = document.getElementById('cust_days');
        if (sel.value === 'custom') return parseInt(document.getElementById('cust_custom_days').value) || 0;
        return parseInt(sel.value) || 0;
      }
      function toggleCustCustomDays(val) {
        const inp = document.getElementById('cust_custom_days');
        if (val === 'custom') { inp.removeAttribute('hidden'); inp.focus(); }
        else inp.setAttribute('hidden', '');
      }
      function toggleCustStatus(status) {
        const daysGroup = document.getElementById('cust_days_group');
        const gameLabel = document.getElementById('cust_game_label');
        const grpRegular = document.getElementById('cust_optgroup_regular');
        const grpUpcoming = document.getElementById('cust_optgroup_upcoming');
        const gameSel = document.getElementById('cust_game');

        if (status === 'reservation') {
          // Show only upcoming games
          daysGroup.setAttribute('hidden', '');
          grpRegular.style.display = 'none';
          grpUpcoming.style.display = '';
          gameLabel.textContent = 'Upcoming Game Reserved *';
          // Reset selection to avoid carrying over a regular game
          gameSel.value = '';
        } else {
          // Show only regular games
          grpRegular.style.display = '';
          grpUpcoming.style.display = 'none';
          gameLabel.textContent = 'Game Rented *';
          gameSel.value = '';
          if (status === 'bought') {
            daysGroup.setAttribute('hidden', '');
          } else {
            daysGroup.removeAttribute('hidden');
            updateCustEndDate();
          }
        }
      }
      function updateCustPrice() {
        const sel = document.getElementById('cust_game');
        const opt = sel.options[sel.selectedIndex];
        const days = document.getElementById('cust_days').value;
        const type = document.getElementById('cust_type').value;
        if (!opt.value) return;
        // Only auto-fill price for standard durations
        const price = (days !== 'custom') ? (opt.dataset[type + days] || '') : '';
        if (price) document.getElementById('cust_price').value = price;
        updateCustEndDate();
      }
      function updateCustEndDate() {
        const start = document.getElementById('cust_start').value;
        const days = getCustDays();
        if (!start || !days) return;
        const d = new Date(start + 'T00:00:00');
        d.setDate(d.getDate() + days);
        document.getElementById('cust_end').value = d.toISOString().slice(0,10);
      }
      // Set today as default start date
      document.getElementById('cust_start').value = new Date().toISOString().slice(0,10);
      updateCustEndDate();
      </script>
    </div>

    <!-- Customers Table -->
    <div class="table-card" style="margin-top:1.5rem;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
        <h2 style="margin:0;border:none;padding:0;">All Customers (<%= customers.length %>)</h2>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <button onclick="filterCustomers('all')" id="cf-all" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;">All</button>
          <button onclick="filterCustomers('renting')" id="cf-renting" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#166534;color:#22c55e;">🟢 Renting</button>
          <button onclick="filterCustomers('reservation')" id="cf-reservation" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#4a1a6a;color:#c084fc;">🔖 Reservation</button>
          <button onclick="filterCustomers('bought')" id="cf-bought" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#1e3a5f;color:#60a5fa;">🛒 Bought</button>
          <button onclick="filterCustomers('done')" id="cf-done" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;">✅ Done</button>
        </div>
      </div>

      <% if (customers.length === 0) { %>
        <div style="padding:2rem;text-align:center;color:#444;font-style:italic;">No customers yet. Add one above!</div>
      <% } else { %>
      <div style="overflow-x:auto;">
        <table class="games-table" id="customersTable">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Game</th>
              <th>Duration</th>
              <th>Type</th>
              <th>Start</th>
              <th>End</th>
              <th>Price</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% customers.forEach(c => {
              const isRenting = c.status === 'renting';
              const isBought = c.status === 'bought';
              const isReservation = c.status === 'reservation';
              const endDate = c.end_date ? new Date(c.end_date + 'T00:00:00') : null;
              const today = new Date(); today.setHours(0,0,0,0);
              const isOverdue = isRenting && endDate && endDate < today;
              const daysLeft = endDate ? Math.ceil((endDate - today) / 86400000) : null;
            %>
            <tr class="cust-row" data-status="<%= c.status %>" style="<%= isOverdue ? 'background:rgba(239,68,68,0.06);' : '' %>">
              <td>
                <div style="font-weight:700;"><%= c.customer_name %></div>
                <% if (c.notes) { %><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;"><%= c.notes %></div><% } %>
              </td>
              <td style="font-size:0.85rem;"><strong><%= c.game_title %></strong></td>
              <td style="color:#aaa;font-size:0.85rem;"><%= (isBought || isReservation) ? '—' : c.days + ' days' %></td>
              <td>
                <% if (c.account_type === 'tr') { %>
                  <span style="color:#ffc400;font-size:0.78rem;font-weight:700;">🏆 Trophy</span>
                <% } else if (c.account_type === 'ps4') { %>
                  <span style="color:#60a5fa;font-size:0.78rem;font-weight:700;">🕹️ PS4 Primary</span>
                <% } else { %>
                  <span style="color:#aaa;font-size:0.78rem;">🎮 Non-Trophy</span>
                <% } %>
              </td>
              <td style="font-size:0.82rem;color:#aaa;"><%= c.start_date ? new Date(c.start_date+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—' %></td>
              <td style="font-size:0.82rem;">
                <% if (c.end_date) { %>
                  <span style="color:<%= isOverdue ? '#ef4444' : (daysLeft !== null && daysLeft <= 2 && isRenting ? '#f59e0b' : '#aaa') %>;">
                    <%= new Date(c.end_date+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
                  </span>
                  <% if (isRenting && daysLeft !== null) { %>
                    <div style="font-size:0.68rem;color:<%= isOverdue ? '#ef4444' : (daysLeft <= 2 ? '#f59e0b' : '#555') %>;">
                      <%= isOverdue ? 'Overdue by '+Math.abs(daysLeft)+'d' : daysLeft === 0 ? 'Due today' : daysLeft+'d left' %>
                    </div>
                  <% } %>
                <% } else { %>—<% } %>
              </td>
              <td style="font-weight:700;color:var(--ps-blue);">₱<%= c.price || 0 %></td>
              <td>
                <form method="POST" action="/admin/customers/status/<%= c.id %>" style="display:inline;">
                  <% if (isRenting) { %>
                    <input type="hidden" name="status" value="done">
                    <button type="submit" style="background:#166534;color:#fff;border:none;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;cursor:pointer;white-space:nowrap;" title="Mark as Done">🟢 Renting</button>
                  <% } else if (isReservation) { %>
                    <span style="background:#2d1a4a;color:#c084fc;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;white-space:nowrap;">🔖 Reserved</span>
                  <% } else if (isBought) { %>
                    <span style="background:#1e3a5f;color:#60a5fa;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;white-space:nowrap;">🛒 Bought</span>
                  <% } else { %>
                    <input type="hidden" name="status" value="renting">
                    <button type="submit" style="background:#222;color:#aaa;border:1px solid #333;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;cursor:pointer;white-space:nowrap;" title="Mark as Renting">✅ Done</button>
                  <% } %>
                </form>
              </td>
              <td>
                <div class="action-btns">
                  <a href="/admin/customers/edit/<%= c.id %>" class="btn-edit">✏️ Edit</a>
                  <form method="POST" action="/admin/customers/delete/<%= c.id %>" style="display:inline" onsubmit="return confirm('Delete <%= c.customer_name.replace(/'/g, "\\'") %>?')">
                    <button type="submit" class="btn-delete">🗑</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <script>
    function filterCustomers(status) {
      document.querySelectorAll('.cust-row').forEach(r => {
        r.style.display = (status === 'all' || r.dataset.status === status) ? '' : 'none';
      });
      ['all','renting','reservation','bought','done'].forEach(s => {
        const btn = document.getElementById('cf-'+s);
        if (!btn) return;
        btn.style.background = s === status ? 'var(--ps-blue)' : '';
        btn.style.color = s === status ? '#000' : '';
        btn.style.borderColor = s === status ? 'var(--ps-blue)' : '';
      });
    }
    </script>

  </div><!-- /tab-customers -->

  <!-- ═══════════════ VISITORS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-visitors">
    <%
      const vNow = new Date();
      const vTodayStr = vNow.toISOString().slice(0, 10);
      const vWeekAgo  = new Date(vNow - 7 * 86400000).toISOString().slice(0, 10);
      const vMonthAgo = new Date(vNow - 30 * 86400000).toISOString().slice(0, 10);

      const visToday = visitors.filter(v => v.date === vTodayStr);
      const visWeek  = visitors.filter(v => v.date >= vWeekAgo);
      const visMonth = visitors.filter(v => v.date >= vMonthAgo);

      const uniqueToday = new Set(visToday.map(v => v.ip)).size;
      const uniqueWeek  = new Set(visWeek.map(v => v.ip)).size;
      const uniqueMonth = new Set(visMonth.map(v => v.ip)).size;
      const uniqueAll   = new Set(visitors.map(v => v.ip)).size;

      const vPageCounts = {};
      visitors.forEach(v => { vPageCounts[v.page] = (vPageCounts[v.page] || 0) + 1; });
      const topPages = Object.entries(vPageCounts).sort((a,b) => b[1]-a[1]);

      const vLast7 = [];
      for (let i = 6; i >= 0; i--) {
        const vd = new Date(vNow - i * 86400000);
        const vds = vd.toISOString().slice(0, 10);
        const vlabel = vd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        vLast7.push({ date: vds, label: vlabel, count: visitors.filter(v => v.date === vds).length });
      }
      const vMaxBar = Math.max(...vLast7.map(d => d.count), 1);

      const recentVisitors = [...visitors].reverse().slice(0, 30);
    %>

    <!-- KPI Cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem;">
      <div class="stat-card">
        <div class="stat-card-label">Today's Visits</div>
        <div class="stat-card-num" style="color:#22c55e;"><%= visToday.length %></div>
        <div class="stat-card-sub"><%= uniqueToday %> unique visitor<%= uniqueToday!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">Last 7 Days</div>
        <div class="stat-card-num" style="color:#60a5fa;"><%= visWeek.length %></div>
        <div class="stat-card-sub"><%= uniqueWeek %> unique visitor<%= uniqueWeek!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">Last 30 Days</div>
        <div class="stat-card-num" style="color:#a78bfa;"><%= visMonth.length %></div>
        <div class="stat-card-sub"><%= uniqueMonth %> unique visitor<%= uniqueMonth!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">All-Time Visits</div>
        <div class="stat-card-num" style="color:#ffc400;"><%= visitors.length %></div>
        <div class="stat-card-sub"><%= uniqueAll %> unique visitor<%= uniqueAll!==1?'s':'' %></div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem;">

      <!-- Last 7 Days Bar Chart -->
      <div class="table-card" style="border-color:rgba(96,165,250,0.2);">
        <h2 style="border-color:rgba(96,165,250,0.1);margin-bottom:1.25rem;">📈 Visits — Last 7 Days</h2>
        <div style="display:flex;align-items:flex-end;gap:0.4rem;height:120px;">
          <% vLast7.forEach(day => { %>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.3rem;height:100%;">
            <div style="font-size:0.65rem;color:#555;"><%= day.count %></div>
            <div style="width:100%;background:rgba(96,165,250,0.15);border-radius:4px 4px 0 0;border-top:2px solid #60a5fa;height:<%= day.count > 0 ? Math.round((day.count/vMaxBar)*85) : 2 %>px;min-height:2px;"></div>
            <div style="font-size:0.6rem;color:#555;text-align:center;line-height:1.2;"><%= day.label %></div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Top Pages -->
      <div class="table-card" style="border-color:rgba(167,139,250,0.2);">
        <h2 style="border-color:rgba(167,139,250,0.1);margin-bottom:1rem;">🔗 Most Visited Pages</h2>
        <% if (topPages.length === 0) { %>
          <div style="color:#555;font-size:0.85rem;">No visits recorded yet.</div>
        <% } else { %>
          <% topPages.forEach(([page, count]) => { %>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.6rem;">
            <div style="flex:1;font-size:0.82rem;color:#ccc;"><%= page %></div>
            <div style="font-size:0.75rem;color:#a78bfa;font-weight:700;"><%= count %></div>
            <div style="width:60px;height:6px;background:#1a1a1a;border-radius:3px;overflow:hidden;">
              <div style="height:100%;background:#a78bfa;border-radius:3px;width:<%= Math.round((count/topPages[0][1])*100) %>%;"></div>
            </div>
          </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Recent Visits Table -->
    <div class="table-card" style="border-color:rgba(34,197,94,0.15);">
      <h2 style="border-color:rgba(34,197,94,0.1);">🕐 Recent Visits (<%= recentVisitors.length %>)</h2>
      <% if (recentVisitors.length === 0) { %>
        <div style="padding:2rem;text-align:center;color:#555;">No visits recorded yet. Share your website link to get visitors!</div>
      <% } else { %>
      <table class="games-table" style="width:100%;">
        <thead>
          <tr>
            <th>Page</th>
            <th>Date</th>
            <th>Time</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% recentVisitors.forEach(v => { %>
          <tr>
            <td><span style="color:#22c55e;font-weight:600;"><%= v.page || v.path %></span></td>
            <td style="color:#aaa;font-size:0.8rem;"><%= v.date %></td>
            <td style="color:#aaa;font-size:0.8rem;"><%= v.time ? new Date(v.time).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'}) : '' %></td>
            <td style="color:#555;font-size:0.75rem;font-family:monospace;"><%= v.ip ? v.ip.replace(/^::ffff:/, '').slice(0,15) : '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div><!-- /tab-visitors -->

  <!-- ═══════════════ SECURITY TAB ═══════════════ -->
  <div class="tab-panel" id="tab-security">
    <div class="form-card" style="border-color:rgba(255,50,50,0.2);background:linear-gradient(135deg,#1a0a0a,#1a1a1a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">🔒 Change Admin Password</h2>
      <form method="POST" action="/admin/change-password">
        <div class="form-grid">
          <div class="form-group"><label>Current Password</label><input type="password" name="current_password" placeholder="Current password" required></div>
          <div class="form-group"><label>New Password</label><input type="password" name="new_password" placeholder="New password (min 4 chars)" required></div>
          <div class="form-group"><label>Confirm New Password</label><input type="password" name="confirm_password" placeholder="Repeat new password" required></div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn" style="background:#c0392b;color:#fff;font-weight:700;padding:0.75rem 1.75rem;border-radius:50px;border:none;cursor:pointer;">Change Password</button>
        </div>
      </form>
    </div>
  </div><!-- /tab-security -->

</div><!-- /admin-container -->

<!-- LOADING OVERLAY -->
<div id="loadingOverlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);flex-direction:column;align-items:center;justify-content:center;gap:1.25rem;">
  <div style="width:52px;height:52px;border:4px solid #222;border-top-color:var(--ps-blue);border-radius:50%;animation:spin 0.7s linear infinite;"></div>
  <div id="loadingText" style="color:#fff;font-weight:700;font-size:1rem;letter-spacing:0.5px;">Saving changes...</div>
</div>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<script>
// ── Tab system ──
const TAB_KEY = 'adminTab';
const tabs = ['settings','announcements','games','customers','psplus','security','visitors'];

function switchTab(name) {
  tabs.forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('active', t===name);
    document.querySelector('[data-tab='+t+']').classList.toggle('active', t===name);
  });
  localStorage.setItem(TAB_KEY, name);
  history.replaceState({}, '', '/admin' + (name !== 'settings' ? '?tab='+name : ''));
}

// Determine initial tab: URL param > msg-based auto-switch > localStorage > default
(function() {
  const params = new URLSearchParams(window.location.search);
  const msg = params.get('msg');
  const urlTab = params.get('tab');

  // Auto-switch to relevant tab after a form save
  const msgTabMap = {
    added:'games', updated:'games', deleted:'games',
    upcoming_added:'games', upcoming_updated:'games', upcoming_deleted:'games',
    cat_added:'games', cat_updated:'games', cat_deleted:'games',
    announcement:'announcements',
    psplus_added:'psplus', psplus_updated:'psplus', psplus_deleted:'psplus',
    psplus_prices:'psplus', popular_added:'psplus', popular_updated:'psplus', popular_deleted:'psplus',
    customer_added:'customers', customer_updated:'customers', customer_deleted:'customers',
    settings_saved:'settings', password_changed:'security',
    wrong_password:'security', password_mismatch:'security', password_too_short:'security'
  };

  const initial = urlTab || (msg && msgTabMap[msg]) || localStorage.getItem(TAB_KEY) || 'settings';
  switchTab(initial);

  // Toast notifications
  if (msg) {
    const messages = { added:'✅ Game added!', updated:'✅ Game updated!', deleted:'🗑 Game deleted!', announcement:'📢 Announcement saved!', upcoming_added:'🔜 Upcoming game added!', upcoming_updated:'✅ Upcoming game updated!', upcoming_deleted:'🗑 Upcoming game deleted!', psplus_added:'⭐ Monthly entry added!', psplus_updated:'✅ Monthly entry updated!', psplus_deleted:'🗑 Monthly entry deleted!', psplus_prices:'💰 PS Plus prices saved!', popular_added:'🔥 Game added to Most Played!', popular_updated:'✅ Most Played game updated!', popular_deleted:'🗑 Game removed from Most Played!', settings_saved:'⚙️ Settings saved!', password_changed:'🔒 Password changed!', wrong_password:'❌ Current password is wrong!', password_mismatch:'❌ Passwords do not match!', password_too_short:'❌ Password must be at least 4 characters!', cat_added:'🏷️ Category created!', cat_updated:'🏷️ Category updated!', cat_deleted:'🗑 Category deleted!', customer_added:'👤 Customer added!', customer_updated:'✅ Customer updated!', customer_deleted:'🗑 Customer deleted!' };
    const text = messages[msg];
    if (text) {
      const toast = document.createElement('div');
      toast.className = 'toast success';
      toast.textContent = text;
      document.body.appendChild(toast);
      setTimeout(() => toast.classList.add('show'), 100);
      setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 400); }, 3000);
      history.replaceState({}, '', '/admin?tab=' + (msgTabMap[msg] || initial));
    }
  }
})();

// ── Loading overlay ──
(function() {
  const overlay = document.getElementById('loadingOverlay');
  const loadingText = document.getElementById('loadingText');
  const messages = { '/admin/announcement':'📢 Saving announcement...', '/admin/announcements':'📢 Saving announcement...', '/admin/site-settings':'⚙️ Saving settings...', '/admin/hero-text':'✏️ Saving hero text...', '/admin/change-password':'🔒 Changing password...', '/admin/psplus/prices':'💰 Saving PS Plus prices...', '/admin/add':'🎮 Adding game...', '/admin/upcoming/add':'🔜 Adding upcoming game...', '/admin/psplus/add':'⭐ Adding PS Plus entry...', '/admin/psplus/popular/add':'🔥 Adding Most Played game...', '/admin/price-categories':'🏷️ Saving category...' };
  document.addEventListener('submit', function(e) {
    if (e.target.dataset.noLoading) return;
    const action = e.target.action || '';
    const label = Object.keys(messages).find(k => action.includes(k));
    loadingText.textContent = label ? messages[label] : 'Saving changes...';
    overlay.style.display = 'flex';
  });
})();
</script>
</body>
</html>
