          </div>
          <div class="form-group" style="margin-top:0.75rem;"><label>Review Text *</label><textarea name="text" rows="3" placeholder="Paste the customer's review from Facebook..." required style="width:100%;resize:vertical;"></textarea></div>
          <button type="submit" class="btn" style="background:linear-gradient(135deg,#f59e0b,#d97706);color:#000;font-weight:700;border:none;padding:0.6rem 1.5rem;border-radius:50px;cursor:pointer;margin-top:0.5rem;">➕ Add Review</button>
