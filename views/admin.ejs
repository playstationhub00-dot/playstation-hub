<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel — <%= settings.title %></title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .admin-tabs { display:flex; gap:0.25rem; background:#0a0a0a; border:1px solid #1a1a1a; border-radius:14px; padding:0.35rem; margin-bottom:1.75rem; flex-wrap:wrap; }
    .admin-tab { flex:1; min-width:90px; text-align:center; padding:0.6rem 0.75rem; border-radius:10px; font-size:0.82rem; font-weight:700; cursor:pointer; color:#555; border:none; background:none; transition:all 0.18s; letter-spacing:0.3px; white-space:nowrap; }
    .admin-tab:hover { color:#aaa; background:#111; }
    .admin-tab.active { background:var(--ps-blue); color:#000; box-shadow:0 2px 12px rgba(240,165,0,0.3); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .add-choice-overlay { display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.7);backdrop-filter:blur(6px);align-items:center;justify-content:center; }
    .add-choice-overlay.open { display:flex; }
    .add-choice-box { background:#111;border:1px solid #222;border-radius:20px;padding:2rem;width:min(480px,92vw);animation:popIn 0.18s ease; }
    @keyframes popIn { from{transform:scale(0.93);opacity:0} to{transform:scale(1);opacity:1} }
    .add-choice-grid { display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-top:1.25rem; }
    .add-choice-card { background:#0a0a0a;border:1px solid #222;border-radius:14px;padding:1.25rem 0.75rem;text-align:center;cursor:pointer;transition:all 0.15s;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem; }
    .add-choice-card:hover { border-color:var(--ps-blue);background:#1a1500;transform:translateY(-2px); }
    .add-choice-card .icon { font-size:2rem;line-height:1; }
    .add-choice-card .label { font-weight:700;font-size:0.82rem;color:#fff; }
    .add-choice-card .desc { font-size:0.7rem;color:#555;line-height:1.4; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
    <a href="/admin/logout" style="background:#222;color:#aaa;border:1px solid #333;border-radius:8px;padding:0.45rem 0.9rem;font-size:0.8rem;font-weight:600;text-decoration:none;margin-left:0.5rem;">🔒 Logout</a>
  </div>
</nav>

<div class="admin-container">
  <div class="admin-header">
    <h1>🎮 Admin Panel</h1>
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <div id="mongoIndicator" style="display:flex;align-items:center;gap:0.45rem;background:#111;border:1px solid #222;border-radius:20px;padding:0.35rem 0.85rem;font-size:0.78rem;font-weight:600;color:#555;">
        <span id="mongoDot" style="width:8px;height:8px;border-radius:50%;background:#333;display:inline-block;"></span>
        <span id="mongoLabel">Checking DB…</span>
      </div>
      <button id="themeToggle" onclick="toggleTheme()" title="Toggle light/dark mode"
        style="background:#111;border:1px solid #222;border-radius:20px;padding:0.35rem 0.85rem;font-size:0.82rem;font-weight:600;color:#aaa;cursor:pointer;display:flex;align-items:center;gap:0.4rem;">
        <span id="themeIcon">☀️</span><span id="themeLabel">Light</span>
      </button>
      <a href="/" class="btn btn-outline" style="font-size:0.875rem;padding:0.5rem 1rem;">← View Site</a>
    </div>
  </div>
  <script>
  // Theme toggle
  (function() {
    const saved = localStorage.getItem('adminTheme');
    if (saved === 'light') applyLight();
  })();
  function applyLight() {
    document.body.classList.add('light-mode');
    const btn = document.getElementById('themeToggle');
    if (btn) { btn.style.background='#f0f2f5'; btn.style.borderColor='#ddd'; btn.style.color='#333'; }
    const icon = document.getElementById('themeIcon'), lbl = document.getElementById('themeLabel');
    if (icon) icon.textContent = '🌙';
    if (lbl) lbl.textContent = 'Dark';
  }
  function applyDark() {
    document.body.classList.remove('light-mode');
    const btn = document.getElementById('themeToggle');
    if (btn) { btn.style.background='#111'; btn.style.borderColor='#222'; btn.style.color='#aaa'; }
    const icon = document.getElementById('themeIcon'), lbl = document.getElementById('themeLabel');
    if (icon) icon.textContent = '☀️';
    if (lbl) lbl.textContent = 'Light';
  }
  function toggleTheme() {
    if (document.body.classList.contains('light-mode')) {
      applyDark(); localStorage.setItem('adminTheme', 'dark');
    } else {
      applyLight(); localStorage.setItem('adminTheme', 'light');
    }
  }
  fetch('/admin/mongo-status').then(r=>r.json()).then(d=>{
    const dot=document.getElementById('mongoDot'),label=document.getElementById('mongoLabel'),wrap=document.getElementById('mongoIndicator');
    if(d.status&&d.status.includes('✅')){dot.style.background='#22c55e';dot.style.boxShadow='0 0 6px #22c55e';label.textContent='MongoDB Connected';label.style.color='#22c55e';wrap.style.borderColor='#14532d';}
    else if(d.status&&d.status.includes('no MONGODB_URI')){dot.style.background='#f59e0b';label.textContent='No MONGODB_URI';label.style.color='#f59e0b';wrap.style.borderColor='#78350f';}
    else{dot.style.background='#ef4444';dot.style.boxShadow='0 0 6px #ef4444';label.textContent='DB Disconnected';label.style.color='#ef4444';wrap.style.borderColor='#7f1d1d';}
  }).catch(()=>{ document.getElementById('mongoLabel').textContent='DB Unknown'; });
  </script>

  <!-- TAB BAR -->
  <div class="admin-tabs" id="adminTabs">
    <button class="admin-tab" data-tab="settings" onclick="switchTab('settings')">⚙️ Settings</button>
    <button class="admin-tab" data-tab="announcements" onclick="switchTab('announcements')">📢 Announcements</button>
    <button class="admin-tab" data-tab="games" onclick="switchTab('games')">🎮 Games</button>
    <button class="admin-tab" data-tab="customers" onclick="switchTab('customers')">👥 Customers</button>
    <button class="admin-tab" data-tab="psplus" onclick="switchTab('psplus')">⭐ PS Plus</button>
    <button class="admin-tab" data-tab="visitors" onclick="switchTab('visitors')">👁️ Visitors</button>
    <button class="admin-tab" data-tab="security" onclick="switchTab('security')">🔒 Security</button>
  </div>

  <!-- ═══════════════ SETTINGS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-settings">

    <!-- SITE SETTINGS -->
    <div class="form-card" style="border-color:rgba(240,165,0,0.4);background:linear-gradient(135deg,#1a1500 0%,#1a1a0a 100%);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">⚙️ Site Settings</h2>
      <form method="POST" action="/admin/site-settings" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group full">
            <label>Website Title <span style="color:#555;font-size:0.75rem;">(shown in browser tab and nav)</span></label>
            <input type="text" name="title" value="<%= settings.title %>" placeholder="e.g. Playstation Hub" required>
          </div>
          <div class="form-group full">
            <label>Logo Image <span style="color:#555;font-size:0.75rem;">(PNG, JPG or SVG — blank keeps current)</span></label>
            <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:0.75rem;">
              <img src="<%= settings.logo_path %>" alt="Current logo" style="height:44px;width:auto;background:#000;border-radius:8px;padding:6px 10px;">
              <span style="color:#555;font-size:0.8rem;">Current logo</span>
            </div>
            <input type="file" name="logo" accept="image/*,.svg" style="padding:0.5rem;">
          </div>
          <div class="form-group full">
            <label>Favicon <span style="color:#555;font-size:0.75rem;">(small icon in browser tab — PNG, ICO or SVG)</span></label>
            <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:0.75rem;">
              <img src="<%= settings.favicon_path %>" alt="Current favicon" style="width:32px;height:32px;background:#000;border-radius:6px;padding:4px;">
              <span style="color:#555;font-size:0.8rem;">Current favicon</span>
            </div>
            <input type="file" name="favicon" accept="image/*,.svg,.ico" style="padding:0.5rem;">
          </div>

          <!-- Hero Background -->
          <div class="form-group full" style="margin-top:0.5rem;">
            <label>Home Page Hero Background</label>
            <div style="display:flex;gap:0.75rem;margin:0.65rem 0 1rem;flex-wrap:wrap;" id="heroBgOptions">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='default') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="default" <%= settings.hero_bg.type==='default' ? 'checked' : '' %> onchange="heroTypeChange(this)"> Default Gradient
              </label>
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='image') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="image" <%= settings.hero_bg.type==='image' ? 'checked' : '' %> onchange="heroTypeChange(this)"> 🖼 Image
              </label>
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='video') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="video" <%= settings.hero_bg.type==='video' ? 'checked' : '' %> onchange="heroTypeChange(this)"> 🎬 Video Loop
              </label>
            </div>
            <div id="heroBgUpload" style="display:<%= settings.hero_bg.type!=='default' ? 'block' : 'none' %>;">
              <% if (settings.hero_bg.path) { %>
              <div style="margin-bottom:0.75rem;display:flex;align-items:center;gap:0.75rem;">
                <% if (settings.hero_bg.type==='video') { %>
                  <video src="<%= settings.hero_bg.path %>" style="height:60px;border-radius:6px;" muted></video>
                <% } else { %>
                  <img src="<%= settings.hero_bg.path %>" style="height:60px;border-radius:6px;object-fit:cover;width:100px;">
                <% } %>
                <span style="color:#555;font-size:0.8rem;">Current background</span>
              </div>
              <% } %>
              <label style="color:#aaa;font-size:0.82rem;display:block;margin-bottom:0.4rem;">Upload new file <span style="color:#555;">(blank = keep current)</span></label>
              <input type="file" name="hero_bg_file" accept="image/*,video/mp4,video/webm" style="padding:0.5rem;">
              <div style="margin-top:0.5rem;font-size:0.78rem;color:#555;">Supported: JPG, PNG, WEBP for image · MP4, WEBM for video loop</div>
              <div style="margin-top:1.25rem;">
                <label style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                  <span style="color:#aaa;font-size:0.82rem;font-weight:600;">🌑 Background Darkness (overlay)</span>
                  <span id="overlayVal" style="color:var(--ps-blue);font-weight:700;font-size:0.9rem;"><%= settings.hero_bg.overlay || 50 %>%</span>
                </label>
                <input type="range" name="hero_bg_overlay" id="overlaySlider" min="0" max="100" value="<%= settings.hero_bg.overlay || 50 %>"
                  oninput="document.getElementById('overlayVal').textContent=this.value+'%'"
                  style="width:100%;accent-color:var(--ps-blue);cursor:pointer;height:6px;">
                <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:#555;margin-top:0.3rem;">
                  <span>0% — fully visible</span><span>100% — fully dark</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn btn-primary" style="background:var(--ps-blue);">Save Settings</button>
        </div>
      </form>

      <script>
      function heroTypeChange(el) {
        document.getElementById('heroBgUpload').style.display = el.value === 'default' ? 'none' : 'block';
        document.querySelectorAll('#heroBgOptions label').forEach(l => {
          l.style.borderColor = l.querySelector('input').checked ? 'var(--ps-blue)' : '#333';
        });
      }
      </script>
    </div>

    <!-- HERO SLIDES MANAGER -->
    <div class="form-card" style="border-color:rgba(240,165,0,0.5);background:linear-gradient(135deg,#0d0d00,#1a1a0a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">🖼 Hero Promo Slideshow</h2>
      <p style="color:#888;font-size:0.85rem;margin:0 0 1.25rem;">Upload promo posters. They replace the homepage hero with an auto-sliding carousel (auto-advances every 5 seconds). Remove all slides to restore the text hero.</p>

      <!-- Current slides -->
      <% if (settings.hero_slides && settings.hero_slides.length > 0) { %>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
        <% settings.hero_slides.forEach((sl, i) => { %>
        <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:10px;padding:0.75rem;display:flex;flex-direction:column;align-items:center;gap:0.5rem;width:160px;">
          <img src="<%= sl.path %>" style="width:100%;height:100px;object-fit:cover;border-radius:6px;">
          <% if (sl.caption) { %>
          <div style="font-size:0.72rem;color:#aaa;text-align:center;word-break:break-word;"><%= sl.caption %></div>
          <% } %>
          <form method="POST" action="/admin/hero-slides/delete" onsubmit="return confirm('Delete this slide?');" style="width:100%;">
            <input type="hidden" name="index" value="<%= i %>">
            <button type="submit" style="width:100%;background:#c0392b;border:none;color:#fff;border-radius:6px;padding:0.35rem;cursor:pointer;font-size:0.78rem;">🗑 Delete</button>
          </form>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div style="color:#666;font-size:0.85rem;margin-bottom:1.25rem;padding:0.75rem;background:#111;border-radius:8px;border:1px dashed #333;">No slides yet — upload your first promo poster below to activate the slideshow.</div>
      <% } %>

      <!-- Upload new slide -->
      <form method="POST" action="/admin/hero-slides/upload" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
        <label style="color:#aaa;font-size:0.82rem;font-weight:600;">Add New Slide</label>
        <input type="file" name="slide_image" accept="image/*" required style="padding:0.5rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;">
        <input type="text" name="caption" placeholder="Caption (optional — shown at bottom of slide)" style="padding:0.6rem 0.9rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;font-size:0.875rem;">
        <input type="text" name="link" placeholder="Link when tapped (optional, e.g. /browse)" style="padding:0.6rem 0.9rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;font-size:0.875rem;">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" style="background:var(--ps-blue);">Upload Slide</button>
        </div>
      </form>
    </div>

    <!-- HERO TEXT EDITOR -->
    <div class="form-card" style="border-color:rgba(240,165,0,0.3);background:linear-gradient(135deg,#111000,#1a1a0a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">✏️ Home Page Hero Text</h2>
      <form method="POST" action="/admin/hero-text">
        <div class="form-grid">
          <div class="form-group">
            <label>Line 1 <span style="color:#555;font-size:0.75rem;">("Rent the Latest")</span></label>
            <input type="text" name="line1" value="<%= settings.hero_text.line1 %>" placeholder="e.g. Rent the Latest">
          </div>
          <div class="form-group">
            <label>Line 2 <span style="color:#555;font-size:0.75rem;">("Games")</span></label>
            <input type="text" name="line2" value="<%= settings.hero_text.line2 %>" placeholder="e.g. Games">
          </div>
          <div class="form-group">
            <label>Highlighted Text <span style="color:#555;font-size:0.75rem;">("PS5 & PS4")</span></label>
            <input type="text" name="highlight" value="<%= settings.hero_text.highlight %>" placeholder="e.g. PS5 & PS4">
          </div>
          <div class="form-group">
            <label>Highlight Color</label>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <input type="color" name="highlight_color" value="<%= settings.hero_text.highlight_color %>" style="width:48px;height:40px;border:none;border-radius:8px;cursor:pointer;background:none;">
              <span id="hlColorVal" style="color:#aaa;font-size:0.85rem;font-family:monospace;"><%= settings.hero_text.highlight_color %></span>
            </div>
          </div>
          <div class="form-group full">
            <label>Subtitle Text</label>
            <textarea name="subtitle" rows="2" placeholder="e.g. Play more, pay less..."><%= settings.hero_text.subtitle %></textarea>
          </div>
          <div class="form-group">
            <label>Subtitle Color</label>
            <div style="display:flex;align-items:center;gap:0.75rem;">
              <input type="color" name="subtitle_color" value="<%= settings.hero_text.subtitle_color %>" style="width:48px;height:40px;border:none;border-radius:8px;cursor:pointer;background:none;">
              <span id="subColorVal" style="color:#aaa;font-size:0.85rem;font-family:monospace;"><%= settings.hero_text.subtitle_color %></span>
            </div>
          </div>
          <div class="form-group full">
            <label style="display:flex;justify-content:space-between;">
              <span>Title Font Size</span>
              <span id="titleSizeVal" style="color:var(--ps-blue);font-weight:700;"><%= settings.hero_text.title_size %>px</span>
            </label>
            <input type="range" name="title_size" min="20" max="120" value="<%= settings.hero_text.title_size %>"
              oninput="document.getElementById('titleSizeVal').textContent=this.value+'px'"
              style="width:100%;accent-color:var(--ps-blue);cursor:pointer;height:6px;">
            <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:#555;margin-top:0.3rem;">
              <span>20px — small</span><span>120px — huge</span>
            </div>
          </div>
          <div class="form-group full">
            <label style="color:#555;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.5px;">Preview</label>
            <div id="heroPreview" style="background:linear-gradient(135deg,#000,#1a1000,#000);border-radius:12px;padding:2rem;text-align:center;border:1px solid #222;">
              <div id="prevTitle" style="font-weight:900;line-height:1.15;margin-bottom:0.75rem;color:#fff;"></div>
              <div id="prevSubtitle" style="font-size:0.9rem;max-width:480px;margin:0 auto;"></div>
            </div>
          </div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn btn-primary" style="background:var(--ps-blue);">Save Hero Text</button>
        </div>
      </form>
      <script>
      (function() {
        const fields = { line1:document.querySelector('[name=line1]'), line2:document.querySelector('[name=line2]'), highlight:document.querySelector('[name=highlight]'), highlight_color:document.querySelector('[name=highlight_color]'), subtitle:document.querySelector('[name=subtitle]'), subtitle_color:document.querySelector('[name=subtitle_color]'), title_size:document.querySelector('[name=title_size]') };
        function updatePreview() {
          const l1=fields.line1.value,l2=fields.line2.value,hl=fields.highlight.value,hlColor=fields.highlight_color.value,subColor=fields.subtitle_color.value,size=fields.title_size.value;
          document.getElementById('prevTitle').style.fontSize=size+'px';
          document.getElementById('prevTitle').innerHTML=(l1?l1+'<br>':'')+'<span style="color:'+hlColor+'">'+(hl||'')+'</span>'+(l2?' '+l2:'');
          document.getElementById('prevSubtitle').style.color=subColor;
          document.getElementById('prevSubtitle').textContent=fields.subtitle.value;
          document.getElementById('hlColorVal').textContent=hlColor;
          document.getElementById('subColorVal').textContent=subColor;
        }
        Object.values(fields).forEach(f=>{if(f)f.addEventListener('input',updatePreview);});
        updatePreview();
      })();
      </script>
    </div>

  </div><!-- /tab-settings -->

  <!-- ═══════════════ ANNOUNCEMENTS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-announcements">
    <div class="form-card" style="border-color:rgba(0,112,209,0.4);background:linear-gradient(135deg,#1a1a1a 0%,#0d1a2e 100%);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">📢 Announcements <span style="font-size:0.78rem;font-weight:400;color:#555;margin-left:0.25rem;">— rotate through multiple banners</span></h2>

      <% if (announcements && announcements.length > 0) { %>
      <div style="display:flex;flex-direction:column;gap:0.65rem;margin-bottom:1.25rem;">
        <% announcements.forEach((ann, i) => { %>
        <div style="background:#0a0a14;border:1px solid #1a1a3a;border-radius:10px;padding:0.85rem 1rem;display:flex;align-items:flex-start;gap:0.75rem;">
          <span style="font-size:1rem;margin-top:0.1rem;">📢</span>
          <div style="flex:1;">
            <form method="POST" action="/admin/announcements/edit/<%= ann.id %>" style="display:flex;flex-direction:column;gap:0.6rem;">
              <textarea name="text" rows="2" style="width:100%;resize:vertical;"><%= ann.text %></textarea>
              <div style="display:flex;align-items:center;gap:1rem;">
                <label style="display:flex;align-items:center;gap:0.4rem;font-size:0.82rem;cursor:pointer;">
                  <label class="toggle-switch" style="width:38px;height:20px;">
                    <input type="checkbox" name="active" <%= ann.active ? 'checked' : '' %>>
                    <span class="toggle-slider"></span>
                  </label>
                  <span style="color:<%= ann.active ? '#22c55e' : '#555' %>"><%= ann.active ? 'Active' : 'Hidden' %></span>
                </label>
                <button type="submit" class="btn btn-primary" style="padding:0.35rem 0.9rem;font-size:0.8rem;">Save</button>
                <button type="button" class="btn btn-outline" style="padding:0.35rem 0.9rem;font-size:0.8rem;border-color:#7f1d1d;color:#ef4444;"
                  onclick="if(confirm('Delete this announcement?')) fetch('/admin/announcements/delete/<%= ann.id %>',{method:'POST'}).then(()=>location.reload());">
                  Delete
                </button>
              </div>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p style="color:#444;font-size:0.82rem;margin-bottom:1rem;font-style:italic;">No announcements yet.</p>
      <% } %>

      <details style="background:#050514;border:1px dashed #1a1a3a;border-radius:10px;overflow:hidden;">
        <summary style="padding:0.85rem 1rem;cursor:pointer;color:#4a9eff;font-weight:700;font-size:0.9rem;list-style:none;">+ Add New Announcement</summary>
        <div style="padding:1rem;border-top:1px dashed #1a1a3a;">
          <form method="POST" action="/admin/announcements/add">
            <div class="form-grid">
              <div class="form-group full">
                <label>Announcement Text *</label>
                <textarea name="text" rows="2" placeholder="📢 Your announcement here..." required></textarea>
              </div>
              <div class="form-group">
                <label>Show on Website</label>
                <label class="toggle-switch"><input type="checkbox" name="active" checked><span class="toggle-slider"></span></label>
              </div>
            </div>
            <div class="form-actions" style="margin-top:0.75rem;">
              <button type="submit" class="btn btn-primary" style="background:#1d4ed8;">Add Announcement</button>
            </div>
          </form>
        </div>
      </details>
    </div>
  </div><!-- /tab-announcements -->

  <!-- ═══════════════ GAMES TAB ═══════════════ -->
  <div class="tab-panel" id="tab-games">

    <!-- Add New button -->
    <div style="display:flex;justify-content:flex-end;margin-bottom:1.25rem;">
      <button onclick="document.getElementById('addChoiceModal').classList.add('open')"
        class="btn btn-primary" style="background:var(--ps-blue);color:#000;font-weight:800;font-size:0.9rem;padding:0.65rem 1.5rem;border-radius:50px;display:flex;align-items:center;gap:0.5rem;">
        + Add New
      </button>
    </div>

    <!-- Choice Modal -->
    <div class="add-choice-overlay" id="addChoiceModal" onclick="if(event.target===this)this.classList.remove('open')">
      <div class="add-choice-box">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-weight:800;font-size:1.1rem;color:#fff;">What do you want to add?</span>
          <button onclick="document.getElementById('addChoiceModal').classList.remove('open')" style="background:none;border:none;color:#555;font-size:1.4rem;cursor:pointer;line-height:1;">✕</button>
        </div>
        <div class="add-choice-grid">
          <a class="add-choice-card" href="#add-game-form" onclick="document.getElementById('addChoiceModal').classList.remove('open');setTimeout(()=>document.getElementById('add-game-form').scrollIntoView({behavior:'smooth'}),50)">
            <span class="icon">🎮</span>
            <span class="label">New Game</span>
            <span class="desc">Add a rentable PS5 or PS4 game to your library</span>
          </a>
          <a class="add-choice-card" href="#add-upcoming-form" onclick="document.getElementById('addChoiceModal').classList.remove('open');setTimeout(()=>document.getElementById('add-upcoming-form').scrollIntoView({behavior:'smooth'}),50)">
            <span class="icon">🔜</span>
            <span class="label">Upcoming Game</span>
            <span class="desc">Add a coming soon title open for reservation</span>
          </a>
          <a class="add-choice-card" href="#add-category-form" onclick="document.getElementById('addChoiceModal').classList.remove('open');setTimeout(()=>document.getElementById('add-category-form').scrollIntoView({behavior:'smooth'}),50)">
            <span class="icon">🏷️</span>
            <span class="label">Price Category</span>
            <span class="desc">Create a pricing tier shared by multiple games</span>
          </a>
        </div>
      </div>
    </div>

    <!-- PRICE CATEGORIES -->
    <div id="add-category-form" class="form-card" style="border-color:rgba(34,197,94,0.3);background:linear-gradient(135deg,#001a06,#0a1a0a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">🏷️ Price Categories</h2>
      <p style="color:#666;font-size:0.82rem;margin-bottom:1.25rem;">Create pricing tiers (e.g. "New Games", "Classic") — assign games to a category so they all share the same price automatically.</p>
      <% if (priceCategories.length > 0) { %>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:1.5rem;">
        <% priceCategories.forEach(cat => { %>
        <details style="background:#0a0a0a;border:1px solid #1a2a1a;border-radius:10px;overflow:hidden;">
          <summary style="padding:0.85rem 1rem;cursor:pointer;display:flex;align-items:center;gap:0.75rem;list-style:none;user-select:none;">
            <span style="font-size:1rem;">🏷️</span>
            <span style="font-weight:700;color:#fff;flex:1;"><%= cat.name %></span>
            <span style="font-size:0.75rem;color:#555;">NT: ₱<%= cat.nt_price_10d %>/₱<%= cat.nt_price_15d %>/₱<%= cat.nt_price_30d %> &nbsp;|&nbsp; TR: ₱<%= cat.tr_price_10d %>/₱<%= cat.tr_price_15d %>/₱<%= cat.tr_price_30d %></span>
            <span style="color:#444;font-size:0.8rem;margin-left:0.5rem;">▼</span>
          </summary>
          <div style="padding:1rem;border-top:1px solid #1a2a1a;">
            <form method="POST" action="/admin/price-categories/edit/<%= cat.id %>">
              <div class="form-grid">
                <div class="form-group full"><label>Category Name</label><input type="text" name="name" value="<%= cat.name %>" required></div>
                <div class="form-group full" style="margin-bottom:0;"><label style="color:#aaa;">🎮 Non-Trophy Prices (₱)</label></div>
                <div class="form-group"><label>10 Days</label><input type="number" name="nt_price_10d" value="<%= cat.nt_price_10d %>" min="1"></div>
                <div class="form-group"><label>15 Days</label><input type="number" name="nt_price_15d" value="<%= cat.nt_price_15d %>" min="1"></div>
                <div class="form-group"><label>30 Days</label><input type="number" name="nt_price_30d" value="<%= cat.nt_price_30d %>" min="1"></div>
                <div class="form-group full" style="margin-bottom:0;"><label style="color:#ffc400;">🏆 Trophy Account Prices (₱)</label></div>
                <div class="form-group"><label>10 Days</label><input type="number" name="tr_price_10d" value="<%= cat.tr_price_10d %>" min="1"></div>
                <div class="form-group"><label>15 Days</label><input type="number" name="tr_price_15d" value="<%= cat.tr_price_15d %>" min="1"></div>
                <div class="form-group"><label>30 Days</label><input type="number" name="tr_price_30d" value="<%= cat.tr_price_30d %>" min="1"></div>
              </div>
              <div class="form-actions" style="margin-top:0.75rem;">
                <button type="submit" class="btn btn-primary" style="background:#166534;">Save Category</button>
                <button type="button" class="btn btn-outline" style="border-color:#7f1d1d;color:#ef4444;"
                  onclick="if(confirm('Delete this category? Games using it will switch to custom price.')) { fetch('/admin/price-categories/delete/<%= cat.id %>',{method:'POST'}).then(()=>location.reload()); }">Delete</button>
              </div>
            </form>
          </div>
        </details>
        <% }) %>
      </div>
      <% } else { %>
      <p style="color:#444;font-size:0.82rem;margin-bottom:1.25rem;font-style:italic;">No categories yet. Add one below.</p>
      <% } %>
      <details style="background:#050f05;border:1px dashed #1a3a1a;border-radius:10px;overflow:hidden;">
        <summary style="padding:0.85rem 1rem;cursor:pointer;color:#22c55e;font-weight:700;font-size:0.9rem;list-style:none;">+ Add New Price Category</summary>
        <div style="padding:1rem;border-top:1px dashed #1a3a1a;">
          <form method="POST" action="/admin/price-categories/add">
            <div class="form-grid">
              <div class="form-group full"><label>Category Name *</label><input type="text" name="name" placeholder="e.g. New Games, Classic, Special" required></div>
              <div class="form-group full" style="margin-bottom:0;"><label style="color:#aaa;">🎮 Non-Trophy Prices (₱)</label></div>
              <div class="form-group"><label>10 Days</label><input type="number" name="nt_price_10d" value="149" min="1"></div>
              <div class="form-group"><label>15 Days</label><input type="number" name="nt_price_15d" value="199" min="1"></div>
              <div class="form-group"><label>30 Days</label><input type="number" name="nt_price_30d" value="349" min="1"></div>
              <div class="form-group full" style="margin-bottom:0;"><label style="color:#ffc400;">🏆 Trophy Account Prices (₱)</label></div>
              <div class="form-group"><label>10 Days</label><input type="number" name="tr_price_10d" value="199" min="1"></div>
              <div class="form-group"><label>15 Days</label><input type="number" name="tr_price_15d" value="249" min="1"></div>
              <div class="form-group"><label>30 Days</label><input type="number" name="tr_price_30d" value="399" min="1"></div>
            </div>
            <div class="form-actions" style="margin-top:0.75rem;">
              <button type="submit" class="btn btn-primary" style="background:#166534;">Create Category</button>
            </div>
          </form>
        </div>
      </details>
    </div>

    <!-- ADD GAME FORM -->
    <div id="add-game-form" class="form-card">
      <h2>+ Add New Game</h2>
      <form method="POST" action="/admin/add" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group full"><label>Game Title *</label><input type="text" name="title" placeholder="e.g. God of War Ragnarök" required></div>
          <div class="form-group">
            <label>Platform</label>
            <select name="platform"><option value="PS5">PS5</option><option value="PS4">PS4</option><option value="PS4/PS5">PS4/PS5</option></select>
          </div>
          <div class="form-group"><label>Genre</label><input type="text" name="genre" placeholder="e.g. Action, RPG, Horror"></div>
          <div class="form-group"><label>🎮 Non-Trophy Slots</label><input type="number" name="non_trophy_slots" value="1" min="0"></div>
          <div class="form-group"><label>Available Slots <span style="color:#555;font-size:0.7rem;">(total)</span></label><input type="number" name="available_slots" value="1" min="0"></div>
          <div class="form-group"><label>Current Renters</label><input type="number" name="renters" value="0" min="0"></div>
          <div class="form-group"><label>🕹️ PS4 Primary Slots</label><input type="number" name="ps4_primary_slots" value="0" min="0"></div>
          <div class="form-group"><label>Game Cost (₱) <span style="color:#555;font-size:0.72rem;">what you paid</span></label><input type="number" name="cost" value="0" min="0" placeholder="e.g. 2500"></div>

          <!-- Pricing mode -->
          <div class="form-group full">
            <label>Pricing</label>
            <div style="display:flex;gap:0.75rem;margin-bottom:0.75rem;">
              <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-weight:600;">
                <input type="radio" name="price_mode" value="category" id="add_mode_cat" onchange="toggleAddPriceMode(this.value)" <%= priceCategories.length ? '' : 'disabled' %>>
                🏷️ Use Category
              </label>
              <label style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-weight:600;">
                <input type="radio" name="price_mode" value="custom" id="add_mode_custom" onchange="toggleAddPriceMode(this.value)" checked>
                ✏️ Custom Price
              </label>
            </div>
            <div id="add_cat_section" style="display:none;">
              <select name="price_category_id" style="width:100%;">
                <option value="">— Select a category —</option>
                <% priceCategories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.name %> (NT: ₱<%= cat.nt_price_10d %>/₱<%= cat.nt_price_15d %>/₱<%= cat.nt_price_30d %>)</option>
                <% }) %>
              </select>
            </div>
          </div>
          <div id="add_custom_prices">
            <div class="form-group full" style="margin-bottom:0;"><label style="color:#aaa;">🎮 Non-Trophy Prices (₱)</label></div>
            <div class="form-group"><label>10 Days</label><input type="number" name="nt_price_10d" value="149" min="1"></div>
            <div class="form-group"><label>15 Days</label><input type="number" name="nt_price_15d" value="199" min="1"></div>
            <div class="form-group"><label>30 Days</label><input type="number" name="nt_price_30d" value="349" min="1"></div>
            <div class="form-group full" style="margin-bottom:0;"><label style="color:#ffc400;">🏆 Trophy Account Prices (₱) <span style="font-weight:400;color:#664d00;font-size:0.78rem;">— +₱100 deposit not included here</span></label></div>
            <div class="form-group"><label>10 Days</label><input type="number" name="tr_price_10d" value="199" min="1"></div>
            <div class="form-group"><label>15 Days</label><input type="number" name="tr_price_15d" value="249" min="1"></div>
            <div class="form-group"><label>30 Days</label><input type="number" name="tr_price_30d" value="399" min="1"></div>
          </div>
          <script>
          function toggleAddPriceMode(v) {
            document.getElementById('add_cat_section').style.display = v==='category' ? 'block' : 'none';
            document.getElementById('add_custom_prices').style.display = v==='category' ? 'none' : 'contents';
          }
          </script>

          <div class="form-group"><label>Cover Image</label><input type="file" name="cover_image" accept="image/*" style="padding:0.5rem;"></div>
          <div class="form-group" style="justify-content:center;">
            <label>Trophy Account Available</label>
            <label class="toggle-switch"><input type="checkbox" name="trophy_account" id="add_trophy_chk" onchange="document.getElementById('add_trophy_slots').style.display=this.checked?'block':'none'"><span class="toggle-slider"></span></label>
          </div>
          <div class="form-group" id="add_trophy_slots" style="display:none;">
            <label>Trophy Account Slots <span style="color:#ffc400;font-size:0.72rem;">🏆 how many accounts</span></label>
            <input type="number" name="trophy_slots" value="1" min="1" max="20">
          </div>
          <div class="form-group full"><label>Description (optional)</label><textarea name="description" placeholder="Short description of the game..."></textarea></div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add Game</button>
          <button type="reset" class="btn btn-outline">Clear</button>
        </div>
      </form>
    </div>

    <!-- GAMES TABLE -->
    <div class="table-card">
      <h2>All Games (<%= games.length %>)</h2>
      <div style="overflow-x:auto;">
        <table class="games-table">
          <thead>
            <tr><th>Cover</th><th>Title</th><th>Platform</th><th>🎮 NT Slots</th><th style="color:#ffc400;">🏆 TR Slots</th><th>🕹️ PS4 Slots</th><th>Non-Trophy Prices</th><th>Trophy Prices</th><th style="color:#f59e0b;">Cost</th><th style="color:#22c55e;">Earned</th><th style="color:var(--ps-blue);">Profit</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% if (games.length === 0) { %>
            <tr><td colspan="12" style="text-align:center;color:var(--text-secondary);padding:2rem;">No games yet. Add one above!</td></tr>
            <% } %>
            <% games.forEach(game => {
              const gameTotalEarned = customers.filter(c => c.game_id === game.id).reduce((s,c) => s+(c.price||0), 0);
              const gameRentalCount = customers.filter(c => c.game_id === game.id).length;
              const gameCost = game.cost || 0;
              const gameProfit = gameTotalEarned - gameCost;
            %>
            <tr>
              <td>
                <% if (game.cover_image) { %><img src="<%= game.cover_image %>" class="table-cover" alt=""><% } else { %><div class="table-cover-placeholder">🎮</div><% } %>
              </td>
              <td>
                <strong><%= game.title %></strong>
                <% if (game._category_name) { %>
                  <span style="display:inline-block;margin-left:0.4rem;background:#0a2a0a;border:1px solid #166534;border-radius:20px;padding:0.1rem 0.5rem;font-size:0.68rem;color:#22c55e;font-weight:600;">🏷️ <%= game._category_name %></span>
                <% } %>
              </td>
              <td><span style="color:var(--ps-blue);font-weight:600;font-size:0.8rem;"><%= game.platform %></span></td>
              <td>
                <% const ntS = game.non_trophy_slots || 0; %>
                <% if (ntS > 0) { %><span class="badge badge-available"><%= ntS %></span><% } else { %><span class="badge badge-unavailable">0</span><% } %>
              </td>
              <td>
                <% if (game.trophy_account) { %>
                  <span style="color:#ffc400;font-weight:700;font-size:0.88rem;">🏆 <%= game.trophy_slots || 0 %></span>
                <% } else if ((game.trophy_slots || 0) > 0) { %>
                  <span style="color:#555;font-size:0.8rem;"><%= game.trophy_slots %> (off)</span>
                <% } else { %>
                  <span style="color:#333;font-size:0.8rem;">—</span>
                <% } %>
              </td>
              <td>
                <% const ps4S = game.ps4_primary_slots || 0; %>
                <% if (game.platform === 'PS4' || game.platform === 'PS4/PS5') { %>
                  <% if (ps4S > 0) { %><span style="color:#60a5fa;font-weight:700;">🕹️ <%= ps4S %></span><% } else { %><span style="color:#333;font-size:0.8rem;">0</span><% } %>
                <% } else { %>
                  <span style="color:#333;font-size:0.8rem;">—</span>
                <% } %>
              </td>
              <td style="font-size:0.8rem;color:#aaa;line-height:1.7;">₱<%= game.nt_price_10d %> / ₱<%= game.nt_price_15d %> / ₱<%= game.nt_price_30d %></td>
              <td style="font-size:0.8rem;color:#ffc400;line-height:1.7;"><%= game.trophy_account ? '₱'+game.tr_price_10d+' / ₱'+game.tr_price_15d+' / ₱'+game.tr_price_30d : '—' %></td>
              <td>
                <div style="font-weight:700;color:#f59e0b;font-size:0.9rem;">₱<%= gameCost.toLocaleString() %></div>
              </td>
              <td>
                <div style="font-weight:800;color:#22c55e;font-size:0.9rem;">₱<%= gameTotalEarned.toLocaleString() %></div>
                <div style="font-size:0.68rem;color:#555;margin-top:0.1rem;"><%= gameRentalCount %> txn<%= gameRentalCount !== 1 ? 's' : '' %></div>
              </td>
              <td>
                <div style="font-weight:800;color:<%= gameProfit >= 0 ? 'var(--ps-blue)' : '#ef4444' %>;font-size:0.9rem;">₱<%= gameProfit.toLocaleString() %></div>
                <div style="font-size:0.68rem;color:#555;margin-top:0.1rem;"><%= gameProfit >= 0 ? 'profit' : 'at a loss' %></div>
              </td>
              <td>
                <div class="action-btns">
                  <a href="/admin/edit/<%= game.id %>" class="btn-edit">✏️ Edit</a>
                  <form method="POST" action="/admin/delete/<%= game.id %>" style="display:inline" onsubmit="return confirm('Delete <%= game.title.replace(/'/g, "\\'") %>?')">
                    <button type="submit" class="btn-delete">🗑 Delete</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- UPCOMING GAMES -->
    <div id="add-upcoming-form" class="form-card" style="border-color:#2a1a3a;background:linear-gradient(135deg,#1a1a1a,#0d001a);margin-top:1.5rem;">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">🔜 Add Upcoming Game <span style="font-size:0.75rem;font-weight:500;color:#666;margin-left:0.25rem;">— Open for Reservation</span></h2>
      <form method="POST" action="/admin/upcoming/add" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group full"><label>Game Title *</label><input type="text" name="title" placeholder="e.g. GTA VI" required></div>
          <div class="form-group">
            <label>Platform</label>
            <select name="platform"><option value="PS5">PS5</option><option value="PS4">PS4</option><option value="PS4/PS5">PS4/PS5</option></select>
          </div>
          <div class="form-group"><label>Genre</label><input type="text" name="genre" placeholder="e.g. Open World, RPG"></div>
          <div class="form-group">
            <label>Expected Release Date</label>
            <div style="display:flex;flex-direction:column;gap:0.5rem;">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;font-weight:600;">
                <input type="checkbox" id="add_tba" name="release_date_tba" onchange="toggleAddTba(this.checked)">
                Mark as TBA (date unknown)
              </label>
              <input type="date" name="release_date" id="add_date_input" style="width:100%;">
              <input type="hidden" name="release_date_tba_val" id="add_tba_hidden" value="">
            </div>
          </div>
          <script>
          function toggleAddTba(checked) {
            const inp=document.getElementById('add_date_input'),hid=document.getElementById('add_tba_hidden');
            inp.disabled=checked; inp.style.opacity=checked?'0.3':'1'; hid.value=checked?'TBA':'';
          }
          </script>
          <div class="form-group"><label>Cover Image</label><input type="file" name="cover_image" accept="image/*" style="padding:0.5rem;"></div>
          <div class="form-group full"><label>Description (optional)</label><textarea name="description" placeholder="Short description..."></textarea></div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn" style="background:linear-gradient(135deg,#4a0080,#7b2ff7);color:#fff;font-weight:700;padding:0.75rem 1.75rem;border-radius:50px;border:none;cursor:pointer;">Add Upcoming Game</button>
          <button type="reset" class="btn btn-outline">Clear</button>
        </div>
      </form>
    </div>

    <% if (upcoming.length > 0) { %>
    <div class="table-card" style="border-color:#2a1a3a;">
      <h2 style="border-color:#2a1a3a;">🔜 Upcoming Games (<%= upcoming.length %>)</h2>
      <div style="overflow-x:auto;">
        <table class="games-table">
          <thead><tr><th>Cover</th><th>Title</th><th>Platform</th><th>Genre</th><th>Release Date</th><th>Actions</th></tr></thead>
          <tbody>
            <% upcoming.forEach(game => { %>
            <tr>
              <td><% if (game.cover_image) { %><img src="<%= game.cover_image %>" class="table-cover" alt=""><% } else { %><div class="table-cover-placeholder" style="background:#1a0030;">🔜</div><% } %></td>
              <td>
                <strong><%= game.title %></strong>
                <div style="font-size:0.72rem;margin-top:0.2rem;"><span style="background:linear-gradient(135deg,#4a0080,#f107a3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:700;">COMING SOON</span></div>
              </td>
              <td><span style="color:var(--ps-blue);font-weight:600;font-size:0.8rem;"><%= game.platform %></span></td>
              <td style="color:var(--text-secondary)"><%= game.genre || '—' %></td>
              <td style="color:#aaa;font-size:0.85rem;"><%= game.release_date === 'TBA' ? 'TBA' : (game.release_date ? new Date(game.release_date+'T00:00:00').toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'}) : '—') %></td>
              <td>
                <div class="action-btns">
                  <a href="/admin/upcoming/edit/<%= game.id %>" class="btn-edit">✏️ Edit</a>
                  <form method="POST" action="/admin/upcoming/delete/<%= game.id %>" style="display:inline" onsubmit="return confirm('Delete <%= game.title.replace(/'/g, "\\'") %>?')">
                    <button type="submit" class="btn-delete">🗑 Delete</button>
