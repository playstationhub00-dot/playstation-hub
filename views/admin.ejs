          <div><div style="font-size:1.3rem;font-weight:900;color:#aaa;line-height:1;"><%= doneCustomers.length %></div><div style="font-size:0.6rem;color:#555;margin-top:0.1rem;">Completed</div></div>
        </div>
        <div style="background:<%= overdueCustomers.length > 0 ? '#1a0a0a' : '#0d0d0d' %>;border:1px solid <%= overdueCustomers.length > 0 ? '#3a1a1a' : '#1e1e1e' %>;border-radius:10px;padding:0.75rem 0.6rem;display:flex;align-items:center;gap:0.5rem;">
          <div style="font-size:1.2rem;">⚠️</div>
          <div><div style="font-size:1.3rem;font-weight:900;color:<%= overdueCustomers.length > 0 ? '#ef4444' : '#555' %>;line-height:1;"><%= overdueCustomers.length %></div><div style="font-size:0.6rem;color:#555;margin-top:0.1rem;">Overdue</div></div>
        </div>
      </div>

      <!-- Charts Row -->
      <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:0.65rem;margin-bottom:0.65rem;">

        <!-- Monthly Bar Chart -->
        <div style="background:#0d0d0d;border:1px solid #1e1e1e;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.85rem;">Monthly Revenue — Last 6 Months</div>
          <div style="display:flex;align-items:flex-end;gap:0.4rem;height:110px;" id="dashBarChart">
            <% monthLabels.forEach((lbl, i) => {
              const pct = Math.max(Math.round((monthRevs[i] / maxMonthRev) * 100), 3);
              const isLast = i === monthLabels.length - 1;
              const isPeak = monthRevs[i] === maxMonthRev && maxMonthRev > 0;
              const barColor = isPeak ? '#3b82f6' : isLast ? '#22c55e' : '#2a2a2a';
              const valColor = isPeak ? '#3b82f6' : isLast ? '#22c55e' : '#555';
            %>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.25rem;height:100%;">
              <div style="flex:1;display:flex;align-items:flex-end;width:100%;">
                <div style="width:100%;height:<%= pct %>%;background:<%= barColor %>;border-radius:4px 4px 0 0;min-height:3px;cursor:pointer;transition:opacity 0.15s;"
                  onmouseenter="showDashTip(event,'<%= lbl %>: ₱<%= monthRevs[i].toLocaleString() %>')"
                  onmouseleave="hideDashTip()"
                  onmousemove="moveDashTip(event)"></div>
              </div>
              <div style="font-size:0.58rem;color:#444;white-space:nowrap;"><%= lbl %></div>
              <% if (monthRevs[i] > 0) { %>
              <div style="font-size:0.58rem;font-weight:700;color:<%= valColor %>;">₱<%= monthRevs[i] >= 1000 ? (monthRevs[i]/1000).toFixed(1)+'k' : monthRevs[i] %></div>
              <% } else { %><div style="font-size:0.58rem;"> </div><% } %>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Top Games -->
        <div style="background:#0d0d0d;border:1px solid #1e1e1e;border-radius:12px;padding:1rem;">
          <div style="font-size:0.7rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.85rem;">Most Rented / Sold Games</div>
          <% if (topGames.length === 0) { %>
            <div style="color:#333;font-size:0.8rem;text-align:center;padding:1.5rem 0;">No data yet</div>
          <% } else {
            const maxCount = topGames[0][1];
            const medals = ['🥇','🥈','🥉'];
          %>
          <div style="display:flex;flex-direction:column;gap:0.55rem;">
            <% topGames.forEach(([title, count], i) => { %>
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.2rem;">
                <div style="font-size:0.75rem;color:#ccc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:72%;"><%= medals[i] || (i+1)+'.' %> <%= title %></div>
                <div style="font-size:0.72rem;font-weight:800;color:#3b82f6;"><%= count %>x</div>
              </div>
              <div style="background:#1a1a1a;border-radius:3px;height:5px;">
                <div style="width:<%= Math.round((count/maxCount)*100) %>%;height:100%;background:linear-gradient(90deg,#3b82f6,#7c3aed);border-radius:3px;"></div>
              </div>
            </div>
            <% }) %>
          </div>
          <% } %>
        </div>

      </div>

      <!-- Insight Pills -->
      <%
        const sortedRevs = [...monthRevs];
        const peakIdx = sortedRevs.indexOf(Math.max(...sortedRevs));
        const peakMonth = monthLabels[peakIdx] || '';
        const peakVal = Math.max(...monthRevs);
        const prevMonthRev = monthRevs[monthRevs.length - 2] || 0;
        const currMonthRev = monthRevs[monthRevs.length - 1] || 0;
        const rentPct = totalRevenue > 0 ? Math.round((rentRevenue/totalRevenue)*100) : 0;
      %>
      <div style="display:flex;flex-direction:column;gap:0.45rem;">
        <% if (peakVal > 0) { %>
        <div style="background:#111;border:1px solid #1e1e1e;border-radius:8px;padding:0.55rem 0.85rem;font-size:0.72rem;color:#aaa;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.4;">
          <span style="flex-shrink:0;">📈</span>
          <span><strong style="color:#fff;">Best month: <%= peakMonth %></strong> — ₱<%= peakVal.toLocaleString() %>. Identify what worked and repeat it.</span>
        </div>
        <% } %>
        <% if (overdueCustomers.length > 0) { %>
        <div style="background:#1a0a0a;border:1px solid #3a1a1a;border-radius:8px;padding:0.55rem 0.85rem;font-size:0.72rem;color:#aaa;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.4;">
          <span style="flex-shrink:0;">⚠️</span>
          <span><strong style="color:#ef4444;"><%= overdueCustomers.length %> overdue rental<%= overdueCustomers.length !== 1 ? 's' : '' %></strong> — follow up immediately to recover games or collect late fees.</span>
        </div>
        <% } %>
        <% if (rentPct > 90) { %>
        <div style="background:#111;border:1px solid #1e1e1e;border-radius:8px;padding:0.55rem 0.85rem;font-size:0.72rem;color:#aaa;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.4;">
          <span style="flex-shrink:0;">💰</span>
          <span><strong style="color:#fff;">Game sales are only <%= 100 - rentPct %>% of revenue</strong> — push buy options to returning renters to grow this.</span>
        </div>
        <% } %>
        <% if (topGames.length > 0) { %>
        <div style="background:#111;border:1px solid #1e1e1e;border-radius:8px;padding:0.55rem 0.85rem;font-size:0.72rem;color:#aaa;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.4;">
          <span style="flex-shrink:0;">🎮</span>
          <span><strong style="color:#fff;"><%= topGames[0][0] %> is your #1 game</strong> — <%= topGames[0][1] %>x rented/sold. Keep it stocked and front-and-center on your site.</span>
        </div>
        <% } %>
        <% if (doneCustomers.length > activeCustomers.length * 5) { %>
        <div style="background:#111;border:1px solid #1e1e1e;border-radius:8px;padding:0.55rem 0.85rem;font-size:0.72rem;color:#aaa;display:flex;align-items:flex-start;gap:0.5rem;line-height:1.4;">
          <span style="flex-shrink:0;">📉</span>
          <span><strong style="color:#fff;"><%= doneCustomers.length %> past customers</strong> vs <%= activeCustomers.length %> active — most renters don't return. A Messenger follow-up campaign could recover many of them.</span>
        </div>
        <% } %>
      </div>

      <!-- Tooltip -->
      <div id="dashTip" style="position:fixed;background:#1a1a1a;border:1px solid #333;border-radius:8px;padding:0.4rem 0.65rem;font-size:0.72rem;color:#fff;pointer-events:none;z-index:9999;display:none;white-space:nowrap;"></div>
      <script>
        function showDashTip(e, text) { var t=document.getElementById('dashTip'); t.textContent=text; t.style.display='block'; moveDashTip(e); }
        function hideDashTip() { document.getElementById('dashTip').style.display='none'; }
        function moveDashTip(e) { var t=document.getElementById('dashTip'); t.style.left=(e.clientX+12)+'px'; t.style.top=(e.clientY-28)+'px'; }
      </script>

    </div>

      </div></div><!-- /accordion dashboard -->

    <!-- Message Blast -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #f43f5e;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(244,63,94,0.15);">📢</div>
          <div><div class="sa-title">Message Blast</div><div class="sa-desc">Generate personalized messages for past customers</div></div>
        </div><span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div style="padding:1.25rem;">

      <!-- AUTO BLAST SECTION -->
      <div style="background:linear-gradient(135deg,rgba(244,63,94,0.08),rgba(168,85,247,0.08));border:1px solid #3a1a2a;border-radius:14px;padding:1.25rem;margin-bottom:1.5rem;">
        <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.85rem;">
          <div style="font-size:1.2rem;">⚡</div>
          <div>
            <div style="font-weight:800;font-size:0.9rem;color:#f43f5e;">Auto Send via Messenger API</div>
            <div style="font-size:0.72rem;color:#555;margin-top:0.1rem;">Sends directly to everyone who has ever messaged your Facebook Page</div>
          </div>
          <div style="margin-left:auto;background:#111;border:1px solid #2a2a2a;border-radius:20px;padding:0.3rem 0.75rem;font-size:0.72rem;color:#aaa;" id="blastContactCount">
            Loading contacts...
          </div>
        </div>
        <textarea id="autoBlastMsg" rows="5" style="width:100%;background:#0a0a0a;border:1px solid #2a2a2a;border-radius:10px;color:#fff;padding:0.85rem;font-size:0.83rem;line-height:1.6;resize:vertical;font-family:inherit;box-sizing:border-box;margin-bottom:0.75rem;">Kamusta! 👋 PlayStation Hub dito!

Nag-aalok kami ng mga bagong laro ngayon! 🎮

Mayroon kaming mga PS5 exclusives at dagdag pang mga titles. Pumunta sa aming website para makita ang lahat:

👉 https://playstation-hub-production.up.railway.app

Mag-message lang para mag-reserve ng slot! 😊</textarea>
        <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
          <button onclick="sendAutoBlast()" id="autoBlastBtn" style="background:linear-gradient(135deg,#f43f5e,#a855f7);color:#fff;border:none;border-radius:9px;padding:0.6rem 1.25rem;font-weight:800;font-size:0.85rem;cursor:pointer;display:flex;align-items:center;gap:0.4rem;">
            ⚡ Send to All Contacts
          </button>
          <div id="autoBlastStatus" style="font-size:0.8rem;color:#555;"></div>
        </div>
        <div id="autoBlastResult" style="display:none;margin-top:0.85rem;background:#0a1a0a;border:1px solid #1a3a1a;border-radius:10px;padding:0.85rem;font-size:0.82rem;line-height:1.7;"></div>
        <div style="margin-top:0.65rem;font-size:0.68rem;color:#333;line-height:1.5;">
          ℹ️ Uses <strong style="color:#444;">HUMAN_AGENT</strong> tag — works for contacts who messaged within 7 days. Contacts are collected automatically from your Page's Messenger inbox.
        </div>
      </div>

      <div style="border-top:1px solid #1a1a1a;padding-top:1rem;margin-bottom:1rem;">
        <div style="font-size:0.7rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.75rem;">Manual Copy-Paste Tool (for older contacts)</div>
      </div>

      <!-- Stats bar -->
      <%
        const doneC = customers.filter(c => c.status === 'done');
        const uniqueNames = [...new Set(doneC.map(c => c.customer_name))];
        const blastData = uniqueNames.map(name => {
          const records = doneC.filter(c => c.customer_name === name);
          const lastGame = records[records.length - 1]?.game_title || '';
          const totalRentals = records.length;
          return { name, lastGame, totalRentals };
        }).sort((a,b) => b.totalRentals - a.totalRentals);
      %>
      <div style="display:flex;gap:0.65rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        <div style="background:#0a1a0a;border:1px solid #1a3a1a;border-radius:10px;padding:0.65rem 1rem;flex:1;min-width:120px;">
          <div style="font-size:0.65rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Past Customers</div>
          <div style="font-size:1.4rem;font-weight:900;color:#22c55e;"><%= uniqueNames.length %></div>
        </div>
        <div style="background:#100a00;border:1px solid #3a2a00;border-radius:10px;padding:0.65rem 1rem;flex:1;min-width:120px;">
          <div style="font-size:0.65rem;color:#555;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Total Past Rentals</div>
          <div style="font-size:1.4rem;font-weight:900;color:#fbbf24;"><%= doneC.length %></div>
        </div>
        <div style="background:#0a0a1a;border:1px solid #1a1a3a;border-radius:10px;padding:0.65rem 1rem;flex:2;min-width:180px;display:flex;align-items:center;gap:0.75rem;">
          <div style="font-size:1.5rem;">💡</div>
          <div style="font-size:0.75rem;color:#555;line-height:1.5;">Copy a customer's message and paste it in <strong style="color:#aaa;">Facebook Messenger</strong> to reach them individually.</div>
        </div>
      </div>

      <!-- Message Template Composer -->
      <div style="margin-bottom:1rem;">
        <label style="font-size:0.75rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:0.5rem;">Message Template</label>
        <div style="font-size:0.72rem;color:#555;margin-bottom:0.75rem;">Use <code style="background:#1a1a1a;padding:0.1rem 0.35rem;border-radius:4px;color:#a78bfa;">{name}</code> and <code style="background:#1a1a1a;padding:0.1rem 0.35rem;border-radius:4px;color:#a78bfa;">{game}</code> as placeholders.</div>

        <!-- AI Generator -->
        <div style="background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(59,130,246,0.06));border:1px solid #2a1a3a;border-radius:12px;padding:0.9rem;margin-bottom:0.85rem;">
          <div style="font-size:0.72rem;font-weight:700;color:#a855f7;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.35rem;">
            <span>✨</span> AI Message Generator
          </div>
          <div style="display:flex;gap:0.5rem;">
            <input type="text" id="aiPrompt" placeholder='e.g. "encourage them to come back for holidays" or "promote our Buy permanent option"'
              style="flex:1;background:#111;border:1px solid #2a2a2a;border-radius:8px;color:#fff;padding:0.55rem 0.85rem;font-size:0.8rem;min-width:0;">
            <button onclick="generateAITemplate()" id="aiGenBtn"
              style="background:linear-gradient(135deg,#7b2ff7,#3b82f6);color:#fff;border:none;border-radius:8px;padding:0.55rem 1rem;font-weight:700;font-size:0.8rem;cursor:pointer;white-space:nowrap;flex-shrink:0;">
              ✨ Generate
            </button>
          </div>
          <div id="aiGenStatus" style="font-size:0.72rem;color:#555;margin-top:0.4rem;min-height:1rem;"></div>
        </div>
        <textarea id="blastTemplate" rows="5" style="width:100%;background:#111;border:1px solid #333;border-radius:10px;color:#fff;padding:0.85rem;font-size:0.85rem;line-height:1.6;resize:vertical;font-family:inherit;box-sizing:border-box;">Hey {name}! 👋

Kamusta na? Just wanted to reach out — we have new games available at PlayStation Hub! 🎮

Last time you rented {game} — we've got even more titles now including PS5 exclusives!

We also have a new Permanent Access option if you want to own a game slot forever 🔓

Check it out: https://playstation-hub-production.up.railway.app

Message us anytime to reserve your slot! 😊</textarea>
        <div style="display:flex;gap:0.5rem;margin-top:0.65rem;flex-wrap:wrap;">
          <button onclick="generateBlast()" style="background:linear-gradient(135deg,#f43f5e,#e11d48);color:#fff;border:none;border-radius:8px;padding:0.55rem 1.1rem;font-weight:700;font-size:0.82rem;cursor:pointer;">⚡ Generate Messages</button>
          <button onclick="copyAllNames()" style="background:#1a1a1a;color:#aaa;border:1px solid #333;border-radius:8px;padding:0.55rem 1.1rem;font-weight:700;font-size:0.82rem;cursor:pointer;">📋 Copy All Names</button>
          <button onclick="filterBlast('all')" id="blastFilterAll" style="background:var(--ps-blue);color:#000;border:none;border-radius:8px;padding:0.55rem 0.85rem;font-weight:700;font-size:0.78rem;cursor:pointer;">All</button>
          <button onclick="filterBlast('top')" id="blastFilterTop" style="background:#1a1a1a;color:#aaa;border:1px solid #333;border-radius:8px;padding:0.55rem 0.85rem;font-weight:700;font-size:0.78rem;cursor:pointer;">Top Renters</button>
          <input type="text" id="blastSearch" oninput="filterBlastSearch(this.value)" placeholder="Search name..." style="background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;padding:0.5rem 0.85rem;font-size:0.82rem;flex:1;min-width:140px;">
        </div>
      </div>

      <!-- Copied toast -->
      <div id="blastToast" style="display:none;background:#22c55e;color:#000;font-weight:700;font-size:0.8rem;padding:0.4rem 1rem;border-radius:20px;text-align:center;margin-bottom:0.75rem;">✅ Copied!</div>

      <!-- Customer List -->
      <div id="blastList" style="display:flex;flex-direction:column;gap:0.5rem;max-height:520px;overflow-y:auto;">
        <% blastData.forEach((c, i) => { %>
        <div class="blast-row" data-name="<%= c.name.toLowerCase() %>" data-rentals="<%= c.totalRentals %>"
          style="background:#111;border:1px solid #1e1e1e;border-radius:10px;padding:0.85rem 1rem;display:flex;align-items:center;gap:0.85rem;">
          <div style="font-size:0.75rem;font-weight:900;color:#333;min-width:22px;text-align:right;">#<%= i+1 %></div>
          <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:0.88rem;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= c.name %></div>
            <div style="font-size:0.7rem;color:#555;margin-top:0.1rem;">Last: <%= c.lastGame %> &nbsp;·&nbsp; <%= c.totalRentals %> rental<%= c.totalRentals !== 1 ? 's' : '' %></div>
          </div>
          <button onclick="copyBlastMsg('<%= c.name.replace(/'/g,"\\'") %>','<%= c.lastGame.replace(/'/g,"\\'") %>')"
            style="background:#1a1a1a;color:#aaa;border:1px solid #2a2a2a;border-radius:7px;padding:0.4rem 0.75rem;font-size:0.75rem;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0;">
            📋 Copy Msg
          </button>
          <button onclick="openFBSearch('<%= c.name.replace(/'/g,"\\'") %>')"
            style="background:#1877f2;color:#fff;border:none;border-radius:7px;padding:0.4rem 0.75rem;font-size:0.75rem;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0;">
            📘 Find
          </button>
        </div>
        <% }) %>
        <% if (blastData.length === 0) { %>
        <div style="text-align:center;padding:2rem;color:#333;font-size:0.85rem;">No past customers yet.</div>
        <% } %>
      </div>

      <script>
      async function generateAITemplate() {
        const prompt = document.getElementById('aiPrompt').value.trim();
        if (!prompt) { document.getElementById('aiGenStatus').textContent = 'Please describe what kind of message you want.'; return; }
        const btn = document.getElementById('aiGenBtn');
        const status = document.getElementById('aiGenStatus');
        btn.disabled = true; btn.textContent = '⏳ Generating...';
        status.textContent = 'AI is writing your message...';
        try {
          const resp = await fetch('/admin/ai-generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'prompt=' + encodeURIComponent(prompt)
          });
          const data = await resp.json();
          if (data.ok) {
            document.getElementById('blastTemplate').value = data.message;
            document.getElementById('autoBlastMsg').value = data.message;
            status.innerHTML = '<span style="color:#22c55e;">✅ Message generated! You can edit it before sending.</span>';
          } else {
            status.innerHTML = '<span style="color:#f43f5e;">❌ ' + (data.error || 'Failed') + '</span>';
          }
        } catch(e) {
          status.innerHTML = '<span style="color:#f43f5e;">❌ Network error.</span>';
        }
        btn.disabled = false; btn.textContent = '✨ Generate';
      }

      // Load contact count
      fetch('/admin/blast/contacts').then(r=>r.json()).then(d=>{
        document.getElementById('blastContactCount').textContent = d.count + ' FB contact' + (d.count!==1?'s':'');
        document.getElementById('blastContactCount').style.color = d.count > 0 ? '#22c55e' : '#f43f5e';
      }).catch(()=>{});

      async function sendAutoBlast() {
        const msg = document.getElementById('autoBlastMsg').value.trim();
        if (!msg) return showBlastToast('Please write a message first!');
        const btn = document.getElementById('autoBlastBtn');
        const status = document.getElementById('autoBlastStatus');
        const result = document.getElementById('autoBlastResult');
        if (!confirm('Send this message to ALL your Facebook Messenger contacts?\n\nThis cannot be undone.')) return;
        btn.disabled = true;
        btn.textContent = '⏳ Sending...';
        status.textContent = 'Please wait...';
        result.style.display = 'none';
        try {
          const resp = await fetch('/admin/blast', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'message=' + encodeURIComponent(msg)
          });
          const data = await resp.json();
          result.style.display = 'block';
          if (data.ok) {
            result.innerHTML = '<strong style="color:#22c55e;">✅ Blast Complete!</strong><br>' +
              '📤 Sent: <strong style="color:#22c55e;">' + data.sent + '</strong> &nbsp;|&nbsp; ' +
              '❌ Failed: <strong style="color:' + (data.failed>0?'#f43f5e':'#555') + '">' + data.failed + '</strong> &nbsp;|&nbsp; ' +
              '👥 Total contacts: <strong>' + data.total + '</strong>';
            status.textContent = '';
          } else {
            result.innerHTML = '<strong style="color:#f43f5e;">❌ ' + (data.error || 'Send failed') + '</strong>';
            status.textContent = '';
          }
        } catch(e) {
          result.style.display = 'block';
          result.innerHTML = '<strong style="color:#f43f5e;">❌ Network error. Try again.</strong>';
          status.textContent = '';
        }
        btn.disabled = false;
        btn.textContent = '⚡ Send to All Contacts';
      }

      const _blastData = <%- JSON.stringify(blastData) %>;

      function generateBlast() {
        const tmpl = document.getElementById('blastTemplate').value;
        document.querySelectorAll('.blast-preview').forEach(e => e.remove());
        showBlastToast('⚡ Messages ready — click Copy Msg on each customer!');
      }

      function copyBlastMsg(name, game) {
        const tmpl = document.getElementById('blastTemplate').value;
        const msg = tmpl.replace(/\{name\}/g, name).replace(/\{game\}/g, game || 'a game');
        navigator.clipboard.writeText(msg).then(() => showBlastToast('✅ Copied message for ' + name + '!'));
      }

      function copyAllNames() {
        const rows = document.querySelectorAll('.blast-row:not([style*="display: none"]):not([style*="display:none"])');
        const names = [...rows].map(r => r.querySelector('[style*="font-weight:700"]')?.textContent?.trim()).filter(Boolean);
        navigator.clipboard.writeText(names.join('\n')).then(() => showBlastToast('✅ Copied ' + names.length + ' names!'));
      }

      function showBlastToast(msg) {
        const t = document.getElementById('blastToast');
        t.textContent = msg; t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 2500);
      }

      let _blastFilter = 'all';
      function filterBlast(type) {
        _blastFilter = type;
        document.getElementById('blastFilterAll').style.background = type === 'all' ? 'var(--ps-blue)' : '#1a1a1a';
        document.getElementById('blastFilterAll').style.color = type === 'all' ? '#000' : '#aaa';
        document.getElementById('blastFilterTop').style.background = type === 'top' ? 'var(--ps-blue)' : '#1a1a1a';
        document.getElementById('blastFilterTop').style.color = type === 'top' ? '#000' : '#aaa';
        applyBlastFilters();
      }

      function filterBlastSearch(q) { applyBlastFilters(q); }

      function openFBSearch(name) {
        navigator.clipboard.writeText(name).catch(()=>{});
        window.open('https://www.facebook.com/messages/search/?query=' + encodeURIComponent(name), '_blank');
        showBlastToast('📘 Opening Messenger search for ' + name);
      }

      function applyBlastFilters(q) {
        q = (q || document.getElementById('blastSearch').value || '').toLowerCase().trim();
        document.querySelectorAll('.blast-row').forEach(row => {
          const nameMatch = !q || row.dataset.name.includes(q);
          const topMatch = _blastFilter !== 'top' || parseInt(row.dataset.rentals) >= 3;
          row.style.display = (nameMatch && topMatch) ? '' : 'none';
        });
      }
      </script>

    </div>
      </div></div><!-- /accordion message-blast -->

    <!-- Import Customers from Excel -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #818cf8;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(129,140,248,0.15);">📥</div>
          <div><div class="sa-title">Import from Excel</div><div class="sa-desc">Bulk-import customer records via .xlsx file</div></div>
        </div><span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div class="form-card" style="border-color:rgba(99,102,241,0.35);background:linear-gradient(135deg,#0d0d1f,#0a0a0a);">
      <h2 style="display:none;">📥 Import Customers from Excel</h2>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin:0 0 1rem;">
        Upload an Excel file (.xlsx) to bulk-import customer records. Existing customers are kept — only new rows are added.
      </p>
      <% if (locals.msg) { %>
        <% if (String(msg).startsWith('imported_')) { %>
          <%
            const parts = String(msg).split('_');
            const importedN = parts[1] || '?';
            const skippedN = parts[3] || '0';
          %>
          <div style="background:rgba(34,197,94,0.12);border:1px solid #22c55e;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;color:#22c55e;font-weight:600;">
            ✅ Successfully imported <%= importedN %> customer(s)<% if (parseInt(skippedN) > 0) { %>, <%= skippedN %> row(s) skipped (blank name)<% } %>.
          </div>
        <% } else if (String(msg).includes('import_error') || String(msg) === 'error') { %>
          <div style="background:rgba(239,68,68,0.12);border:1px solid #ef4444;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;color:#ef4444;font-weight:600;">
            ❌ Import failed. Make sure the file is a valid .xlsx using the sample format.
          </div>
        <% } %>
      <% } %>
      <form method="POST" action="/admin/customers/import" enctype="multipart/form-data">
        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
          <label style="flex:1;min-width:240px;">
            <span style="color:var(--text-secondary);font-size:0.8rem;display:block;margin-bottom:0.35rem;">Select Excel File (.xlsx)</span>
            <input type="file" name="import_file" accept=".xlsx,.xls" required
              style="width:100%;padding:0.5rem 0.75rem;background:#111;border:1px solid #333;border-radius:8px;color:#eee;font-size:0.85rem;cursor:pointer;">
          </label>
          <div style="display:flex;flex-direction:column;gap:0.5rem;padding-top:0.4rem;">
            <button type="submit" class="btn btn-primary" style="background:#4f46e5;min-width:130px;">📤 Import</button>
            <a href="/admin/customers/sample" class="btn btn-outline" style="text-align:center;font-size:0.8rem;min-width:130px;">⬇️ Sample File</a>
          </div>
        </div>
      </form>
      <div style="margin-top:1rem;padding:0.85rem 1rem;background:#0d0d0d;border-radius:8px;border:1px solid #222;">
        <p style="font-size:0.78rem;color:var(--text-secondary);margin:0 0 0.4rem;font-weight:700;">Required columns in your Excel file:</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
          <% ['customer_name','game_title','days','account_type','start_date','end_date','price','status','notes'].forEach(col => { %>
            <code style="background:#1a1a1a;border:1px solid #333;padding:0.15rem 0.5rem;border-radius:4px;font-size:0.75rem;color:#a78bfa;"><%= col %></code>
          <% }) %>
        </div>
        <p style="font-size:0.75rem;color:#666;margin:0.5rem 0 0;">account_type: <b style="color:#ccc">nt</b> / <b style="color:#ffc400">tr</b> / <b style="color:#60a5fa">ps4</b> &nbsp;|&nbsp; status: <b style="color:#ccc">renting</b> / <b style="color:#ccc">done</b> / <b style="color:#ccc">bought</b> / <b style="color:#ccc">reservation</b> &nbsp;|&nbsp; dates: YYYY-MM-DD</p>
      </div>
      </div></div><!-- /accordion import -->

    <!-- Add Customer Form -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #22c55e;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(34,197,94,0.15);">👤</div>
          <div><div class="sa-title">Add New Customer</div><div class="sa-desc">Log a rental, sale, or reservation manually</div></div>
        </div><span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div class="form-card" style="border-color:rgba(34,197,94,0.3);background:linear-gradient(135deg,#001a06,#0a0a0a);">
      <h2 style="display:none;">👤 Add New Customer</h2>
      <form method="POST" action="/admin/customers/add">
        <div class="form-grid">

          <div class="form-group full">
            <label>Customer Name *</label>
            <input type="text" name="customer_name" placeholder="e.g. Juan dela Cruz" required>
          </div>

          <div class="form-group full">
            <label id="cust_game_label">Game Rented *</label>
            <select name="game_id" id="cust_game" onchange="updateCustPrice()" required>
              <option value="">— Select a game —</option>
              <!-- Regular games (shown for renting/done/bought) -->
              <optgroup label="Available Games" id="cust_optgroup_regular">
                <% games.forEach(g => { %>
                <option value="<%= g.id %>" data-type="regular"
                  data-nt10="<%= g.nt_price_10d %>" data-nt15="<%= g.nt_price_15d %>" data-nt30="<%= g.nt_price_30d %>"
                  data-tr10="<%= g.tr_price_10d %>" data-tr15="<%= g.tr_price_15d %>" data-tr30="<%= g.tr_price_30d %>"
                  data-slots="<%= g.available_slots %>">
                  <%= g.title %> (<%= g.platform %>)<%= g.available_slots > 0 ? ' — '+g.available_slots+' slot(s)' : ' — FULL' %>
                </option>
                <% }) %>
              </optgroup>
              <!-- Upcoming games (shown for reservation) -->
              <optgroup label="Coming Soon Games" id="cust_optgroup_upcoming" style="display:none;">
                <% upcoming.forEach(g => { %>
                <option value="upcoming_<%= g.id %>" data-type="upcoming" data-title="<%= g.title %>"
                  data-nt10="<%= g.nt_price_10d||0 %>" data-nt15="<%= g.nt_price_15d||0 %>" data-nt30="<%= g.nt_price_30d||0 %>"
                  data-tr10="<%= g.tr_price_10d||0 %>" data-tr15="<%= g.tr_price_15d||0 %>" data-tr30="<%= g.tr_price_30d||0 %>">
                  🔜 <%= g.title %> (<%= g.platform %>) — <%= g.release_date === 'TBA' ? 'TBA' : g.release_date %>
                </option>
                <% }) %>
              </optgroup>
            </select>
          </div>

          <div class="form-group" id="cust_days_group">
            <label>Rental Duration</label>
            <select name="days" id="cust_days" onchange="toggleCustCustomDays(this.value);updateCustPrice()">
              <option value="10">10 Days</option>
              <option value="15">15 Days</option>
              <option value="30">30 Days</option>
              <option value="custom">✏️ Custom...</option>
            </select>
            <input type="number" id="cust_custom_days" name="custom_days" min="1" max="365" placeholder="Enter number of days"
              hidden oninput="updateCustEndDate()">
          </div>

          <div class="form-group">
            <label>Account Type</label>
            <select name="account_type" id="cust_type" onchange="updateCustPrice()">
              <option value="nt">🎮 Non-Trophy</option>
              <option value="tr">🏆 Trophy Account</option>
              <option value="ps4">🕹️ PS4 Primary</option>
            </select>
          </div>

          <div class="form-group">
            <label>Start Date</label>
            <input type="date" name="start_date" id="cust_start" onchange="updateCustEndDate()">
          </div>

          <div class="form-group">
            <label>End Date <span style="color:#555;font-size:0.72rem;">(auto-calculated)</span></label>
            <input type="date" name="end_date" id="cust_end">
          </div>

          <div class="form-group">
            <label>Price (₱) <span style="color:#555;font-size:0.72rem;">(auto-filled)</span></label>
            <input type="number" name="price" id="cust_price" min="0" placeholder="0">
          </div>

          <div class="form-group">
            <label>Status</label>
            <select name="status" id="cust_status" onchange="toggleCustStatus(this.value)">
              <option value="renting">🟢 Currently Renting</option>
              <option value="reservation">🔖 Reservation</option>
              <option value="done">✅ Done</option>
              <option value="bought">🛒 Bought</option>
            </select>
          </div>

          <div class="form-group full">
            <label>🗂️ Assign to Account Slot <span style="color:#555;font-size:0.72rem;">(optional — marks that slot rented/buyed on the Accounts dashboard)</span></label>
            <% const SLOT_LBL = { trophy:'🏆 Trophy', non_trophy:'🎮 Non-Trophy', ps4_primary:'🕹️ PS4 Primary' }; %>
            <select name="account_assign">
              <option value="">— None —</option>
              <% (accounts||[]).forEach(a => { ['trophy','non_trophy','ps4_primary'].forEach(t => { const s=a.slots[t]; if (s && s.enabled && s.status==='open') { %>
                <option value="<%= a.id %>:<%= t %>"><%= a.label %> — <%= SLOT_LBL[t] %></option>
              <% } }) }) %>
            </select>
          </div>

          <div class="form-group full">
            <label>Notes <span style="color:#555;font-size:0.72rem;">(optional)</span></label>
            <input type="text" name="notes" placeholder="e.g. Paid via GCash, needs follow-up...">
          </div>

        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" style="background:#166534;">Add Customer</button>
          <button type="reset" class="btn btn-outline">Clear</button>
        </div>
      </form>
      <script>
      function getCustDays() {
        const sel = document.getElementById('cust_days');
        if (sel.value === 'custom') return parseInt(document.getElementById('cust_custom_days').value) || 0;
        return parseInt(sel.value) || 0;
      }
      function toggleCustCustomDays(val) {
        const inp = document.getElementById('cust_custom_days');
        if (val === 'custom') { inp.removeAttribute('hidden'); inp.focus(); }
        else inp.setAttribute('hidden', '');
      }
      function toggleCustStatus(status) {
        const daysGroup = document.getElementById('cust_days_group');
        const gameLabel = document.getElementById('cust_game_label');
        const grpRegular = document.getElementById('cust_optgroup_regular');
        const grpUpcoming = document.getElementById('cust_optgroup_upcoming');
        const gameSel = document.getElementById('cust_game');

        if (status === 'reservation') {
          // Show only coming soon games
          daysGroup.removeAttribute('hidden');
          grpRegular.style.display = 'none';
          grpUpcoming.style.display = '';
          gameLabel.textContent = 'Coming Soon Game *';
          // Reset selection to avoid carrying over a regular game
          gameSel.value = '';
        } else {
          // Show only regular games
          grpRegular.style.display = '';
          grpUpcoming.style.display = 'none';
          gameLabel.textContent = 'Game Rented *';
          gameSel.value = '';
          if (status === 'bought') {
            daysGroup.setAttribute('hidden', '');
          } else {
            daysGroup.removeAttribute('hidden');
            updateCustEndDate();
          }
        }
      }
      function updateCustPrice() {
        const sel = document.getElementById('cust_game');
        const opt = sel.options[sel.selectedIndex];
        const days = document.getElementById('cust_days').value;
        const type = document.getElementById('cust_type').value;
        if (!opt.value) return;
        // Only auto-fill price for standard durations
        const price = (days !== 'custom') ? (opt.dataset[type + days] || '') : '';
        if (price) document.getElementById('cust_price').value = price;
        updateCustEndDate();
      }
      function updateCustEndDate() {
        const start = document.getElementById('cust_start').value;
        const days = getCustDays();
        if (!start || !days) return;
        const d = new Date(start + 'T00:00:00');
        d.setDate(d.getDate() + days);
        document.getElementById('cust_end').value = d.toISOString().slice(0,10);
      }
      // Set today as default start date
      document.getElementById('cust_start').value = new Date().toISOString().slice(0,10);
      updateCustEndDate();
      </script>
    </div>

      </div></div><!-- /accordion add-customer -->

    <!-- Customers Table -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #60a5fa;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(96,165,250,0.15);">📋</div>
          <div><div class="sa-title">All Customers (<%= customers.length %>)</div><div class="sa-desc">View, filter, edit & manage all rental records</div></div>
        </div><span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div class="table-card" style="margin-top:0;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;flex-wrap:wrap;gap:0.5rem;">
        <h2 style="margin:0;border:none;padding:0;">All Customers (<%= customers.length %>)</h2>
        <div style="position:relative;flex:0 0 260px;">
          <input type="text" id="custSearch" placeholder="Search name or game..." oninput="searchCustomers(this.value)"
            style="width:100%;padding:0.45rem 0.9rem 0.45rem 2.2rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;font-size:0.85rem;box-sizing:border-box;">
          <span style="position:absolute;left:0.6rem;top:50%;transform:translateY(-50%);color:#555;font-size:0.9rem;pointer-events:none;">🔍</span>
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        <button onclick="filterCustomers('all')" id="cf-all" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;">All</button>
        <button onclick="filterCustomers('renting')" id="cf-renting" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#166534;color:#22c55e;">🟢 Renting</button>
        <button onclick="filterCustomers('reservation')" id="cf-reservation" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#4a1a6a;color:#c084fc;">🔖 Reservation</button>
        <button onclick="filterCustomers('bought')" id="cf-bought" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;border-color:#1e3a5f;color:#60a5fa;">🛒 Bought</button>
        <button onclick="filterCustomers('done')" id="cf-done" class="btn btn-outline" style="padding:0.3rem 0.85rem;font-size:0.78rem;font-weight:700;">✅ Done</button>
      </div>

      <% if (customers.length === 0) { %>
        <div style="padding:2rem;text-align:center;color:#444;font-style:italic;">No customers yet. Add one above!</div>
      <% } else { %>
      <div style="max-height:520px;overflow-y:auto;overflow-x:auto;border-radius:8px;">
        <table class="games-table" id="customersTable">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Game</th>
              <th>Duration</th>
              <th>Type</th>
              <th>Start</th>
              <th>End</th>
              <th>Price</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% customers.forEach(c => {
              const isRenting = c.status === 'renting';
              const isBought = c.status === 'bought';
              const isReservation = c.status === 'reservation';
              const endDate = c.end_date ? new Date(c.end_date + 'T00:00:00') : null;
              const today = new Date(); today.setHours(0,0,0,0);
              const isOverdue = isRenting && endDate && endDate < today;
              const daysLeft = endDate ? Math.ceil((endDate - today) / 86400000) : null;
            %>
            <tr class="cust-row" data-status="<%= c.status %>" data-name="<%= c.customer_name.toLowerCase() %>" data-game="<%= c.game_title.toLowerCase() %>" style="<%= isOverdue ? 'background:rgba(239,68,68,0.06);' : '' %>">
              <td>
                <div style="font-weight:700;"><%= c.customer_name %></div>
                <% if (c.notes) { %><div style="font-size:0.7rem;color:#555;margin-top:0.15rem;"><%= c.notes %></div><% } %>
              </td>
              <td style="font-size:0.85rem;">
                <strong><%= c.game_title %></strong>
                <% if (isReservation && String(c.game_id).startsWith('upcoming_')) { %>
                <div style="margin-top:0.2rem;"><span style="background:linear-gradient(135deg,rgba(74,0,128,0.3),rgba(241,7,163,0.2));border:1px solid #5a2a8a;border-radius:6px;padding:0.1rem 0.45rem;font-size:0.65rem;color:#a855f7;font-weight:700;">🔜 Coming Soon</span></div>
                <% } %>
              </td>
              <td style="color:#aaa;font-size:0.85rem;"><%= (isBought || isReservation) ? '—' : c.days + ' days' %></td>
              <td>
                <% if (c.account_type === 'tr') { %>
                  <span style="color:#ffc400;font-size:0.78rem;font-weight:700;">🏆 Trophy</span>
                <% } else if (c.account_type === 'ps4') { %>
                  <span style="color:#60a5fa;font-size:0.78rem;font-weight:700;">🕹️ PS4 Primary</span>
                <% } else { %>
                  <span style="color:#aaa;font-size:0.78rem;">🎮 Non-Trophy</span>
                <% } %>
              </td>
              <td style="font-size:0.82rem;color:#aaa;"><%= c.start_date ? new Date(c.start_date+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '—' %></td>
              <td style="font-size:0.82rem;">
                <% if (c.end_date) { %>
                  <span style="color:<%= isOverdue ? '#ef4444' : (daysLeft !== null && daysLeft <= 2 && isRenting ? '#f59e0b' : '#aaa') %>;">
                    <%= new Date(c.end_date+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %>
                  </span>
                  <% if (isRenting && daysLeft !== null) { %>
                    <div style="font-size:0.68rem;color:<%= isOverdue ? '#ef4444' : (daysLeft <= 2 ? '#f59e0b' : '#555') %>;">
                      <%= isOverdue ? 'Overdue by '+Math.abs(daysLeft)+'d' : daysLeft === 0 ? 'Due today' : daysLeft+'d left' %>
                    </div>
                  <% } %>
                <% } else { %>—<% } %>
              </td>
              <td style="font-weight:700;color:var(--ps-blue);">₱<%= c.price || 0 %></td>
              <td>
                <form method="POST" action="/admin/customers/status/<%= c.id %>" style="display:inline;">
                  <% if (isRenting) { %>
                    <input type="hidden" name="status" value="done">
                    <button type="submit" style="background:#166534;color:#fff;border:none;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;cursor:pointer;white-space:nowrap;" title="Mark as Done">🟢 Renting</button>
                  <% } else if (isReservation) { %>
                    <span style="background:#2d1a4a;color:#c084fc;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;white-space:nowrap;">🔖 Reserved</span>
                  <% } else if (isBought) { %>
                    <span style="background:#1e3a5f;color:#60a5fa;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;white-space:nowrap;">🛒 Bought</span>
                  <% } else { %>
                    <input type="hidden" name="status" value="renting">
                    <button type="submit" style="background:#222;color:#aaa;border:1px solid #333;border-radius:20px;padding:0.25rem 0.7rem;font-size:0.72rem;font-weight:700;cursor:pointer;white-space:nowrap;" title="Mark as Renting">✅ Done</button>
                  <% } %>
                </form>
              </td>
              <td>
                <div class="action-btns">
                  <a href="/admin/customers/edit/<%= c.id %>" class="btn-edit">✏️ Edit</a>
                  <form method="POST" action="/admin/customers/delete/<%= c.id %>" style="display:inline" onsubmit="return confirm('Delete <%= c.customer_name.replace(/'/g, "\\'") %>?')">
                    <button type="submit" class="btn-delete">🗑</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <script>
    let _custStatus = 'all';
    function filterCustomers(status) {
      _custStatus = status;
      applyCustomerFilter();
      ['all','renting','reservation','bought','done'].forEach(s => {
        const btn = document.getElementById('cf-'+s);
        if (!btn) return;
        btn.style.background = s === status ? 'var(--ps-blue)' : '';
        btn.style.color = s === status ? '#000' : '';
        btn.style.borderColor = s === status ? 'var(--ps-blue)' : '';
      });
    }
    function searchCustomers(q) { applyCustomerFilter(); }
    function applyCustomerFilter() {
      const q = (document.getElementById('custSearch')?.value || '').toLowerCase().trim();
      document.querySelectorAll('.cust-row').forEach(r => {
        const statusOk = _custStatus === 'all' || r.dataset.status === _custStatus;
        const searchOk = !q || r.dataset.name.includes(q) || r.dataset.game.includes(q);
        r.style.display = (statusOk && searchOk) ? '' : 'none';
      });
    }
    </script>
      </div></div></div><!-- /accordion customers-table -->

  </div><!-- /tab-customers -->

  <!-- ═══════════════ VISITORS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-visitors">
    <%
      const vNow = new Date();
      const vTodayStr = vNow.toISOString().slice(0, 10);
      const vWeekAgo  = new Date(vNow - 7 * 86400000).toISOString().slice(0, 10);
      const vMonthAgo = new Date(vNow - 30 * 86400000).toISOString().slice(0, 10);

      const visToday = visitors.filter(v => v.date === vTodayStr);
      const visWeek  = visitors.filter(v => v.date >= vWeekAgo);
      const visMonth = visitors.filter(v => v.date >= vMonthAgo);

      const uniqueToday = new Set(visToday.map(v => v.ip)).size;
      const uniqueWeek  = new Set(visWeek.map(v => v.ip)).size;
      const uniqueMonth = new Set(visMonth.map(v => v.ip)).size;
      const uniqueAll   = new Set(visitors.map(v => v.ip)).size;

      // topPages removed — per-period top pages computed below

      const vLast7 = [];
      for (let i = 6; i >= 0; i--) {
        const vd = new Date(vNow - i * 86400000);
        const vds = vd.toISOString().slice(0, 10);
        const vlabel = vd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        vLast7.push({ date: vds, label: vlabel, count: visitors.filter(v => v.date === vds).length });
      }
      const vMaxBar = Math.max(...vLast7.map(d => d.count), 1);

      const recentVisitors = [...visitors].reverse().slice(0, 100);

      // Page counts per period (computed here, filtered in JS)
      const vPageToday = {}; visToday.forEach(v => { vPageToday[v.page||v.path] = (vPageToday[v.page||v.path]||0)+1; });
      const vPageWeek  = {}; visWeek.forEach(v  => { vPageWeek[v.page||v.path]  = (vPageWeek[v.page||v.path] ||0)+1; });
      const vPageMonth = {}; visMonth.forEach(v => { vPageMonth[v.page||v.path] = (vPageMonth[v.page||v.path]||0)+1; });
      const vPageAll   = {}; visitors.forEach(v => { vPageAll[v.page||v.path]   = (vPageAll[v.page||v.path]  ||0)+1; });
      const topPagesToday = Object.entries(vPageToday).sort((a,b)=>b[1]-a[1]).slice(0,5);
      const topPagesWeek  = Object.entries(vPageWeek).sort((a,b)=>b[1]-a[1]).slice(0,5);
      const topPagesMonth = Object.entries(vPageMonth).sort((a,b)=>b[1]-a[1]).slice(0,5);
      const topPagesAll   = Object.entries(vPageAll).sort((a,b)=>b[1]-a[1]).slice(0,5);
    %>

    <!-- KPI Cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin-bottom:2rem;">
      <div class="stat-card">
        <div class="stat-card-label">Today's Visits</div>
        <div class="stat-card-num" style="color:#22c55e;"><%= visToday.length %></div>
        <div class="stat-card-sub"><%= uniqueToday %> unique visitor<%= uniqueToday!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">Last 7 Days</div>
        <div class="stat-card-num" style="color:#60a5fa;"><%= visWeek.length %></div>
        <div class="stat-card-sub"><%= uniqueWeek %> unique visitor<%= uniqueWeek!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">Last 30 Days</div>
        <div class="stat-card-num" style="color:#a78bfa;"><%= visMonth.length %></div>
        <div class="stat-card-sub"><%= uniqueMonth %> unique visitor<%= uniqueMonth!==1?'s':'' %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label">All-Time Visits</div>
        <div class="stat-card-num" style="color:#ffc400;"><%= visitors.length %></div>
        <div class="stat-card-sub"><%= uniqueAll %> unique visitor<%= uniqueAll!==1?'s':'' %></div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:2rem;">

      <!-- Last 7 Days Bar Chart -->
      <div class="table-card" style="border-color:rgba(96,165,250,0.2);">
        <h2 style="border-color:rgba(96,165,250,0.1);margin-bottom:1.25rem;">📈 Visits — Last 7 Days</h2>
        <div style="display:flex;align-items:flex-end;gap:0.4rem;height:120px;">
          <% vLast7.forEach(day => { %>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.3rem;height:100%;">
            <div style="font-size:0.65rem;color:#555;"><%= day.count %></div>
            <div style="width:100%;background:rgba(96,165,250,0.15);border-radius:4px 4px 0 0;border-top:2px solid #60a5fa;height:<%= day.count > 0 ? Math.round((day.count/vMaxBar)*85) : 2 %>px;min-height:2px;"></div>
            <div style="font-size:0.6rem;color:#555;text-align:center;line-height:1.2;"><%= day.label %></div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Top Pages -->
      <div class="table-card" style="border-color:rgba(167,139,250,0.2);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
          <h2 style="border:none;margin:0;padding:0;">🔗 Most Visited Pages <span style="font-size:0.7rem;color:#555;">(Top 5)</span></h2>
          <div style="display:flex;gap:0.35rem;">
            <button onclick="setTopFilter('today')" id="tpBtn-today" class="vis-filter-btn vis-filter-active" style="font-size:0.7rem;padding:0.25rem 0.6rem;">Today</button>
            <button onclick="setTopFilter('week')"  id="tpBtn-week"  class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">Weekly</button>
            <button onclick="setTopFilter('month')" id="tpBtn-month" class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">Monthly</button>
            <button onclick="setTopFilter('all')"   id="tpBtn-all"   class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">All</button>
          </div>
        </div>
        <div id="topPagesBody"><!-- filled by JS --></div>
      </div>
    </div>

    <!-- Recent Visits Table -->
    <div class="table-card" style="border-color:rgba(34,197,94,0.15);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.5rem;">
        <h2 style="border:none;margin:0;padding:0;">🕐 Recent Visits</h2>
        <div style="display:flex;gap:0.35rem;">
          <button onclick="setVisFilter('today')" id="rvBtn-today" class="vis-filter-btn vis-filter-active" style="font-size:0.7rem;padding:0.25rem 0.6rem;">Today</button>
          <button onclick="setVisFilter('week')"  id="rvBtn-week"  class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">Weekly</button>
          <button onclick="setVisFilter('month')" id="rvBtn-month" class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">Monthly</button>
          <button onclick="setVisFilter('all')"   id="rvBtn-all"   class="vis-filter-btn"                  style="font-size:0.7rem;padding:0.25rem 0.6rem;">All</button>
        </div>
      </div>
      <% if (recentVisitors.length === 0) { %>
        <div style="padding:2rem;text-align:center;color:#555;">No visits recorded yet. Share your website link to get visitors!</div>
      <% } else { %>
      <div style="max-height:420px;overflow-y:auto;border-radius:8px;">
      <table class="games-table" style="width:100%;">
        <thead>
          <tr>
            <th>Page</th>
            <th>Date</th>
            <th>Time</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody id="recentVisitsBody">
          <% recentVisitors.forEach(v => { %>
          <tr data-date="<%= v.date %>">
            <td><span style="color:#22c55e;font-weight:600;"><%= v.page || v.path %></span></td>
            <td style="color:#aaa;font-size:0.8rem;"><%= v.date %></td>
            <td style="color:#aaa;font-size:0.8rem;"><%= v.time ? new Date(v.time).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit'}) : '' %></td>
            <td style="color:#555;font-size:0.75rem;font-family:monospace;"><%= v.ip ? v.ip.replace(/^::ffff:/, '').slice(0,15) : '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
      <% } %>
    </div>

    <script>
    // Top pages data from server
    const TP_DATA = {
      today: <%- JSON.stringify(topPagesToday) %>,
      week:  <%- JSON.stringify(topPagesWeek) %>,
      month: <%- JSON.stringify(topPagesMonth) %>,
      all:   <%- JSON.stringify(topPagesAll) %>
    };

    function renderTopPages(pages) {
      const body = document.getElementById('topPagesBody');
      if (!pages || pages.length === 0) {
        body.innerHTML = '<div style="color:#555;font-size:0.85rem;">No visits for this period.</div>';
        return;
      }
      const maxCount = pages[0][1];
      body.innerHTML = pages.map(([page, count]) =>
        `<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.6rem;">
          <div style="flex:1;font-size:0.82rem;color:#ccc;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${page}</div>
          <div style="font-size:0.75rem;color:#a78bfa;font-weight:700;">${count}</div>
          <div style="width:60px;height:6px;background:#1a1a1a;border-radius:3px;overflow:hidden;">
            <div style="height:100%;background:#a78bfa;border-radius:3px;width:${Math.round((count/maxCount)*100)}%;"></div>
          </div>
        </div>`
      ).join('');
    }

    let tpFilter = 'today';
    function setTopFilter(f) {
      tpFilter = f;
      ['today','week','month','all'].forEach(k => {
        document.getElementById('tpBtn-'+k).classList.toggle('vis-filter-active', k === f);
      });
      renderTopPages(TP_DATA[f]);
    }
    renderTopPages(TP_DATA['today']);

    // Recent Visits filter
    const vTodayStr = '<%= new Date().toISOString().slice(0,10) %>';
    const vWeekAgo  = '<%= new Date(Date.now()-7*86400000).toISOString().slice(0,10) %>';
    const vMonthAgo = '<%= new Date(Date.now()-30*86400000).toISOString().slice(0,10) %>';

    let rvFilter = 'today';
    function setVisFilter(f) {
      rvFilter = f;
      ['today','week','month','all'].forEach(k => {
        document.getElementById('rvBtn-'+k).classList.toggle('vis-filter-active', k === f);
      });
      const rows = document.querySelectorAll('#recentVisitsBody tr');
      rows.forEach(row => {
        const d = row.dataset.date || '';
        let show = true;
        if (f === 'today') show = d === vTodayStr;
        else if (f === 'week')  show = d >= vWeekAgo;
        else if (f === 'month') show = d >= vMonthAgo;
        row.style.display = show ? '' : 'none';
      });
    }
    setVisFilter('today');
    </script>
  </div><!-- /tab-visitors -->

  <!-- ═══════════════ SECURITY TAB ═══════════════ -->
  <div class="tab-panel" id="tab-security">
    <div class="form-card" style="border-color:rgba(255,50,50,0.2);background:linear-gradient(135deg,#1a0a0a,#1a1a1a);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;">🔒 Change Admin Password</h2>
      <form method="POST" action="/admin/change-password">
        <div class="form-grid">
          <div class="form-group"><label>Current Password</label><input type="password" name="current_password" placeholder="Current password" required></div>
          <div class="form-group"><label>New Password</label><input type="password" name="new_password" placeholder="New password (min 4 chars)" required></div>
          <div class="form-group"><label>Confirm New Password</label><input type="password" name="confirm_password" placeholder="Repeat new password" required></div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn" style="background:#c0392b;color:#fff;font-weight:700;padding:0.75rem 1.75rem;border-radius:50px;border:none;cursor:pointer;">Change Password</button>
        </div>
      </form>
    </div>
  </div><!-- /tab-security -->

</div><!-- /admin-container -->

<!-- LOADING OVERLAY -->
<div id="loadingOverlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);flex-direction:column;align-items:center;justify-content:center;gap:1.25rem;">
  <div style="width:52px;height:52px;border:4px solid #222;border-top-color:var(--ps-blue);border-radius:50%;animation:spin 0.7s linear infinite;"></div>
  <div id="loadingText" style="color:#fff;font-weight:700;font-size:1rem;letter-spacing:0.5px;">Saving changes...</div>
</div>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<script>
// ── Tab system ──
const TAB_KEY = 'adminTab';
const tabs = ['settings','announcements','games','customers','psplus','security','visitors'];

function toggleAccordion(header) {
  const body = header.nextElementSibling;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  header.classList.toggle('open', !isOpen);
}
// alias for old class names still used in Games/Customers tabs
window.toggleAccordion = toggleAccordion;

function switchTab(name) {
  tabs.forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('active', t===name);
    document.querySelector('[data-tab='+t+']').classList.toggle('active', t===name);
  });
  localStorage.setItem(TAB_KEY, name);
  history.replaceState({}, '', '/admin' + (name !== 'settings' ? '?tab='+name : ''));
}

// Determine initial tab: URL param > msg-based auto-switch > localStorage > default
(function() {
  const params = new URLSearchParams(window.location.search);
  const msg = params.get('msg');
  const urlTab = params.get('tab');

  // Auto-switch to relevant tab after a form save
  const msgTabMap = {
    added:'games', updated:'games', deleted:'games',
    upcoming_added:'games', upcoming_updated:'games', upcoming_deleted:'games',
    cat_added:'games', cat_updated:'games', cat_deleted:'games',
    announcement:'announcements',
    psplus_added:'psplus', psplus_updated:'psplus', psplus_deleted:'psplus',
    psplus_prices:'psplus', popular_added:'psplus', popular_updated:'psplus', popular_deleted:'psplus',
    customer_added:'customers', customer_updated:'customers', customer_deleted:'customers',
    settings_saved:'settings', password_changed:'security',
    wrong_password:'security', password_mismatch:'security', password_too_short:'security'
  };

  const initial = urlTab || (msg && msgTabMap[msg]) || localStorage.getItem(TAB_KEY) || 'settings';
  switchTab(initial);

  // Toast notifications
  if (msg) {
    const messages = { added:'✅ Game added!', updated:'✅ Game updated!', deleted:'🗑 Game deleted!', announcement:'📢 Announcement saved!', upcoming_added:'🔜 Upcoming game added!', upcoming_updated:'✅ Upcoming game updated!', upcoming_deleted:'🗑 Upcoming game deleted!', game_released:'🚀 Game released to Available Games!', psplus_added:'⭐ Monthly entry added!', psplus_updated:'✅ Monthly entry updated!', psplus_deleted:'🗑 Monthly entry deleted!', psplus_prices:'💰 PS Plus prices saved!', popular_added:'🔥 Game added to Most Played!', popular_updated:'✅ Most Played game updated!', popular_deleted:'🗑 Game removed from Most Played!', settings_saved:'⚙️ Settings saved!', password_changed:'🔒 Password changed!', wrong_password:'❌ Current password is wrong!', password_mismatch:'❌ Passwords do not match!', password_too_short:'❌ Password must be at least 4 characters!', cat_added:'🏷️ Category created!', cat_updated:'🏷️ Category updated!', cat_deleted:'🗑 Category deleted!', customer_added:'👤 Customer added!', customer_updated:'✅ Customer updated!', customer_deleted:'🗑 Customer deleted!' };
    const text = messages[msg];
    if (text) {
      const toast = document.createElement('div');
      toast.className = 'toast success';
      toast.textContent = text;
      document.body.appendChild(toast);
      setTimeout(() => toast.classList.add('show'), 100);
      setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 400); }, 3000);
      history.replaceState({}, '', '/admin?tab=' + (msgTabMap[msg] || initial));
    }
  }
})();

// ── Loading overlay ──
(function() {
  const overlay = document.getElementById('loadingOverlay');
  const loadingText = document.getElementById('loadingText');
  const messages = { '/admin/announcement':'📢 Saving announcement...', '/admin/announcements':'📢 Saving announcement...', '/admin/site-settings':'⚙️ Saving settings...', '/admin/hero-text':'✏️ Saving hero text...', '/admin/change-password':'🔒 Changing password...', '/admin/psplus/prices':'💰 Saving PS Plus prices...', '/admin/add':'🎮 Adding game...', '/admin/upcoming/add':'🔜 Adding upcoming game...', '/admin/psplus/add':'⭐ Adding PS Plus entry...', '/admin/psplus/popular/add':'🔥 Adding Most Played game...', '/admin/price-categories':'🏷️ Saving category...' };
  document.addEventListener('submit', function(e) {
    if (e.target.dataset.noLoading) return;
    const action = e.target.action || '';
    const label = Object.keys(messages).find(k => action.includes(k));
    loadingText.textContent = label ? messages[label] : 'Saving changes...';
    overlay.style.display = 'flex';
  });
})();
</script>

</body>
</html>
