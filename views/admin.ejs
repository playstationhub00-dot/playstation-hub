<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel — <%= settings.title %></title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .admin-tabs { display:flex; gap:0.25rem; background:#0a0a0a; border:1px solid #1a1a1a; border-radius:14px; padding:0.35rem; margin-bottom:1.75rem; flex-wrap:wrap; }
    .admin-tab { flex:1; min-width:90px; text-align:center; padding:0.6rem 0.75rem; border-radius:10px; font-size:0.82rem; font-weight:700; cursor:pointer; color:#555; border:none; background:none; transition:all 0.18s; letter-spacing:0.3px; white-space:nowrap; }
    .admin-tab:hover { color:#aaa; background:#111; }
    .admin-tab.active { background:var(--ps-blue); color:#000; box-shadow:0 2px 12px rgba(240,165,0,0.3); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .add-choice-overlay { display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.7);backdrop-filter:blur(6px);align-items:center;justify-content:center; }
    .add-choice-overlay.open { display:flex; }
    .add-choice-box { background:#111;border:1px solid #222;border-radius:20px;padding:2rem;width:min(480px,92vw);animation:popIn 0.18s ease; }
    @keyframes popIn { from{transform:scale(0.93);opacity:0} to{transform:scale(1);opacity:1} }
    .add-choice-grid { display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-top:1.25rem; }
    .add-choice-card { background:#0a0a0a;border:1px solid #222;border-radius:14px;padding:1.25rem 0.75rem;text-align:center;cursor:pointer;transition:all 0.15s;text-decoration:none;display:flex;flex-direction:column;align-items:center;gap:0.5rem; }
    .add-choice-card:hover { border-color:var(--ps-blue);background:#1a1500;transform:translateY(-2px); }
    .add-choice-card .icon { font-size:2rem;line-height:1; }
    .add-choice-card .label { font-weight:700;font-size:0.82rem;color:#fff; }
    .add-choice-card .desc { font-size:0.7rem;color:#555;line-height:1.4; }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
    <a href="/admin/logout" style="background:#222;color:#aaa;border:1px solid #333;border-radius:8px;padding:0.45rem 0.9rem;font-size:0.8rem;font-weight:600;text-decoration:none;margin-left:0.5rem;">🔒 Logout</a>
  </div>
</nav>

<div class="admin-container">
  <div class="admin-header">
    <h1>🎮 Admin Panel</h1>
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <div id="mongoIndicator" style="display:flex;align-items:center;gap:0.45rem;background:#111;border:1px solid #222;border-radius:20px;padding:0.35rem 0.85rem;font-size:0.78rem;font-weight:600;color:#555;">
        <span id="mongoDot" style="width:8px;height:8px;border-radius:50%;background:#333;display:inline-block;"></span>
        <span id="mongoLabel">Checking DB…</span>
      </div>
      <button id="themeToggle" onclick="toggleTheme()" title="Toggle light/dark mode"
        style="background:#111;border:1px solid #222;border-radius:20px;padding:0.35rem 0.85rem;font-size:0.82rem;font-weight:600;color:#aaa;cursor:pointer;display:flex;align-items:center;gap:0.4rem;">
        <span id="themeIcon">☀️</span><span id="themeLabel">Light</span>
      </button>
      <a href="/" class="btn btn-outline" style="font-size:0.875rem;padding:0.5rem 1rem;">← View Site</a>
    </div>
  </div>
  <script>
  // Theme toggle
  (function() {
    const saved = localStorage.getItem('adminTheme');
    if (saved === 'light') applyLight();
  })();
  function applyLight() {
    document.body.classList.add('light-mode');
    const btn = document.getElementById('themeToggle');
    if (btn) { btn.style.background='#f0f2f5'; btn.style.borderColor='#ddd'; btn.style.color='#333'; }
    const icon = document.getElementById('themeIcon'), lbl = document.getElementById('themeLabel');
    if (icon) icon.textContent = '🌙';
    if (lbl) lbl.textContent = 'Dark';
  }
  function applyDark() {
    document.body.classList.remove('light-mode');
    const btn = document.getElementById('themeToggle');
    if (btn) { btn.style.background='#111'; btn.style.borderColor='#222'; btn.style.color='#aaa'; }
    const icon = document.getElementById('themeIcon'), lbl = document.getElementById('themeLabel');
    if (icon) icon.textContent = '☀️';
    if (lbl) lbl.textContent = 'Light';
  }
  function toggleTheme() {
    if (document.body.classList.contains('light-mode')) {
      applyDark(); localStorage.setItem('adminTheme', 'dark');
    } else {
      applyLight(); localStorage.setItem('adminTheme', 'light');
    }
  }
  fetch('/admin/mongo-status').then(r=>r.json()).then(d=>{
    const dot=document.getElementById('mongoDot'),label=document.getElementById('mongoLabel'),wrap=document.getElementById('mongoIndicator');
    if(d.status&&d.status.includes('✅')){dot.style.background='#22c55e';dot.style.boxShadow='0 0 6px #22c55e';label.textContent='MongoDB Connected';label.style.color='#22c55e';wrap.style.borderColor='#14532d';}
    else if(d.status&&d.status.includes('no MONGODB_URI')){dot.style.background='#f59e0b';label.textContent='No MONGODB_URI';label.style.color='#f59e0b';wrap.style.borderColor='#78350f';}
    else{dot.style.background='#ef4444';dot.style.boxShadow='0 0 6px #ef4444';label.textContent='DB Disconnected';label.style.color='#ef4444';wrap.style.borderColor='#7f1d1d';}
  }).catch(()=>{ document.getElementById('mongoLabel').textContent='DB Unknown'; });
  </script>

  <!-- TAB BAR -->
  <div class="admin-tabs" id="adminTabs">
    <button class="admin-tab" data-tab="settings" onclick="switchTab('settings')">⚙️ Settings</button>
    <button class="admin-tab" data-tab="announcements" onclick="switchTab('announcements')">📢 Announcements</button>
    <button class="admin-tab" data-tab="games" onclick="switchTab('games')">🎮 Games</button>
    <button class="admin-tab" data-tab="customers" onclick="switchTab('customers')">👥 Customers</button>
    <a class="admin-tab" href="/admin/accounts" style="text-decoration:none;line-height:1.2;">🗂️ Accounts</a>
    <button class="admin-tab" data-tab="psplus" onclick="switchTab('psplus')">⭐ PS Plus</button>
    <button class="admin-tab" data-tab="visitors" onclick="switchTab('visitors')">👁️ Visitors</button>
    <button class="admin-tab" data-tab="security" onclick="switchTab('security')">🔒 Security</button>
  </div>

  <!-- ═══════════════ SETTINGS TAB ═══════════════ -->
  <div class="tab-panel" id="tab-settings">

    <style>
    .settings-accordion { border:1px solid #222; border-radius:14px; overflow:hidden; margin-bottom:0.75rem; }
    .settings-accordion-header { display:flex; align-items:center; justify-content:space-between; padding:0.85rem 1.25rem; cursor:pointer; user-select:none; background:#111; transition:background 0.15s; border-left:3px solid #333; }
    .settings-accordion-header:hover { background:#161616; }
    .settings-accordion-header .sa-left { display:flex; align-items:center; gap:0.75rem; }
    .settings-accordion-header .sa-icon { font-size:1rem; width:30px; height:30px; border-radius:7px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .settings-accordion-header .sa-title { font-weight:700; font-size:0.9rem; color:#fff; line-height:1.2; }
    .settings-accordion-header .sa-desc { font-size:0.72rem; color:#555; margin-top:0.1rem; }
    .settings-accordion-header .sa-arrow { color:#555; font-size:0.8rem; transition:transform 0.2s; flex-shrink:0; }
    .settings-accordion-header.open .sa-arrow { transform:rotate(180deg); }
    .settings-accordion-body { display:none; background:#0a0a0a; border-top:1px solid #1a1a1a; }
    .settings-accordion-body.open { display:block; }
    .settings-accordion-body > .form-card,
    .settings-accordion-body > .table-card { border:none !important; border-radius:0 !important; margin:0 !important; box-shadow:none !important; }
    .settings-accordion-body > div > .form-card,
    .settings-accordion-body > div > .table-card { border:none !important; border-radius:0 !important; margin:0 !important; box-shadow:none !important; }
    </style>

    <!-- SITE SETTINGS -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #f0a500;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(240,165,0,0.15);">⚙️</div>
          <div>
            <div class="sa-title">Site Settings</div>
            <div class="sa-desc">Website title, logo, favicon & hero background</div>
          </div>
        </div>
        <span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div style="border-color:rgba(240,165,0,0.4);background:linear-gradient(135deg,#1a1500 0%,#1a1a0a 100%);">
      <h2 style="display:flex;align-items:center;gap:0.5rem;display:none;">⚙️ Site Settings</h2>
      <form method="POST" action="/admin/site-settings" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group full">
            <label>Website Title <span style="color:#555;font-size:0.75rem;">(shown in browser tab and nav)</span></label>
            <input type="text" name="title" value="<%= settings.title %>" placeholder="e.g. Playstation Hub" required>
          </div>
          <div class="form-group full">
            <label>Logo Image <span style="color:#555;font-size:0.75rem;">(PNG, JPG or SVG — blank keeps current)</span></label>
            <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:0.75rem;">
              <img src="<%= settings.logo_path %>" alt="Current logo" style="height:44px;width:auto;background:#000;border-radius:8px;padding:6px 10px;">
              <span style="color:#555;font-size:0.8rem;">Current logo</span>
            </div>
            <input type="file" name="logo" accept="image/*,.svg" style="padding:0.5rem;">
          </div>
          <div class="form-group full">
            <label>Favicon <span style="color:#555;font-size:0.75rem;">(small icon in browser tab — PNG, ICO or SVG)</span></label>
            <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:0.75rem;">
              <img src="<%= settings.favicon_path %>" alt="Current favicon" style="width:32px;height:32px;background:#000;border-radius:6px;padding:4px;">
              <span style="color:#555;font-size:0.8rem;">Current favicon</span>
            </div>
            <input type="file" name="favicon" accept="image/*,.svg,.ico" style="padding:0.5rem;">
          </div>

          <!-- Hero Background -->
          <div class="form-group full" style="margin-top:0.5rem;">
            <label>Home Page Hero Background</label>
            <div style="display:flex;gap:0.75rem;margin:0.65rem 0 1rem;flex-wrap:wrap;" id="heroBgOptions">
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='default') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="default" <%= settings.hero_bg.type==='default' ? 'checked' : '' %> onchange="heroTypeChange(this)"> Default Gradient
              </label>
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='image') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="image" <%= settings.hero_bg.type==='image' ? 'checked' : '' %> onchange="heroTypeChange(this)"> 🖼 Image
              </label>
              <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;background:#1a1a1a;border:1px solid <%= (settings.hero_bg.type==='video') ? 'var(--ps-blue)' : '#333' %>;border-radius:10px;padding:0.6rem 1rem;font-size:0.875rem;font-weight:600;">
                <input type="radio" name="hero_bg_type" value="video" <%= settings.hero_bg.type==='video' ? 'checked' : '' %> onchange="heroTypeChange(this)"> 🎬 Video Loop
              </label>
            </div>
            <div id="heroBgUpload" style="display:<%= settings.hero_bg.type!=='default' ? 'block' : 'none' %>;">
              <% if (settings.hero_bg.path) { %>
              <div style="margin-bottom:0.75rem;display:flex;align-items:center;gap:0.75rem;">
                <% if (settings.hero_bg.type==='video') { %>
                  <video src="<%= settings.hero_bg.path %>" style="height:60px;border-radius:6px;" muted></video>
                <% } else { %>
                  <img src="<%= settings.hero_bg.path %>" style="height:60px;border-radius:6px;object-fit:cover;width:100px;">
                <% } %>
                <span style="color:#555;font-size:0.8rem;">Current background</span>
              </div>
              <% } %>
              <label style="color:#aaa;font-size:0.82rem;display:block;margin-bottom:0.4rem;">Upload new file <span style="color:#555;">(blank = keep current)</span></label>
              <input type="file" name="hero_bg_file" accept="image/*,video/mp4,video/webm" style="padding:0.5rem;">
              <div style="margin-top:0.5rem;font-size:0.78rem;color:#555;">Supported: JPG, PNG, WEBP for image · MP4, WEBM for video loop</div>
              <div style="margin-top:1.25rem;">
                <label style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                  <span style="color:#aaa;font-size:0.82rem;font-weight:600;">🌑 Background Darkness (overlay)</span>
                  <span id="overlayVal" style="color:var(--ps-blue);font-weight:700;font-size:0.9rem;"><%= settings.hero_bg.overlay || 50 %>%</span>
                </label>
                <input type="range" name="hero_bg_overlay" id="overlaySlider" min="0" max="100" value="<%= settings.hero_bg.overlay || 50 %>"
                  oninput="document.getElementById('overlayVal').textContent=this.value+'%'"
                  style="width:100%;accent-color:var(--ps-blue);cursor:pointer;height:6px;">
                <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:#555;margin-top:0.3rem;">
                  <span>0% — fully visible</span><span>100% — fully dark</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn btn-primary" style="background:var(--ps-blue);">Save Settings</button>
        </div>
      </form>

      <script>
      function heroTypeChange(el) {
        document.getElementById('heroBgUpload').style.display = el.value === 'default' ? 'none' : 'block';
        document.querySelectorAll('#heroBgOptions label').forEach(l => {
          l.style.borderColor = l.querySelector('input').checked ? 'var(--ps-blue)' : '#333';
        });
      }
      </script>
    </div><!-- /site-settings inner -->
      </div><!-- /accordion-body -->
    </div><!-- /accordion site-settings -->

    <!-- HERO SLIDES MANAGER -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #a855f7;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(168,85,247,0.15);">🖼</div>
          <div>
            <div class="sa-title">Hero Promo Slider</div>
            <div class="sa-desc">Upload promo banners shown as a slideshow on the homepage</div>
          </div>
        </div>
        <span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div style="border-color:rgba(240,165,0,0.5);background:linear-gradient(135deg,#0d0d00,#1a1a0a);">
      <h2 style="display:none;">🖼 Hero Promo Slideshow</h2>
      <p style="color:#888;font-size:0.85rem;margin:0 0 1.25rem;">Upload promo posters. They replace the homepage hero with an auto-sliding carousel (auto-advances every 5 seconds). Remove all slides to restore the text hero.</p>

      <!-- Current slides -->
      <% if (settings.hero_slides && settings.hero_slides.length > 0) { %>
      <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
        <% settings.hero_slides.forEach((sl, i) => { %>
        <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:10px;padding:0.75rem;display:flex;flex-direction:column;align-items:center;gap:0.5rem;width:160px;">
          <img src="<%= sl.path %>" style="width:100%;height:100px;object-fit:cover;border-radius:6px;">
          <% if (sl.caption) { %>
          <div style="font-size:0.72rem;color:#aaa;text-align:center;word-break:break-word;"><%= sl.caption %></div>
          <% } %>
          <form method="POST" action="/admin/hero-slides/delete" onsubmit="return confirm('Delete this slide?');" style="width:100%;">
            <input type="hidden" name="index" value="<%= i %>">
            <button type="submit" style="width:100%;background:#c0392b;border:none;color:#fff;border-radius:6px;padding:0.35rem;cursor:pointer;font-size:0.78rem;">🗑 Delete</button>
          </form>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div style="color:#666;font-size:0.85rem;margin-bottom:1.25rem;padding:0.75rem;background:#111;border-radius:8px;border:1px dashed #333;">No slides yet — upload your first promo poster below to activate the slideshow.</div>
      <% } %>

      <!-- Upload new slide -->
      <form method="POST" action="/admin/hero-slides/upload" enctype="multipart/form-data" style="display:flex;flex-direction:column;gap:0.75rem;max-width:480px;">
        <label style="color:#aaa;font-size:0.82rem;font-weight:600;">Add New Slide</label>
        <input type="file" name="slide_image" accept="image/*" required style="padding:0.5rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;">
        <input type="text" name="caption" placeholder="Caption (optional — shown at bottom of slide)" style="padding:0.6rem 0.9rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;font-size:0.875rem;">
        <input type="text" name="link" placeholder="Link when tapped (optional, e.g. /browse)" style="padding:0.6rem 0.9rem;background:#1a1a1a;border:1px solid #333;border-radius:8px;color:#fff;font-size:0.875rem;">
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" style="background:var(--ps-blue);">Upload Slide</button>
        </div>
      </form>
    </div><!-- /hero-slides inner -->
      </div><!-- /accordion-body -->
    </div><!-- /accordion hero-slides -->

    <!-- PROMO SETTINGS -->
    <%
      const adminPromo = settings.promo || { enabled: true, discount_pct: 10, apply_on_days: 30, deposit: 100 };
    %>
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #22c55e;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(34,197,94,0.15);">🎉</div>
          <div>
            <div class="sa-title">Promo & Pricing Rules</div>
            <div class="sa-desc">Discount %, rental duration rules & security deposit</div>
          </div>
        </div>
        <span class="sa-arrow">▼</span>
      </div>
      <div class="settings-accordion-body">
    <div style="border-color:rgba(34,197,94,0.3);background:linear-gradient(135deg,#041008,#071a0a);">
      <h2 style="display:none;">🎉 Promo & Pricing Rules</h2>
      <form method="POST" action="/admin/promo">
        <div class="form-grid">
          <!-- RENT PROMO -->
          <div class="form-group full" style="margin-bottom:0;">
            <label style="color:#22c55e;font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">⏱️ Rent Promo</label>
          </div>
          <div class="form-group full">
            <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;">
              <input type="checkbox" name="enabled" <%= adminPromo.enabled ? 'checked' : '' %> style="width:18px;height:18px;accent-color:#22c55e;">
              <span>Enable Rent Promo Discount</span>
            </label>
          </div>
          <div class="form-group">
            <label>Rent Discount % <span style="color:#555;font-size:0.75rem;">(applied when promo is active)</span></label>
            <input type="number" name="discount_pct" value="<%= adminPromo.discount_pct %>" min="0" max="100" placeholder="10">
          </div>
          <div class="form-group">
            <label>Apply on Duration (days) <span style="color:#555;font-size:0.75rem;">(e.g. 30 = 30-day rentals get the discount)</span></label>
            <input type="number" name="apply_on_days" value="<%= adminPromo.apply_on_days %>" min="1" placeholder="30">
          </div>
          <div class="form-group">
            <label>Trophy Account Security Deposit (₱) <span style="color:#555;font-size:0.75rem;">(refundable, added to Trophy rentals)</span></label>
            <input type="number" name="deposit" value="<%= adminPromo.deposit %>" min="0" placeholder="100">
          </div>

          <!-- BUY PROMO -->
          <div class="form-group full" style="margin-top:0.5rem;padding-top:1rem;border-top:1px solid #1a1a1a;margin-bottom:0;">
            <label style="color:#a855f7;font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">♾️ Buy Permanent Promo</label>
          </div>
          <div class="form-group full">
            <label style="display:flex;align-items:center;gap:0.75rem;cursor:pointer;">
              <input type="checkbox" name="buy_promo_enabled" <%= adminPromo.buy_promo_enabled ? 'checked' : '' %> style="width:18px;height:18px;accent-color:#a855f7;">
              <span>Enable Buy Promo Discount</span>
            </label>
          </div>
          <div class="form-group">
            <label>Buy Discount % <span style="color:#555;font-size:0.75rem;">(applied to permanent access price)</span></label>
            <input type="number" name="buy_promo_pct" value="<%= adminPromo.buy_promo_pct || 0 %>" min="0" max="100" placeholder="0">
          </div>
        </div>
        <div class="form-actions" style="margin-top:0.75rem;">
          <button type="submit" class="btn btn-primary" style="background:#22c55e;color:#000;">Save Promo Settings</button>
        </div>
      </form>
    </div><!-- /promo inner -->
      </div><!-- /accordion-body -->
    </div><!-- /accordion promo -->

    <!-- HERO TEXT EDITOR -->
    <div class="settings-accordion">
      <div class="settings-accordion-header" onclick="toggleAccordion(this)" style="border-left:3px solid #60a5fa;">
        <div class="sa-left">
          <div class="sa-icon" style="background:rgba(96,165,250,0.15);">✏️</div>
          <div>
            <div class="sa-title">Home Page Hero Text</div>
