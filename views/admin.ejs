          <div class="form-group full"><label>Cover Image <span style="color:#555;font-size:0.75rem;">(monthly PS Plus banner screenshot)</span></label><input type="file" name="cover_image" accept="image/*" style="padding:0.5rem;"></div>
          <div class="form-group full"><label>Games List <span style="color:#555;font-size:0.75rem;">(one game per line)</span></label><textarea name="games_list" rows="6" placeholder="Suicide Squad: Kill the Justice League&#10;The Stanley Parable: Ultra Deluxe&#10;Hitman World of Assassination"></textarea></div>
          <div class="form-group"><label>🎮 Non-Trophy Slots</label><input type="number" name="nt_slots" value="0" min="0" placeholder="0"></div>
          <div class="form-group"><label>🏆 Trophy Slots</label><input type="number" name="tr_slots" value="0" min="0" placeholder="0"></div>
          <div class="form-group full"><label>Notes (optional)</label><textarea name="notes" rows="2" placeholder="e.g. Available on PS4 and PS5"></textarea></div>
