          <div style="background:#111;border:1px solid <%= r.visible ? '#2a2a2a' : '#3a1a1a' %>;border-radius:10px;padding:1rem;display:flex;align-items:flex-start;gap:1rem;opacity:<%= r.visible ? '1' : '0.5' %>;">
            <div style="flex:1;">
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.4rem;flex-wrap:wrap;">
                <strong style="color:#fff;"><%= r.name %></strong>
                <span style="color:#f59e0b;font-size:0.85rem;"><%= '⭐'.repeat(r.rating) %></span>
                <% if (r.game_rented) { %><span style="font-size:0.75rem;color:#888;background:#1a1a1a;padding:0.15rem 0.5rem;border-radius:20px;">🎮 <%= r.game_rented %></span><% } %>
                <% if (!r.visible) { %><span style="font-size:0.7rem;color:#ef4444;background:#2a0000;padding:0.15rem 0.5rem;border-radius:20px;">Hidden</span><% } %>
              </div>
              <div style="color:#ccc;font-size:0.88rem;line-height:1.5;">"<%= r.text %>"</div>
            </div>
            <div style="display:flex;flex-direction:column;gap:0.4rem;flex-shrink:0;">
              <form method="POST" action="/admin/reviews/toggle/<%= r.id %>"><button type="submit" style="background:<%= r.visible ? '#1a2a1a' : '#2a1a00' %>;color:<%= r.visible ? '#4ade80' : '#f59e0b' %>;border:1px solid <%= r.visible ? '#2a4a2a' : '#4a3a00' %>;border-radius:6px;padding:0.3rem 0.75rem;font-size:0.75rem;cursor:pointer;white-space:nowrap;"><%= r.visible ? '👁 Hide' : '👁 Show' %></button></form>
              <form method="POST" action="/admin/reviews/delete/<%= r.id %>" onsubmit="return confirm('Delete this review?')"><button type="submit" style="background:#2a0000;color:#ef4444;border:1px solid #4a0000;border-radius:6px;padding:0.3rem 0.75rem;font-size:0.75rem;cursor:pointer;">🗑 Delete</button></form>
