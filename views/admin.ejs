    <div class="table-card" style="border-color:rgba(255,215,0,0.2);">
      <h2 style="border-color:rgba(255,215,0,0.15);">⭐ PS Plus Monthly Entries (<%= psplus.length %>)</h2>
      <% if (psplus.length === 0) { %>
        <div style="padding:2rem;text-align:center;color:var(--text-secondary);">No entries yet. Add one above!</div>
