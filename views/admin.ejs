            <div class="form-group" style="margin:0;"><label>Game Rented</label><input type="text" name="game_rented" placeholder="e.g. GTA V"></div>
            <div class="form-group" style="margin:0;"><label>Rating (1–5 ⭐)</label><select name="rating"><option value="5">⭐⭐⭐⭐⭐ 5</option><option value="4">⭐⭐⭐⭐ 4</option><option value="3">⭐⭐⭐ 3</option><option value="2">⭐⭐ 2</option><option value="1">⭐ 1</option></select></div>
