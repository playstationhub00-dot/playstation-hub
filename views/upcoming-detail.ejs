<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= game.title %> — Coming Soon — Playstation Hub</title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="facebook-domain-verification" content="noj6ccmsehjq0v2oeq2e716fgyaqq0" />
</head>
<body>
<%- include('partials/announcement') %>
<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
  </div>
</nav>

<%
  const hasNt = !!(game.nt_price_10d || game.nt_price_15d || game.nt_price_30d);
  const hasTr = !!(game.tr_price_10d || game.tr_price_15d || game.tr_price_30d) && (game.trophy_slots || 0) >= 0;
  const showTr = hasTr;

  const ntPrices = { 10: game.nt_price_10d||0, 15: game.nt_price_15d||0, 30: game.nt_price_30d||0 };
  const trPrices = { 10: game.tr_price_10d||0, 15: game.tr_price_15d||0, 30: game.tr_price_30d||0 };

  let displayDate = 'TBA';
  if (game.release_date && game.release_date !== 'TBA') {
    const d = new Date(game.release_date + 'T00:00:00');
    displayDate = d.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
  }
%>

<div class="gd-page">
  <div class="gd-back"><a href="/browse">← Back to Catalog</a></div>

  <div class="gd-layout">

    <!-- LEFT: Cover -->
    <div class="gd-cover-col">
      <% if (game.cover_image) { %>
        <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="gd-cover" style="filter:brightness(0.8);">
      <% } else { %>
        <div class="gd-cover gd-cover-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:64px;height:64px;opacity:0.3;">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
      <% } %>
    </div>

    <!-- RIGHT: Info -->
    <div class="gd-info-col">

      <!-- Genre + Platform -->
      <% if (game.genre) { %><div class="gd-genre-tag"><%= game.genre.toUpperCase() %></div><% } %>
      <h1 class="gd-title"><%= game.title %></h1>
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
        <span style="background:#1a1a2e;border:1px solid #2a2a4a;color:var(--ps-blue);font-size:0.78rem;font-weight:700;padding:0.2rem 0.6rem;border-radius:6px;"><%= game.platform %></span>
        <span style="background:linear-gradient(135deg,rgba(74,0,128,0.3),rgba(241,7,163,0.2));border:1px solid #5a2a8a;border-radius:8px;padding:0.2rem 0.65rem;font-size:0.78rem;color:#a855f7;font-weight:700;">🔜 COMING SOON</span>
        <span style="font-size:0.82rem;color:#888;">📅 Expected: <strong style="color:<%= displayDate === 'TBA' ? '#666' : '#aaa' %>;"><%= displayDate %></strong></span>
      </div>

      <!-- Coming soon banner -->
      <div class="gd-noslot-banner" style="margin-bottom:1.5rem;">
        <span class="gd-noslot-icon">🔜</span>
        <div>
          <div class="gd-noslot-title">Not Yet Available — Open for Reservation</div>
          <div class="gd-noslot-sub">This game is coming soon. Reserve your slot now and be first in line when it drops!</div>
        </div>
      </div>

      <%
        const ntSlots = game.non_trophy_slots || 0;
        const trSlots = game.trophy_slots || 0;
        const totalSlots = ntSlots + trSlots;
        const allFull = totalSlots === 0;
      %>

      <!-- FULL banner when no slots -->
      <% if (allFull) { %>
      <div style="display:flex;align-items:center;gap:0.75rem;background:linear-gradient(135deg,#1a0a0a,#2a0a0a);border:1px solid rgba(239,68,68,0.3);border-radius:12px;padding:1rem 1.2rem;margin-bottom:1.5rem;">
        <span style="font-size:1.5rem;">🚫</span>
        <div>
          <div style="font-weight:800;color:#ef4444;font-size:0.95rem;">All Slots Full</div>
          <div style="font-size:0.78rem;color:#888;margin-top:0.15rem;">No reservation slots available right now. You can still request a slot or join the waitlist below.</div>
        </div>
      </div>
      <% } %>

      <!-- SELECT RENTAL TYPE -->
      <% if ((hasNt || showTr) && !allFull) { %>
      <div class="gd-section-label">SELECT RENTAL TYPE</div>
      <div class="gd-type-options" id="typeOptions">

        <% if (showTr) { %>
        <label class="gd-type-card" id="typeCard-tr">
          <input type="radio" name="rental_type" value="tr" id="type-tr" onchange="onTypeChange()" <%= (!hasNt) ? 'checked' : '' %>>
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🏆</span>
              <span class="gd-type-name">Trophy</span>
              <% if (trSlots > 0) { %>
                <span class="gd-type-status gd-status-avail"><%= trSlots %> slot<%= trSlots !== 1 ? 's' : '' %> available</span>
              <% } else { %>
                <span class="gd-type-status gd-status-rented">Reserved</span>
              <% } %>
            </div>
            <div class="gd-type-desc">Perfect for trophy hunters. Play through games at your own pace and earn trophies on your own main account.</div>
          </div>
        </label>
        <% } %>

        <% if (hasNt) { %>
        <label class="gd-type-card" id="typeCard-nt">
          <input type="radio" name="rental_type" value="nt" id="type-nt" onchange="onTypeChange()" checked>
          <div class="gd-type-body">
            <div class="gd-type-header">
              <span class="gd-type-icon">🎮</span>
              <span class="gd-type-name">Non-Trophy</span>
              <% if (ntSlots > 0) { %>
                <span class="gd-type-status gd-status-avail"><%= ntSlots %> slot<%= ntSlots !== 1 ? 's' : '' %> available</span>
              <% } else { %>
                <span class="gd-type-status gd-status-rented">Reserved</span>
              <% } %>
            </div>
            <div class="gd-type-desc">Ideal for casual players focused on the story and experience, without the need for account-linked achievements.</div>
          </div>
        </label>
        <% } %>

      </div>
      <% } %>

      <!-- SELECT DURATION (hidden when no slots) -->
      <% if (!allFull) { %>
      <div class="gd-section-label" style="margin-top:1.5rem;">SELECT DURATION</div>
      <div class="gd-duration-grid" id="durGrid"></div>
      <% } %>

      <!-- ORDER SUMMARY (hidden when no slots) -->
      <% if (!allFull) { %>
      <div class="gd-total-box" id="orderSummary" style="display:none;">
        <div class="gd-total-label">ORDER SUMMARY</div>
        <div class="gd-total-rows">
          <div class="gd-total-row"><span id="sumBaseLabel">Base</span><span id="sumBase">—</span></div>
          <div class="gd-total-row" id="sumDepositRow" style="display:none;"><span>🔒 Security Deposit (refundable)</span><span style="color:#f59e0b;">+₱100</span></div>
          <div class="gd-total-row" style="color:#22c55e;font-weight:700;"><span>⬇️ 50% Downpayment</span><span id="sumDownpayment">—</span></div>
        </div>
        <div class="gd-total-final"><span>Total</span><span id="sumTotal" style="color:#ffc400;">—</span></div>
      </div>
      <% } %>

      <!-- CHOOSE YOUR OPTION -->
      <div class="gd-section-label" style="margin-top:1.5rem;">CHOOSE YOUR OPTION</div>

      <!-- Slots available: Reserve Now only -->
      <div id="ctaHasSlot" style="display:none;">
        <div style="background:linear-gradient(135deg,#0a1a0a,#0d2a0d);border:1px solid #1a4a1a;border-radius:14px;padding:1.5rem;text-align:center;">
          <div style="font-size:1.5rem;margin-bottom:0.35rem;">⭐</div>
          <div style="font-weight:800;font-size:1.05rem;color:#fff;margin-bottom:0.25rem;">Reserve a Slot</div>
          <div style="font-size:0.82rem;color:#f59e0b;font-weight:700;margin-bottom:0.5rem;">Downpayment upon approval</div>
          <div style="font-size:0.78rem;color:#888;margin-bottom:1rem;">Reserve your slot now. Downpayment details will be sent to you upon approval.</div>
          <a id="reserveLinkSlot" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
             onclick="return handleReserveClick(event,'reserve')"
             style="display:inline-block;background:linear-gradient(135deg,#065f46,#22c55e);color:#fff;font-weight:800;padding:0.75rem 2rem;border-radius:50px;text-decoration:none;font-size:0.92rem;">
            📘 Reserve Now →
          </a>
        </div>
      </div>

      <!-- No slots: Request a Slot + Fall in Line -->
      <div id="ctaNoSlot" style="display:<%= allFull ? '' : 'none' %>;">
        <div class="gd-reserve-options">
          <a id="reserveLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
             class="gd-reserve-card gd-reserve-priority" onclick="return handleReserveClick(event,'reserve')">
            <div class="gd-reserve-badge">PRIORITY</div>
            <div class="gd-reserve-icon">⭐</div>
            <div class="gd-reserve-name">Request a Slot</div>
            <div class="gd-reserve-fee" id="reserveSlotFee">50% Downpayment</div>
            <div class="gd-reserve-note">Pay 50% of the total to lock in your slot when it becomes available.</div>
            <div class="gd-reserve-cta">📘 Request Now →</div>
          </a>
          <a id="queueLink" href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
             class="gd-reserve-card gd-reserve-queue" onclick="return handleReserveClick(event,'queue')">
            <div class="gd-reserve-icon">🎮</div>
            <div class="gd-reserve-name">Fall in Line</div>
            <div class="gd-reserve-fee" style="color:#22c55e;">FREE</div>
            <div class="gd-reserve-note">Join the waitlist at no cost. You'll be notified when a slot opens.</div>
            <div class="gd-reserve-cta">📘 Join Waitlist →</div>
          </a>
        </div>
      </div>

    </div><!-- /gd-info-col -->
  </div><!-- /gd-layout -->
</div><!-- /gd-page -->

<%- include('partials/footer') %>

<script>
const GAME_TITLE = '<%= game.title.replace(/'/g, "\\'").replace(/"/g, "&quot;") %>';
const NT_PRICES  = { 10: <%= game.nt_price_10d||0 %>, 15: <%= game.nt_price_15d||0 %>, 30: <%= game.nt_price_30d||0 %> };
const TR_PRICES  = { 10: <%= game.tr_price_10d||0 %>, 15: <%= game.tr_price_15d||0 %>, 30: <%= game.tr_price_30d||0 %> };
const NT_SLOTS   = <%= game.non_trophy_slots||0 %>;
const TR_SLOTS   = <%= game.trophy_slots||0 %>;

let selectedType = document.querySelector('input[name="rental_type"]:checked')?.value || 'nt';
let selectedDays = null;

function getPrices() { return selectedType === 'tr' ? TR_PRICES : NT_PRICES; }
function getSlots()  { return selectedType === 'tr' ? TR_SLOTS  : NT_SLOTS; }

function onTypeChange() {
  selectedType = document.querySelector('input[name="rental_type"]:checked')?.value || 'nt';
  selectedDays = null;
  // highlight selected card
  document.querySelectorAll('.gd-type-card').forEach(c => c.classList.remove('gd-type-selected'));
  const checked = document.querySelector('input[name="rental_type"]:checked');
  if (checked) checked.closest('.gd-type-card').classList.add('gd-type-selected');
  renderDurButtons();
  updateSummary();
  updateCta();
}

function renderDurButtons() {
  const p = getPrices();
  const grid = document.getElementById('durGrid');
  grid.innerHTML = '';
  [10, 15, 30].forEach(d => {
    if (!p[d]) return; // skip days with no price
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'gd-dur-btn';
    btn.dataset.days = d;
    btn.onclick = () => selectDur(d);
    btn.innerHTML = `<span class="gd-dur-days">${d}</span><span class="gd-dur-label">DAYS</span><span class="gd-dur-price">₱${p[d]}</span>`;
    grid.appendChild(btn);
  });
}

function selectDur(days) {
  selectedDays = days;
  document.querySelectorAll('.gd-dur-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.days) === days));
  updateSummary();
  updateCta();
  updateLinks();
}

function updateSummary() {
  const summary = document.getElementById('orderSummary');
  if (!selectedDays) { summary.style.display = 'none'; return; }
  const price     = getPrices()[selectedDays] || 0;
  const isTrophy  = selectedType === 'tr';
  const deposit   = isTrophy ? 100 : 0;
  const total     = price + deposit;

  const downpay = Math.ceil(total * 0.5);
  document.getElementById('sumBaseLabel').textContent    = 'Base (' + selectedDays + ' days)';
  document.getElementById('sumBase').textContent         = price ? '₱' + price : '—';
  document.getElementById('sumDepositRow').style.display = isTrophy ? '' : 'none';
  document.getElementById('sumDownpayment').textContent  = total ? '₱' + downpay : '—';
  document.getElementById('sumTotal').textContent        = total ? '₱' + total : '—';
  summary.style.display = '';
}

function updateCta() {
  const hasSlot = getSlots() > 0;
  document.getElementById('ctaHasSlot').style.display = hasSlot ? '' : 'none';
  document.getElementById('ctaNoSlot').style.display  = hasSlot ? 'none' : '';
}

function updateLinks() {
  if (!selectedDays) return;
  const typeName = selectedType === 'tr' ? 'Trophy' : 'Non-Trophy';
  const price    = getPrices()[selectedDays] || 0;
  const deposit  = selectedType === 'tr' ? 100 : 0;
  const total    = price + deposit;
  const downpay2 = total ? Math.ceil(total * 0.5) : 0;
  const priceStr = total ? '₱' + total : 'TBD';
  const dpStr    = downpay2 ? '₱' + downpay2 : 'TBD';
  // Update the fee label on the card
  const feeEl = document.getElementById('reserveSlotFee');
  if (feeEl) feeEl.textContent = downpay2 ? '50% Downpayment — ₱' + downpay2 : '50% Downpayment';
  const hasSlot  = getSlots() > 0;

  if (hasSlot) {
    const msg = encodeURIComponent(
      'Hi! I want to RESERVE a slot for:\n' +
      'Game: ' + GAME_TITLE + ' (Coming Soon)\n' +
      'Type: ' + typeName + '\n' +
      'Duration: ' + selectedDays + ' Days\n' +
      'Total: ' + priceStr + '\n' +
      '50% Downpayment: ' + dpStr
    );
    const el = document.getElementById('reserveLinkSlot');
    if (el) el.href = 'http://m.me/PlaystationHub00?text=' + msg;
  } else {
    const reserveMsg = encodeURIComponent(
      'Hi! I want to REQUEST a slot for:\n' +
      'Game: ' + GAME_TITLE + ' (Coming Soon)\n' +
      'Type: ' + typeName + '\n' +
      'Duration: ' + selectedDays + ' Days\n' +
      'Total: ' + priceStr + '\n' +
      '(₱100 reservation fee applies)'
    );
    const queueMsg = encodeURIComponent(
      'Hi! I want to JOIN THE WAITLIST for:\n' +
      'Game: ' + GAME_TITLE + ' (Coming Soon)\n' +
      'Type: ' + typeName + '\n' +
      'Duration: ' + selectedDays + ' Days\n' +
      'Total: ' + priceStr
    );
    const rl = document.getElementById('reserveLink');
    const ql = document.getElementById('queueLink');
    if (rl) rl.href = 'http://m.me/PlaystationHub00?text=' + reserveMsg;
    if (ql) ql.href = 'http://m.me/PlaystationHub00?text=' + queueMsg;
  }
}

const ALL_FULL = <%= allFull ? 'true' : 'false' %>;

function handleReserveClick(e, mode) {
  if (!ALL_FULL && !selectedDays) {
    e.preventDefault();
    const grid = document.getElementById('durGrid');
    grid.classList.remove('gd-dur-grid-shake');
    void grid.offsetWidth;
    grid.classList.add('gd-dur-grid-shake');
    setTimeout(() => grid.classList.remove('gd-dur-grid-shake'), 600);
    return false;
  }
  return true;
}

// Init
const initChecked = document.querySelector('input[name="rental_type"]:checked');
if (initChecked) initChecked.closest('.gd-type-card').classList.add('gd-type-selected');
renderDurButtons();
updateCta();
</script>
</body>
</html>
