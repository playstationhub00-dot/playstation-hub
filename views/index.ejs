<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Playstation Hub — PS5/PS4 Game Rentals</title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="facebook-domain-verification" content="noj6ccmsehjq0v2oeq2e716fgyaqq0" />
</head>
<body>

<%- include('partials/announcement') %>
<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
  </div>
</nav>

<section class="hero<%= settings.hero_bg.type !== 'default' ? ' hero-custom-bg' : '' %>">
  <% if (settings.hero_bg.type === 'image' && settings.hero_bg.path) { %>
    <div class="hero-bg-media" style="background-image:url('<%= settings.hero_bg.path %>');background-size:cover;background-position:center;"></div>
    <div class="hero-bg-overlay" style="opacity:<%= (settings.hero_bg.overlay || 50) / 100 %>;"></div>
  <% } else if (settings.hero_bg.type === 'video' && settings.hero_bg.path) { %>
    <video class="hero-bg-media" autoplay muted loop playsinline>
      <source src="<%= settings.hero_bg.path %>">
    </video>
    <div class="hero-bg-overlay" style="opacity:<%= (settings.hero_bg.overlay || 50) / 100 %>;"></div>
  <% } %>
  <div class="hero-content">
    <% const ht = settings.hero_text; %>
    <h1 style="font-size:<%= ht.title_size %>px;">
      <%= ht.line1 %><% if (ht.line1 && ht.line2) { %><br><% } %><span style="color:<%= ht.highlight_color %>;"><%= ht.highlight %></span><% if (ht.line2) { %> <%= ht.line2 %><% } %>
    </h1>
    <p style="color:<%= ht.subtitle_color %>;"><%= ht.subtitle %></p>
    <div class="hero-actions">
      <a href="/browse" class="btn btn-primary">Browse All Games</a>
      <a href="#how" class="btn btn-outline">How It Works</a>
    </div>
  </div>
</section>

<div class="stats-bar">
  <div class="stat">
    <div class="stat-num"><%= games.length %>+</div>
    <div class="stat-label">Games Available</div>
  </div>
  <div class="stat">
    <% const allPrices = games.flatMap(g => [g.nt_price_10d, g.nt_price_15d, g.nt_price_30d, g.tr_price_10d, g.tr_price_15d, g.tr_price_30d].filter(Boolean)); const lowestPrice = allPrices.length ? Math.min(...allPrices) : 99; %>
    <div class="stat-num">₱<%= lowestPrice %></div>
    <div class="stat-label">Starting Price</div>
  </div>
  <div class="stat">
    <% const totalRenters = games.reduce((sum, g) => sum + (g.renters || 0), 0); %>
    <div class="stat-num"><%= totalRenters %>+</div>
    <div class="stat-label">Active Renters</div>
  </div>
  <div class="stat">
    <div class="stat-num">3</div>
    <div class="stat-label">Rental Durations</div>
  </div>
  <div class="stat">
    <div class="stat-num">100%</div>
    <div class="stat-label">Digital Games</div>
  </div>
</div>

<!-- MOST POPULAR SLIDER -->
<div class="section">
  <h2 class="section-title">Most Popular</h2>
  <div class="upcoming-slider-wrap">
    <button class="slider-arrow slider-arrow-left" onclick="slideSection('popularSlider',-1)" aria-label="Previous">&#8249;</button>
    <div class="upcoming-slider" id="popularSlider">
      <% featured.forEach(game => { %><div style="min-width:240px;max-width:240px;flex-shrink:0;scroll-snap-align:start;"><%- include('partials/game-card', { game }) %></div><% }) %>
    </div>
    <button class="slider-arrow slider-arrow-right" onclick="slideSection('popularSlider',1)" aria-label="Next">&#8250;</button>
  </div>
</div>

<!-- MOST PLAYED IN PS PLUS SLIDER -->
<% if (psplusPopular.length > 0) { %>
<div class="section" style="border-top:1px solid #1a1a1a;padding-top:3rem;">
  <h2 class="section-title">
    <span style="background:linear-gradient(135deg,#FFD700,#ffa500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">★</span>
    Most Played in PS Plus
    <a href="/ps-plus" style="font-size:0.8rem;font-weight:500;color:var(--ps-blue);text-decoration:none;margin-left:0.5rem;">View All →</a>
  </h2>
  <div class="upcoming-slider-wrap">
    <button class="slider-arrow slider-arrow-left" onclick="slideSection('psplusSlider',-1)" aria-label="Previous">&#8249;</button>
    <div class="upcoming-slider" id="psplusSlider">
    <% psplusPopular.forEach((game, idx) => { %>
    <%
      const popData = JSON.stringify({
        cover: game.cover_image||'',
        title: game.title,
        platform: game.platform||'',
        genre: game.genre||'',
        description: game.description||'',
        rank: game.rank || idx + 1
      }).replace(/'/g,"&#39;");
    %>
    <div style="min-width:240px;max-width:240px;flex-shrink:0;scroll-snap-align:start;">
    <div class="game-card psplus-popular-card" onclick="openPopularModal('<%= popData.replace(/"/g,'&quot;') %>')" style="cursor:pointer;">
      <div style="position:relative;">
        <% if (game.cover_image) { %>
          <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="game-cover">
        <% } else { %>
          <div class="game-cover-placeholder" style="background:linear-gradient(135deg,#0a0800,#1a1400);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <span>No Image</span>
          </div>
        <% } %>
        <div class="psplus-popular-rank">#<%= game.rank || idx + 1 %></div>
      </div>
      <div class="game-info">
        <div class="game-platform"><%= game.platform %></div>
        <div class="game-title"><%= game.title %></div>
        <% if (game.genre) { %><div style="font-size:0.75rem;color:#555;"><%= game.genre %></div><% } %>
        <% if (game.description) { %><div class="game-desc-inline"><%= game.description %></div><% } %>
        <div style="margin-top:auto;padding-top:0.75rem;">
          <button class="rent-btn" style="background:linear-gradient(135deg,#856200,#FFD700);color:#000;font-weight:800;width:100%;border:none;cursor:pointer;">
            📘 Rent via PS Plus
          </button>
        </div>
      </div>
    </div>
    </div>
    <% }) %>
    </div>
    <button class="slider-arrow slider-arrow-right" onclick="slideSection('psplusSlider',1)" aria-label="Next">&#8250;</button>
  </div>
</div>
<% } %>

<!-- UPCOMING GAMES -->
<%- include('partials/upcoming-section', { upcoming: upcoming.slice(0, 10), noBorderTop: false }) %>

<!-- ALL GAMES SLIDER -->
<div class="section" style="border-top:1px solid #1a1a1a;padding-top:3rem;">
  <h2 class="section-title">All Games <a href="/browse" style="font-size:0.8rem;font-weight:500;color:var(--ps-blue);text-decoration:none;margin-left:0.5rem;">View All →</a></h2>
  <div class="upcoming-slider-wrap">
    <button class="slider-arrow slider-arrow-left" onclick="slideSection('allGamesSlider',-1)" aria-label="Previous">&#8249;</button>
    <div class="upcoming-slider" id="allGamesSlider">
      <% games.slice(0, 10).forEach(game => { %><div style="min-width:240px;max-width:240px;flex-shrink:0;scroll-snap-align:start;"><%- include('partials/game-card', { game }) %></div><% }) %>
    </div>
    <button class="slider-arrow slider-arrow-right" onclick="slideSection('allGamesSlider',1)" aria-label="Next">&#8250;</button>
  </div>
</div>

<section class="how-section" id="how">
  <div class="how-inner">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Browse & Pick</h3>
        <p>Choose from our PS5 and PS4 digital game library.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Choose Duration</h3>
        <p>Pick 10, 15, or 30 days — flexible pricing to fit your schedule.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Get Access</h3>
        <p>We'll set up your digital access within 24 hours.</p>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <h3>Play & Return</h3>
        <p>Enjoy the game and the slot is released when your rental ends.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<!-- POPULAR GAME MODAL -->
<div class="modal-overlay" id="popularModal" onclick="if(event.target===this)closePopularModal()">
  <div class="modal" style="max-width:560px;padding:0;overflow:hidden;border-radius:18px;">
    <div style="position:relative;width:100%;background:#0a0a0a;">
      <img id="popularModalCover" src="" alt="" style="width:100%;max-height:320px;object-fit:cover;display:block;">
      <div id="popularModalCoverPlaceholder" style="display:none;height:120px;background:linear-gradient(135deg,#1a1400,#111);align-items:center;justify-content:center;font-size:2.5rem;">🎮</div>
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,transparent 55%);pointer-events:none;"></div>
      <div style="position:absolute;bottom:1rem;left:1.25rem;right:2.5rem;">
        <div id="popularModalPlatform" style="font-size:0.7rem;font-weight:700;color:#FFD700;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.2rem;"></div>
        <div id="popularModalTitle" style="font-size:1.15rem;font-weight:800;color:#fff;line-height:1.2;"></div>
      </div>
      <button onclick="closePopularModal()" style="position:absolute;top:0.75rem;right:0.9rem;background:rgba(0,0,0,0.5);border:none;color:#fff;border-radius:50%;width:30px;height:30px;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>
    </div>
    <div style="padding:1.25rem 1.5rem 1.5rem;">
      <div id="popularModalDesc" style="font-size:0.83rem;color:#888;line-height:1.6;margin-bottom:1.25rem;display:none;"></div>
      <div style="font-size:0.75rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Rental Pricing</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:1.25rem;">
        <div style="background:#111;border:1px solid #222;border-radius:10px;padding:0.65rem 0.85rem;">
          <div style="font-size:0.7rem;color:#aaa;font-weight:700;margin-bottom:0.4rem;">🎮 Non-Trophy</div>
          <div style="font-size:0.8rem;color:#ddd;">10 Days — <b style="color:#22c55e;">₱<%= psplusPrices.nt_price_10d %></b></div>
          <div style="font-size:0.8rem;color:#ddd;">15 Days — <b style="color:#22c55e;">₱<%= psplusPrices.nt_price_15d %></b></div>
          <div style="font-size:0.8rem;color:#ddd;">30 Days — <b style="color:#22c55e;">₱<%= psplusPrices.nt_price_30d %></b></div>
        </div>
        <div style="background:#111;border:1px solid #222;border-radius:10px;padding:0.65rem 0.85rem;">
          <div style="font-size:0.7rem;color:#ffc400;font-weight:700;margin-bottom:0.4rem;">🏆 Trophy Account</div>
          <div style="font-size:0.8rem;color:#ddd;">10 Days — <b style="color:#ffc400;">₱<%= psplusPrices.tr_price_10d %></b></div>
          <div style="font-size:0.8rem;color:#ddd;">15 Days — <b style="color:#ffc400;">₱<%= psplusPrices.tr_price_15d %></b></div>
          <div style="font-size:0.8rem;color:#ddd;">30 Days — <b style="color:#ffc400;">₱<%= psplusPrices.tr_price_30d %></b></div>
          <div style="font-size:0.72rem;color:#664d00;margin-top:0.3rem;">+₱100 refundable deposit</div>
        </div>
      </div>
      <div style="display:flex;gap:0.75rem;">
        <button onclick="closePopularModal()" class="btn btn-outline" style="flex:1;">Cancel</button>
        <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
          class="btn" style="flex:1;text-align:center;background:#FFD700;color:#000;font-weight:800;border-radius:50px;padding:0.75rem 1.5rem;text-decoration:none;">📘 Message Us</a>
      </div>
    </div>
  </div>
</div>

<!-- RESERVE MODAL -->
<div class="modal-overlay" id="reserveModal">
  <div class="modal">
    <div style="font-size:1.5rem;margin-bottom:0.5rem;">🔔</div>
    <h2>Reserve a Slot</h2>
    <div id="reserveGameTitle" style="font-weight:700;font-size:1rem;color:#a855f7;margin:0.5rem 0 1rem;"></div>
    <div style="background:#111;border:1px solid #222;border-radius:10px;padding:1rem;margin-bottom:1.25rem;text-align:left;">
      <div style="font-size:0.82rem;color:#bbb;line-height:1.7;margin-bottom:0.75rem;">
        This game is not yet available but you can <strong style="color:#fff;">reserve your slot now</strong>. Message us on Facebook to lock in your reservation!
      </div>
      <div style="font-size:0.78rem;color:var(--ps-blue);font-weight:700;margin-bottom:0.25rem;">📘 Message us on Facebook:</div>
      <div style="font-size:0.8rem;color:#888;">Include the game name and your preferred rental duration.</div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeReserveModal()" style="flex:1;">Cancel</button>
      <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
        class="btn" style="flex:1;text-align:center;background:linear-gradient(135deg,#4a0080,#7b2ff7);color:#fff;font-weight:700;border-radius:50px;padding:0.75rem 1.75rem;text-decoration:none;"
        onclick="closeReserveModal()">📘 Message Us</a>
    </div>
  </div>
</div>

<%- include('partials/rent-modal') %>

<script>
function slideSection(id, dir) {
  const slider = document.getElementById(id);
  if (!slider) return;
  const card = slider.querySelector('[style*="min-width"]') || slider.querySelector('.game-card');
  const cardW = card ? card.offsetWidth + 20 : 260;
  slider.scrollBy({ left: dir * cardW * 2, behavior: 'smooth' });
}

function openPopularModal(dataStr) {
  const d = JSON.parse(dataStr.replace(/&quot;/g, '"').replace(/&#39;/g, "'"));
  const cover = document.getElementById('popularModalCover');
  const placeholder = document.getElementById('popularModalCoverPlaceholder');
  if (d.cover) { cover.src = d.cover; cover.style.display = 'block'; placeholder.style.display = 'none'; }
  else { cover.style.display = 'none'; placeholder.style.display = 'flex'; }
  document.getElementById('popularModalPlatform').textContent = d.platform + (d.genre ? '  ·  ' + d.genre : '');
  document.getElementById('popularModalTitle').textContent = d.title;
  const descEl = document.getElementById('popularModalDesc');
  if (d.description) { descEl.textContent = d.description; descEl.style.display = ''; }
  else descEl.style.display = 'none';
  document.getElementById('popularModal').classList.add('active');
}
function closePopularModal() { document.getElementById('popularModal').classList.remove('active'); }

function openReserveModal(title) {
  document.getElementById('reserveGameTitle').textContent = title;
  document.getElementById('reserveModal').classList.add('active');
}
function closeReserveModal() { document.getElementById('reserveModal').classList.remove('active'); }
document.getElementById('reserveModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeReserveModal(); });

function openRentModal(title, nt10, nt15, nt30, tr10, tr15, tr30, hasTrophy, hasNt) {
  document.getElementById('modalGameTitle').textContent = title;
  document.getElementById('modalNtP10').textContent = '₱' + nt10;
  document.getElementById('modalNtP15').textContent = '₱' + nt15;
  document.getElementById('modalNtP30').textContent = '₱' + nt30;
  document.getElementById('modalTrP10').textContent = '₱' + tr10;
  document.getElementById('modalTrP15').textContent = '₱' + tr15;
  document.getElementById('modalTrP30').textContent = '₱' + tr30;
  document.getElementById('modalNtSection').style.display = hasNt ? 'block' : 'none';
  document.getElementById('modalTrophySection').style.display = hasTrophy ? 'block' : 'none';
  document.getElementById('rentModal').classList.add('active');
}
function closeRentModal() { document.getElementById('rentModal').classList.remove('active'); }
document.getElementById('rentModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeRentModal(); });
</script>
</body>
</html>




