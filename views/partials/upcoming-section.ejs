<% if (upcoming.length > 0) { %>
<div class="section" data-upcoming="1" style="<%= typeof noBorderTop !== 'undefined' && noBorderTop ? '' : 'border-top:1px solid #1a1a1a;' %>padding-bottom:0;">
  <h2 class="section-title" style="color:#fff;">
    <span style="display:inline-flex;align-items:center;gap:0.5rem;">
      <span style="background:linear-gradient(135deg,#7b2ff7,#f107a3);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-size:1.1em;">🔜</span>
      Coming Soon
    </span>
    <span style="font-size:0.8rem;font-weight:500;color:#666;margin-left:0.5rem;">Open for Reservation</span>
  </h2>
  <div class="upcoming-slider-wrap">
    <button class="slider-arrow slider-arrow-left" onclick="slideUpcoming(-1)" aria-label="Previous">&#8249;</button>
    <div class="upcoming-slider" id="upcomingSlider">
    <% upcoming.forEach(game => { %>
    <a href="/upcoming/<%= game.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') %>-<%= game.id %>" class="game-card upcoming-card game-card-link" data-title="<%= game.title.toLowerCase() %>" data-genre="<%= (game.genre||'').toLowerCase() %>">
      <div style="position:relative;overflow:visible;">
        <% if (game.cover_image) { %>
          <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="game-cover" style="filter:brightness(0.75);">
        <% } else { %>
          <div class="game-cover-placeholder" style="background:linear-gradient(135deg,#0d0015,#1a0030);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
            <span>No Image</span>
          </div>
        <% } %>
        <div class="upcoming-overlay-badge">COMING SOON</div>
        <% if (game.rank) { %>
        <div style="position:absolute;top:-14px;right:8px;background:linear-gradient(135deg,#ff4500,#ff8c00);color:#fff;font-size:0.65rem;font-weight:900;padding:0.25rem 0.6rem;border-radius:20px;letter-spacing:0.5px;box-shadow:0 2px 10px rgba(255,69,0,0.6);z-index:10;">🔥 HOT #<%= game.rank %></div>
        <% } %>
      </div>
      <div class="game-info">
        <div class="game-platform"><%= game.platform %></div>
        <div class="game-title"><%= game.title %></div>
        <% if (game.genre) { %><div style="font-size:0.75rem;color:#555;"><%= game.genre %></div><% } %>
        <%
          let displayDate = 'TBA';
          if (game.release_date && game.release_date !== 'TBA') {
            const d = new Date(game.release_date + 'T00:00:00');
            displayDate = d.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
          }
        %>
        <div style="font-size:0.78rem;color:#888;margin-top:0.25rem;">
          📅 Expected: <strong style="color:<%= displayDate === 'TBA' ? '#666' : '#aaa' %>;"><%= displayDate %></strong>
        </div>
        <span class="rent-btn" style="background:linear-gradient(135deg,#4a0080,#7b2ff7);margin-top:0.75rem;">
          🔔 Reserve Slot
        </span>
      </div>
    </a>
    <% }) %>
    </div>
    <button class="slider-arrow slider-arrow-right" onclick="slideUpcoming(1)" aria-label="Next">&#8250;</button>
  </div>
</div>
<script>
function slideUpcoming(dir) {
  const slider = document.getElementById('upcomingSlider');
  if (!slider) return;
  const card = slider.querySelector('.game-card');
  const cardW = card ? card.offsetWidth + 20 : 280;
  slider.scrollBy({ left: dir * cardW * 2, behavior: 'smooth' });
}
</script>
<% } %>
