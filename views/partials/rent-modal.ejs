            <span id="modalTrP30" style="font-weight:800;color:#ffc400;"></span>
          </div>
        </div>
        <div style="margin-top:0.75rem;background:rgba(255,196,0,0.08);border:1px solid rgba(255,196,0,0.2);border-radius:7px;padding:0.5rem 0.75rem;font-size:0.78rem;color:#ccaa00;line-height:1.5;">
