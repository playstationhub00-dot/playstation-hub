        <div style="font-size:0.75rem;font-weight:700;color:#ffc400;margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.5px;">🏆 Trophy Account — Permanent Access</div>
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <div>
            <div id="modalBuyTrOriginal" style="font-size:0.78rem;color:#664d00;text-decoration:line-through;display:none;margin-bottom:0.1rem;"></div>
            <div id="modalBuyTrPrice" style="font-size:1.6rem;font-weight:900;color:#ffc400;"></div>
