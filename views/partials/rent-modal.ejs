    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeRentModal()" style="flex:1;">Cancel</button>
      <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
        class="btn btn-primary" style="flex:1;text-align:center;" onclick="closeRentModal()">
        📘 Message Us
      </a>
