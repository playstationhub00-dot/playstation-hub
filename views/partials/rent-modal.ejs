    <!-- ── RENT PANEL ── -->
    <div id="modalRentPanel">
      <!-- Non-Trophy prices -->
      <div id="modalNtSection" style="background:#111;border:1px solid #222;border-radius:10px;padding:1rem;margin-bottom:0.75rem;">
