      <div style="background:rgba(34,197,94,0.07);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.85rem 1rem;margin-bottom:1.25rem;text-align:left;">
        <div style="font-size:0.78rem;color:#22c55e;font-weight:700;margin-bottom:0.35rem;">💬 Send us on Facebook to buy:</div>
        <div style="font-size:0.82rem;color:#bbb;line-height:1.6;">Game name &nbsp;·&nbsp; "Buy Permanent" &nbsp;·&nbsp; Trophy or Non-Trophy</div>
      </div>
