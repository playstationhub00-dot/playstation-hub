<%
  const ntSlots  = game.non_trophy_slots || 0;
  const trSlots  = game.trophy_slots || 0;
  const ps4Slots = game.ps4_primary_slots || 0;
  const showPs4  = game.platform === 'PS4' || game.platform === 'PS4/PS5';
  const hasTrophy = !!(game.trophy_account || trSlots > 0);
  const allUnavail = ntSlots <= 0 && trSlots <= 0 && (!showPs4 || ps4Slots <= 0);
  const totalSlots = ntSlots + trSlots + (showPs4 ? ps4Slots : 0);
  const isLastSlot = totalSlots === 1;
  const noSlot = totalSlots === 0;
  const buyNt = game.buy_nt_price || 0;
  const buyTr = game.buy_tr_price || 0;
  const hasBuy = buyNt > 0 || buyTr > 0;
  const gameSlug = game.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const modalArgs = `'${game.title.replace(/'/g,"\\'")}',${game.nt_price_10d||0},${game.nt_price_15d||0},${game.nt_price_30d||0},${game.tr_price_10d||0},${game.tr_price_15d||0},${game.tr_price_30d||0},${hasTrophy?'true':'false'},true,${buyNt},${buyTr}`;
%>
<div class="game-card" style="cursor:default;">

  <!-- Clickable cover → game detail page -->
  <a href="/game/<%= gameSlug %>" class="game-card-link" style="display:block;text-decoration:none;">
    <div class="gc-cover-wrap">
      <% if (game.cover_image) { %>
        <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="game-cover">
      <% } else { %>
        <div class="game-cover-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
          <span>No Image</span>
        </div>
      <% } %>
      <span class="gc-platform-badge"><%= game.platform %></span>
      <% if (isLastSlot) { %>
        <div class="gc-slot-banner gc-slot-banner-last">LAST SLOT!</div>
      <% } else if (noSlot) { %>
        <div class="gc-slot-banner gc-slot-banner-none">NO SLOT</div>
      <% } %>
      <% if (hasBuy) { %>
        <div style="position:absolute;top:6px;left:6px;background:linear-gradient(135deg,#7b2ff7,#f107a3);color:#fff;font-size:0.58rem;font-weight:800;padding:0.18rem 0.45rem;border-radius:20px;letter-spacing:0.3px;">♾️ BUY</div>
      <% } %>
    </div>
  </a>

  <div class="game-info">
    <% if (game.genre) { %><div class="gc-genre"><%= game.genre.toUpperCase() %></div><% } %>
    <a href="/game/<%= gameSlug %>" style="text-decoration:none;color:inherit;"><div class="game-title"><%= game.title %></div></a>

    <!-- Pricing columns side by side -->
    <div class="gc-price-table">

      <!-- Non-Trophy column wrapper -->
      <div class="gc-col-wrap">
        <div class="gc-days-left-spacer">
          <% if (ntSlots <= 0 && game.nt_days_left != null && game.nt_days_left > 0) { %>
          <span class="gc-days-left">🎮 Available in <%= game.nt_days_left %>d</span>
          <% } %>
        </div>
        <div class="gc-col gc-col-nt">
          <div class="gc-col-head">
            <span class="gc-col-icon">🎮</span>
            <span class="gc-col-label">NON-TROPHY</span>
          </div>
          <div class="gc-slot-count">
            <% if (ntSlots > 0) { %>
              <span class="gc-avail gc-avail-yes"><%= ntSlots %> slot<%= ntSlots !== 1 ? 's' : '' %> left</span>
            <% } else { %>
              <span class="gc-avail gc-avail-no">RENTED</span>
            <% } %>
          </div>
          <div class="gc-price-rows">
            <div class="gc-price-row"><span class="gc-dur">10D</span><span class="gc-price">₱<%= game.nt_price_10d %></span></div>
            <div class="gc-price-row"><span class="gc-dur">15D</span><span class="gc-price">₱<%= game.nt_price_15d %></span></div>
            <div class="gc-price-row"><span class="gc-dur">30D</span><span class="gc-price">₱<%= game.nt_price_30d %></span></div>
          </div>
        </div>
      </div>

      <!-- Trophy / PS4 Primary column wrapper -->
      <% if (hasTrophy || showPs4) { %>
      <div class="gc-col-wrap">
        <div class="gc-days-left-spacer">
          <% if (hasTrophy && trSlots <= 0 && game.tr_days_left != null && game.tr_days_left > 0) { %>
          <span class="gc-days-left gc-days-left-tr">🏆 Available in <%= game.tr_days_left %>d</span>
          <% } else if (showPs4 && ps4Slots <= 0 && game.ps4_days_left != null && game.ps4_days_left > 0) { %>
          <span class="gc-days-left gc-days-left-ps4">🕹️ PS4 in <%= game.ps4_days_left %>d</span>
          <% } %>
        </div>
        <div class="gc-col gc-col-tr">
          <div class="gc-col-head">
            <span class="gc-col-icon">🏆</span>
            <span class="gc-col-label">TROPHY</span>
          </div>
          <% if (hasTrophy) { %>
          <div class="gc-slot-count">
            <% if (trSlots > 0) { %>
              <span class="gc-avail gc-avail-tr"><%= trSlots %> slot<%= trSlots !== 1 ? 's' : '' %></span>
            <% } else { %>
              <span class="gc-avail gc-avail-no">RENTED</span>
            <% } %>
          </div>
          <% } %>
          <% if (showPs4) { %>
          <div class="gc-slot-count">
            <span class="gc-slot-type-label">PS4</span>
            <% if (ps4Slots > 0) { %>
              <span class="gc-avail gc-avail-ps4"><%= ps4Slots %> slot<%= ps4Slots !== 1 ? 's' : '' %></span>
            <% } else { %>
              <span class="gc-avail gc-avail-no">RENTED</span>
            <% } %>
          </div>
          <% } %>
          <% if (hasTrophy) { %>
          <div class="gc-price-rows">
            <div class="gc-price-row"><span class="gc-dur">10D</span><span class="gc-price gc-price-tr">₱<%= game.tr_price_10d %></span></div>
            <div class="gc-price-row"><span class="gc-dur">15D</span><span class="gc-price gc-price-tr">₱<%= game.tr_price_15d %></span></div>
            <div class="gc-price-row"><span class="gc-dur">30D</span><span class="gc-price gc-price-tr">₱<%= game.tr_price_30d %></span></div>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

    </div>

    <div class="gc-from-price">
      From ₱<%= game.nt_price_10d || game.tr_price_10d || '—' %>
      <span style="color:#555;font-size:0.75em;"> / 10 days</span>
    </div>

    <!-- Action buttons -->
    <% if (allUnavail) { %>
    <span class="rent-btn rent-btn-reserve" onclick="event.preventDefault();openReserveModal('<%= game.title.replace(/'/g,"\\'") %>')">Reserve a Slot →</span>
    <% } else { %>
    <div style="display:flex;gap:0.4rem;">
      <span class="rent-btn" style="flex:1;text-align:center;" onclick="event.preventDefault();openRentModal(<%= modalArgs %>)">⏱️ Rent</span>
      <% if (hasBuy) { %>
      <span class="rent-btn" style="flex:1;text-align:center;background:linear-gradient(135deg,#7b2ff7,#f107a3);border-color:transparent;" onclick="event.preventDefault();openRentModal(<%= modalArgs %>);setTimeout(()=>switchModalTab('buy'),50)">♾️ Buy</span>
      <% } %>
    </div>
    <% } %>
  </div>
</div>
