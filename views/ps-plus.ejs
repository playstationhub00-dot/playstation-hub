<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PS Plus Deluxe — <%= settings.title %></title>
  <link rel="icon" href="<%= settings.favicon_path %>" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="facebook-domain-verification" content="noj6ccmsehjq0v2oeq2e716fgyaqq0" />
</head>
<body>

<%- include('partials/announcement') %>
<nav>
  <a href="/" class="logo"><img src="<%= settings.logo_path %>" alt="<%= settings.title %>" /></a>
  <div class="nav-links">
    <a href="/browse">Browse Games</a>
    <a href="/ps-plus" class="active">PS Plus Deluxe</a>
    <a href="/how-it-works">How It Works</a>
    <a href="/admin" class="admin-btn">Admin Panel</a>
  </div>
</nav>

<!-- HERO BANNER -->
<section class="psplus-hero">
  <div class="psplus-hero-bg"></div>
  <div class="psplus-hero-content">
    <div class="psplus-logo-row">
      <div class="psplus-ps-icon">
        <svg viewBox="0 0 100 100" fill="none">
          <path d="M50 15 L70 35 L50 35 Z" fill="#FFD700"/>
          <path d="M50 15 L30 35 L50 35 Z" fill="#FFD700" opacity="0.6"/>
          <path d="M35 40 L50 85 L65 40 Z" fill="#FFD700"/>
        </svg>
      </div>
      <div>
        <div class="psplus-eyebrow">Playstation Hub</div>
        <h1 class="psplus-title">PS PLUS <span>DELUXE</span></h1>
        <p class="psplus-subtitle">Monthly Games — Unlimited Access</p>
      </div>
    </div>
    <p class="psplus-desc">Access hundreds of games through our PS Plus Deluxe accounts. Enjoy monthly free games and a massive catalog — Trophy or Non-Trophy, your choice.</p>
    <div class="psplus-hero-actions">
      <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener" class="btn btn-primary" style="background:#FFD700;color:#000;">📘 Message Us to Rent</a>
      <a href="#pricing" class="btn btn-outline">View Pricing ↓</a>
      <a href="https://www.playstation.com/en-id/ps-plus/games/?smcid=store%3Aen-us%3Apages-latest%3Aprimary%20nav%3Amsg-ps-plus%3Aall-games" target="_blank" rel="noopener" class="btn btn-outline">🎮 Browse All PS Plus Games</a>
    </div>
  </div>
</section>

<!-- PRICING TABLE -->
<section id="pricing" class="psplus-pricing-section">
  <div class="psplus-pricing-inner">
    <h2>Pricing</h2>
    <p style="color:var(--text-secondary);font-size:0.9rem;margin-top:0.25rem;">Unlimited game changes, subject to slot availability. Prices may vary.</p>

    <!-- Slot availability card -->
    <%
      const ntS = (slots||{}).nt_slots || 0;
      const trS = (slots||{}).tr_slots || 0;
      const ps4S = (slots||{}).ps4_slots || 0;
    %>
    <div style="background:#111;border:1px solid #222;border-radius:14px;padding:1rem 1.25rem;margin-bottom:3rem;display:inline-block;min-width:260px;">
      <div style="font-size:0.7rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:0.6rem;">PS4/PS5 &nbsp;·&nbsp; PS Plus Deluxe</div>
      <div style="font-size:1rem;font-weight:800;color:#FFD700;margin-bottom:0.75rem;">PS Plus Deluxe</div>
      <div style="display:flex;flex-direction:column;gap:0.35rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:1.5rem;font-size:0.8rem;">
          <span style="color:#aaa;font-weight:600;">🎮 Non-Trophy</span>
          <% if (ntS > 0) { %>
            <span style="color:#22c55e;font-weight:700;">● Available (<%= ntS %>)</span>
          <% } else { %>
            <span style="color:#ef4444;font-weight:600;">● Not Available</span>
          <% } %>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:1.5rem;font-size:0.8rem;">
          <span style="color:#aaa;font-weight:600;">🏆 Trophy Account</span>
          <% if (trS > 0) { %>
            <span style="color:#ffc400;font-weight:700;">● Available (<%= trS %>)</span>
          <% } else { %>
            <span style="color:#ef4444;font-weight:600;">● Not Available</span>
          <% } %>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:1.5rem;font-size:0.8rem;">
          <span style="color:#aaa;font-weight:600;">🕹️ PS4 Primary</span>
          <% if (ps4S > 0) { %>
            <span style="color:#60a5fa;font-weight:700;">● Available (<%= ps4S %>)</span>
          <% } else { %>
            <span style="color:#ef4444;font-weight:600;">● Not Available</span>
          <% } %>
        </div>
      </div>
    </div>
    <div class="psplus-price-grid">
      <!-- Non-Trophy -->
      <div class="psplus-price-card">
        <div class="psplus-price-card-label">🎮 Non-Trophy</div>
        <div class="psplus-price-card-sub">Played on our account</div>
        <div class="psplus-price-rows">
          <div class="psplus-price-row">
            <span class="psplus-price-days">10 Days</span>
            <span class="psplus-price-amount">₱<%= prices.nt_price_10d %></span>
          </div>
          <div class="psplus-price-row">
            <span class="psplus-price-days">15 Days</span>
            <span class="psplus-price-amount">₱<%= prices.nt_price_15d %></span>
          </div>
          <div class="psplus-price-row psplus-price-row-highlight">
            <span class="psplus-price-days">30 Days</span>
            <span class="psplus-price-amount">₱<%= prices.nt_price_30d %></span>
          </div>
        </div>
      </div>
      <!-- Divider -->
      <div class="psplus-price-divider"></div>
      <!-- Trophy -->
      <div class="psplus-price-card psplus-price-card-trophy">
        <div class="psplus-price-card-label" style="color:#FFD700;">🏆 Trophy Account</div>
        <div class="psplus-price-card-sub">Play on your own PSN account</div>
        <div class="psplus-price-rows">
          <div class="psplus-price-row">
            <span class="psplus-price-days" style="color:#886600;">10 Days</span>
            <span class="psplus-price-amount" style="color:#FFD700;">₱<%= prices.tr_price_10d %></span>
          </div>
          <div class="psplus-price-row">
            <span class="psplus-price-days" style="color:#886600;">15 Days</span>
            <span class="psplus-price-amount" style="color:#FFD700;">₱<%= prices.tr_price_15d %></span>
          </div>
          <div class="psplus-price-row psplus-price-row-highlight" style="border-color:rgba(255,215,0,0.2);">
            <span class="psplus-price-days" style="color:#886600;">30 Days</span>
            <span class="psplus-price-amount" style="color:#FFD700;">₱<%= prices.tr_price_30d %></span>
          </div>
        </div>
        <div class="psplus-deposit-note">+₱100 refundable security deposit</div>
      </div>
    </div>
    <div class="psplus-notes">
      <span>📩 PM us for full list of games available</span>
      <span>🔒 ₱100 security deposit for Trophy account</span>
      <span>🔄 Unlimited game changes, subject to slot availability</span>
    </div>
  </div>
</section>

<!-- MOST PLAYED GAMES -->
<% if (popular.length > 0) { %>
<section style="padding:3rem 2rem 2rem;max-width:1400px;margin:0 auto;">
  <h2 class="section-title" style="color:#fff;">
    <span style="display:inline-flex;align-items:center;gap:0.5rem;">
      🔥 Most Played in PS Plus
    </span>
    <span style="font-size:0.8rem;font-weight:500;color:#555;margin-left:0.5rem;">Available in our Deluxe accounts</span>
  </h2>
  <div class="games-grid">
    <% popular.forEach((game, idx) => { %>
    <% const rentTarget = '/game/17'; %>
    <a href="<%= rentTarget %>" class="game-card psplus-popular-card game-card-link">
      <div style="position:relative;">
        <% if (game.cover_image) { %>
          <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="game-cover">
        <% } else { %>
          <div class="game-cover-placeholder" style="background:linear-gradient(135deg,#0a0800,#1a1400);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
            <span>No Image</span>
          </div>
        <% } %>
        <div class="psplus-popular-rank">#<%= game.rank || idx + 1 %></div>
      </div>
      <div class="game-info">
        <div class="game-platform"><%= game.platform %></div>
        <div class="game-title"><%= game.title %></div>
        <% if (game.genre) { %><div style="font-size:0.75rem;color:#555;"><%= game.genre %></div><% } %>
        <span class="rent-btn" style="background:linear-gradient(135deg,#856200,#FFD700);color:#000;font-weight:800;width:100%;border:none;cursor:pointer;text-align:center;">
          📘 Rent via PS Plus
        </span>
      </div>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<!-- MONTHLY GAMES BY YEAR -->
<% if (years.length === 0) { %>
<div style="text-align:center;padding:5rem 2rem;color:var(--text-secondary);">
  <div style="font-size:3rem;margin-bottom:1rem;">🎮</div>
  <p>No monthly games added yet. Check back soon!</p>
</div>
<% } %>

<% years.forEach(year => { %>
<section class="psplus-year-section">
  <div class="psplus-year-inner">
    <div class="psplus-year-header">
      <h2 class="psplus-year-title">
        <span class="psplus-year-badge"><%= year %></span>
        Monthly Games
      </h2>
    </div>
    <div class="psplus-months-grid">
      <% byYear[year].forEach(entry => { %>
      <%
        const ntSlots = entry.nt_slots || 0;
        const trSlots = entry.tr_slots || 0;
        const hasSlots = ntSlots > 0 || trSlots > 0;
        const gamesList = (entry.games_list || '').split('\n').map(g=>g.trim()).filter(Boolean);
        const entryData = JSON.stringify({ cover: entry.cover_image||'', month: entry.month_name, year, games: gamesList, notes: entry.notes||'', ntSlots, trSlots, prices: { nt10: prices.nt_price_10d, nt15: prices.nt_price_15d, nt30: prices.nt_price_30d, tr10: prices.tr_price_10d, tr15: prices.tr_price_15d, tr30: prices.tr_price_30d } }).replace(/'/g,"&#39;");
      %>
      <div class="psplus-month-card" onclick="openPsplusModal('<%= entryData.replace(/"/g, '&quot;') %>')" style="cursor:pointer;">
        <div class="psplus-month-cover-wrap">
          <% if (entry.cover_image) { %>
            <img src="<%= entry.cover_image %>" alt="<%= entry.month_name %> <%= year %>" class="psplus-month-cover">
          <% } else { %>
            <div class="psplus-month-cover-placeholder">
              <div class="psplus-month-placeholder-icon">🎮</div>
              <div style="font-size:0.75rem;color:#555;margin-top:0.25rem;">No Image</div>
            </div>
          <% } %>
          <div class="psplus-month-label"><%= entry.month_name.toUpperCase() %></div>
        </div>
        <div class="psplus-month-info">
          <div class="psplus-month-name"><%= entry.month_name %> <span style="color:#555;"><%= year %></span></div>
          <% if (gamesList.length > 0) { %>
            <div class="psplus-games-list">
              <% gamesList.slice(0,3).forEach(game => { %>
                <div class="psplus-game-item">• <%= game %></div>
              <% }) %>
              <% if (gamesList.length > 3) { %>
                <div class="psplus-game-item" style="color:#555;">+<%= gamesList.length - 3 %> more — tap to see all</div>
              <% } %>
            </div>
          <% } %>
          <% if (entry.notes) { %>
            <div class="psplus-month-notes"><%= entry.notes %></div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>
<% }) %>

<%- include('partials/footer') %>

<!-- PS PLUS MONTHLY DETAIL MODAL -->
<div class="modal-overlay" id="psplusModal" onclick="if(event.target===this)closePsplusModal()">
  <div class="modal" style="max-width:520px;padding:0;overflow:hidden;border-radius:18px;">
    <div id="psplusModalCoverWrap" style="position:relative;width:100%;background:#0a0a0a;">
      <img id="psplusModalCover" src="" alt="" style="width:100%;max-height:220px;object-fit:cover;display:block;">
      <div id="psplusModalCoverPlaceholder" style="display:none;height:140px;background:linear-gradient(135deg,#1a1a00,#111);display:flex;align-items:center;justify-content:center;font-size:3rem;">★</div>
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,transparent 60%);pointer-events:none;"></div>
      <div style="position:absolute;bottom:1rem;left:1.25rem;">
        <div id="psplusModalTitle" style="font-size:1.2rem;font-weight:800;color:#FFD700;"></div>
        <div id="psplusModalSub" style="font-size:0.8rem;color:#aaa;margin-top:0.1rem;">PS Plus Deluxe — Monthly Games</div>
      </div>
      <button onclick="closePsplusModal()" style="position:absolute;top:0.75rem;right:0.9rem;background:rgba(0,0,0,0.5);border:none;color:#fff;border-radius:50%;width:30px;height:30px;font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;">✕</button>
    </div>
    <div style="padding:1.25rem 1.5rem 1.5rem;">
      <!-- Games list -->
      <div style="font-size:0.75rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Included Games</div>
      <div id="psplusModalGames" style="display:flex;flex-direction:column;gap:0.3rem;max-height:220px;overflow-y:auto;margin-bottom:1.25rem;"></div>
      <!-- Pricing -->
      <div style="font-size:0.75rem;font-weight:700;color:#666;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Rental Pricing</div>
      <div id="psplusModalPrices" style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:1.25rem;"></div>
      <!-- Notes -->
      <div id="psplusModalNotes" style="font-size:0.8rem;color:#666;margin-bottom:1.25rem;display:none;"></div>
      <!-- Actions -->
      <div style="display:flex;gap:0.75rem;">
        <button onclick="closePsplusModal()" class="btn btn-outline" style="flex:1;">Cancel</button>
        <a href="http://m.me/PlaystationHub00" target="_blank" rel="noopener"
          class="btn" style="flex:1;text-align:center;background:#FFD700;color:#000;font-weight:800;border-radius:50px;padding:0.75rem 1.5rem;text-decoration:none;">📘 Message Us</a>
      </div>
    </div>
  </div>
</div>

<script>
function openPsplusModal(dataStr) {
  const d = JSON.parse(dataStr.replace(/&quot;/g, '"').replace(/&#39;/g, "'"));
  const modal = document.getElementById('psplusModal');
  const cover = document.getElementById('psplusModalCover');
  const placeholder = document.getElementById('psplusModalCoverPlaceholder');

  if (d.cover) {
    cover.src = d.cover; cover.style.display = 'block';
    placeholder.style.display = 'none';
  } else {
    cover.style.display = 'none';
    placeholder.style.display = 'flex';
  }

  document.getElementById('psplusModalTitle').textContent = d.month + ' ' + d.year;


  // Games list
  const gamesEl = document.getElementById('psplusModalGames');
  gamesEl.innerHTML = d.games.length
    ? d.games.map(g => `<div style="font-size:0.85rem;color:#ddd;padding:0.3rem 0;border-bottom:1px solid #1a1a1a;">• ${g}</div>`).join('')
    : '<div style="color:#555;font-size:0.82rem;">No games listed.</div>';

  // Prices
  const p = d.prices || {};
  document.getElementById('psplusModalPrices').innerHTML =
    `<div style="background:#111;border:1px solid #222;border-radius:10px;padding:0.65rem 0.85rem;">
       <div style="font-size:0.7rem;color:#aaa;font-weight:700;margin-bottom:0.4rem;">🎮 Non-Trophy</div>
       <div style="font-size:0.8rem;color:#ddd;">10 Days — <b style="color:#22c55e;">₱${p.nt10||0}</b></div>
       <div style="font-size:0.8rem;color:#ddd;">15 Days — <b style="color:#22c55e;">₱${p.nt15||0}</b></div>
       <div style="font-size:0.8rem;color:#ddd;">30 Days — <b style="color:#22c55e;">₱${p.nt30||0}</b></div>
     </div>
     <div style="background:#111;border:1px solid #222;border-radius:10px;padding:0.65rem 0.85rem;">
       <div style="font-size:0.7rem;color:#ffc400;font-weight:700;margin-bottom:0.4rem;">🏆 Trophy Account</div>
       <div style="font-size:0.8rem;color:#ddd;">10 Days — <b style="color:#ffc400;">₱${p.tr10||0}</b></div>
       <div style="font-size:0.8rem;color:#ddd;">15 Days — <b style="color:#ffc400;">₱${p.tr15||0}</b></div>
       <div style="font-size:0.8rem;color:#ddd;">30 Days — <b style="color:#ffc400;">₱${p.tr30||0}</b></div>
       <div style="font-size:0.72rem;color:#664d00;margin-top:0.3rem;">+₱100 refundable deposit</div>
     </div>`;

  // Notes
  const notesEl = document.getElementById('psplusModalNotes');
  if (d.notes) { notesEl.textContent = '📝 ' + d.notes; notesEl.style.display = ''; }
  else notesEl.style.display = 'none';

  modal.classList.add('active');
}
function closePsplusModal() { document.getElementById('psplusModal').classList.remove('active'); }
</script>
</body>
</html>




